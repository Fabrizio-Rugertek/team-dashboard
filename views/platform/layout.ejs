<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: #F8FAFC; }
  </style>
  <% if (typeof headScripts !== 'undefined') { %><%- headScripts %><% } %>
</head>
<body>
  <!-- Top Nav -->
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-14">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">T</span>
          </div>
          <span class="font-bold text-gray-900 text-lg">Torus</span>
          <span class="text-gray-400 text-sm">Dashboard Platform</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-gray-500"><%= new Date().toLocaleDateString('es-ES', {weekday:'long', day:'numeric', month:'long'}) %></span>
          <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-sm font-semibold text-gray-600">F</div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Page Content -->
  <%- body %>

  <!-- Footer -->
  <footer class="mt-12 py-6 text-center text-sm text-gray-400">
    Torus Dashboard Platform · <%= new Date().getFullYear() %>
    <span class="ml-3 inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-100 text-[11px] font-mono text-gray-500"
          title="Deploy: <%= appDeployAt %>">
      v<%= appVersion %>
    </span>
  </footer>

  <% if (typeof footScripts !== 'undefined') { %><%- footScripts %><% } %>
</body>
</html>
