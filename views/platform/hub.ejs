<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>* { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen">

<!-- Nav -->
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      


      <img src="/img/torus-icon-green.png" alt="Torus" class="h-8 w-auto">
      <span class="text-slate-400 text-sm font-medium">/ Dashboard Platform</span>
    </div>
    <div class="flex items-center gap-3">
      <a href="/" class="text-sm text-slate-500 hover:text-slate-900 font-medium">← Volver</a>
      <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center text-sm font-semibold text-slate-600">F</div>
    </div>
  </div>
</nav>

<!-- Dashboard cards -->
<div class="max-w-7xl mx-auto px-4 py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-slate-900">Dashboards</h1>
    <p class="mt-1 text-slate-500">Plataforma de control y monitoreo</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    
    <a href="/equipo" class="group block bg-white rounded-2xl border-l-4 border-blue-500 border border-slate-200 p-6 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
      <div class="flex items-start justify-between mb-4">
        <span class="text-4xl">👥</span>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800">● Activo</span>

      <h3 class="text-lg font-bold text-slate-900 group-hover:text-blue-600">Control de Equipo</h3>
      <p class="mt-2 text-sm text-slate-500 leading-relaxed">Horas por consultor, anomalías, estado de proyectos y detección de actividades sospechosas</p>
      <div class="mt-4 flex items-center text-blue-600 text-sm font-semibold">
        Abrir →

    </a>

    <a href="/finanzas" class="group block bg-white rounded-2xl border-l-4 border-green-500 border border-slate-200 p-6 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
      <div class="flex items-start justify-between mb-4">
        <span class="text-4xl">📊</span>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800">● Activo</span>

      <h3 class="text-lg font-bold text-slate-900 group-hover:text-green-600">Finanzas</h3>
      <p class="mt-2 text-sm text-slate-500 leading-relaxed">Ingresos, gastos, rentabilidad por proyecto y flujo de caja</p>
      <div class="mt-4 flex items-center text-green-600 text-sm font-semibold">
        Abrir →

    </a>

    <div class="block bg-white rounded-2xl border-l-4 border-slate-300 border border-slate-200 p-6 opacity-60 cursor-not-allowed">
      <div class="flex items-start justify-between mb-4">
        <span class="text-4xl">🎯</span>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-500">○ Próximamente</span>

      <h3 class="text-lg font-bold text-slate-400">Clientes</h3>
      <p class="mt-2 text-sm text-slate-400 leading-relaxed">Estado de proyectos por cliente, SLA, satisfacción y facturación</p>
    </div>

  </div>
</div>

<footer class="text-center text-xs text-slate-400 py-6 mt-8">
  Torus Dashboard Platform · <%= new Date().getFullYear() %>
</footer>

</body>
</html>
