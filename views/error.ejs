<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — Torus Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>* { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center">

<div class="max-w-md w-full mx-4">
  <div class="bg-white rounded-2xl border border-red-200 p-8 text-center shadow-lg">
    <div class="text-6xl mb-4">🚨</div>
    <h1 class="text-2xl font-extrabold text-slate-900 mb-2">Error</h1>
    <p class="text-slate-500 mb-6"><%= message || 'Ocurrió un error inesperado' %></p>
    <a href="/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
      ← Volver al inicio
    </a>
  </div>
</div>

</body>
</html>
