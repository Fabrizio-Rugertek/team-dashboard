<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .rag-red    { background: #FEF2F2; border-color: #FECACA; }
    .rag-amber  { background: #FFFBEB; border-color: #FDE68A; }
    .rag-green  { background: #F0FDF4; border-color: #BBF7D0; }
    .dot-red    { background: #EF4444; }
    .dot-amber  { background: #F59E0B; }
    .dot-green  { background: #22C55E; }
    .filter-btn.active { background:#2563EB; color:#fff; border-color:#2563EB; }
    .filter-btn:hover:not(.active) { background:#EFF6FF; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

<%# ── Nav ──────────────────────────────────────────────────────────────────── %>
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <img src="/img/torus-icon-green.png" alt="Torus" class="h-8 w-auto">
      <span class="text-slate-400 text-sm font-medium">/ Portfolio de Proyectos</span>
      <span class="text-slate-300">·</span>
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800">Inicio</a>
      <span class="text-slate-300">·</span>
      <a href="/equipo" class="text-sm font-medium text-blue-600 hover:text-blue-800">Equipo</a>
      <span class="text-slate-300">·</span>
      <a href="/crm" class="text-sm font-medium text-amber-600 hover:text-amber-800">CRM</a>
      <span class="text-slate-300">·</span>
      <a href="/sop" class="text-sm font-medium text-violet-600 hover:text-violet-800">SOPs</a>
      <% if (user && ['admin','director'].includes(user.role)) { %>
      <span class="text-slate-300">·</span>
      <a href="/finanzas" class="text-sm font-medium text-green-600 hover:text-green-800">Finanzas</a>
      <% } %>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <span>Actualizado: <%= lastUpdate %></span>
        <span class="px-1.5 py-0.5 rounded bg-slate-100 font-mono text-[10px] text-slate-400"
              title="Deploy: <%= appDeployAt %>">v<%= appVersion %></span>
      </div>
      <% if (user) { %>
      <div class="flex items-center gap-2">
        <% if (user.picture) { %>
        <img src="<%= user.picture %>" class="w-7 h-7 rounded-full border border-slate-200" alt="">
        <% } else { %>
        <div class="w-7 h-7 bg-sky-200 rounded-full flex items-center justify-center text-xs font-bold text-sky-800">
          <%= (user.name||user.email).slice(0,1).toUpperCase() %>
        </div>
        <% } %>
        <span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span>
        <span class="text-xs px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-500 font-semibold capitalize"><%= user.role %></span>
        <form action="/auth/logout" method="POST" class="inline">
          <button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Salir</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%# ── Page title ─────────────────────────────────────────────────────────── %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-extrabold text-slate-900">Portfolio de Proyectos</h1>
      <p class="text-sm text-slate-500 mt-1">
        <%= totalActive %> proyectos activos ·
        <span class="text-red-600 font-semibold"><%= redCount %> en riesgo</span> ·
        <span class="text-amber-600 font-semibold"><%= amberCount %> atención</span> ·
        <span class="text-green-600 font-semibold"><%= greenCount %> saludables</span>
      </p>
    </div>
  </div>

  <%# ── KPI bar ─────────────────────────────────────────────────────────────── %>
  <section class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Total Activos</div>
      <div class="text-3xl font-black text-slate-900"><%= totalActive %></div>
      <div class="text-xs text-slate-400 mt-1">proyectos en curso</div>
    </div>
    <div class="bg-red-50 rounded-xl border border-red-200 p-4">
      <div class="text-xs font-semibold text-red-600 uppercase tracking-wide mb-1">En Riesgo</div>
      <div class="text-3xl font-black text-red-600"><%= redCount %></div>
      <div class="text-xs text-red-400 mt-1">requieren atención urgente</div>
    </div>
    <div class="bg-amber-50 rounded-xl border border-amber-200 p-4">
      <div class="text-xs font-semibold text-amber-600 uppercase tracking-wide mb-1">Atención</div>
      <div class="text-3xl font-black text-amber-600"><%= amberCount %></div>
      <div class="text-xs text-amber-400 mt-1">monitorear de cerca</div>
    </div>
    <div class="bg-green-50 rounded-xl border border-green-200 p-4">
      <div class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Saludables</div>
      <div class="text-3xl font-black text-green-600"><%= greenCount %></div>
      <div class="text-xs text-green-400 mt-1">en buen estado</div>
    </div>
  </section>

  <%# ── Portfolio table ────────────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-slate-100 flex flex-wrap items-center gap-3">
      <span class="text-sm font-bold text-slate-700">Proyectos</span>
      <div class="flex items-center gap-1.5 ml-auto flex-wrap">
        <%# Search input %>
        <input type="text" id="projectSearch" placeholder="Buscar proyecto o cliente..."
               oninput="filterTable()"
               class="px-3 py-1.5 text-xs border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 w-52">
        <%# RAG filter buttons %>
        <button onclick="setRagFilter('all')"       id="rag-btn-all"        class="filter-btn active px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold transition-colors">Todos</button>
        <button onclick="setRagFilter('red')"       id="rag-btn-red"        class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 transition-colors">🔴 Riesgo</button>
        <button onclick="setRagFilter('amber')"     id="rag-btn-amber"      class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 transition-colors">🟡 Atención</button>
        <button onclick="setRagFilter('green')"     id="rag-btn-green"      class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 transition-colors">✅ Saludables</button>
        <button onclick="setRagFilter('completed')" id="rag-btn-completed"  class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 transition-colors">Completados</button>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs" id="projectsTable">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-semibold uppercase tracking-wide text-[10px]">
            <th class="text-left px-4 py-3">Proyecto</th>
            <th class="text-left px-4 py-3">Cliente</th>
            <th class="text-left px-4 py-3">Responsable</th>
            <th class="text-left px-4 py-3 min-w-[160px]">Budget Horas</th>
            <th class="text-center px-4 py-3">Tareas</th>
            <th class="text-left px-4 py-3">Go-Live</th>
            <th class="text-right px-4 py-3">Última actividad</th>
          </tr>
        </thead>
        <tbody id="projectsBody">
          <% projects.forEach(p => {
            const today = new Date();
            const dotCls   = p.rag === 'red' ? 'dot-red' : p.rag === 'amber' ? 'dot-amber' : 'dot-green';
            const rowData  = `data-rag="${p.rag}" data-completed="${p.isCompleted ? 'true' : 'false'}"
                              data-name="${(p.fullName||p.name||'').toLowerCase().replace(/"/g,'')}"
                              data-client="${(p.client||'').toLowerCase().replace(/"/g,'')}"`;

            // Budget bar
            const pct = p.hoursPct || 0;
            const barColor = pct >= 100 ? 'bg-red-500' : pct >= 80 ? 'bg-amber-400' : 'bg-green-500';
            const pctText  = pct >= 100 ? 'text-red-600' : pct >= 80 ? 'text-amber-600' : 'text-green-600';

            // Go-live date
            let goLiveDisplay = '—';
            let goLiveCls = 'text-slate-400';
            if (p.goLiveDate) {
              const glDate = new Date(p.goLiveDate + 'T00:00:00');
              const diffDays = Math.round((glDate - today) / 86400000);
              const formatted = glDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
              if (diffDays < 0) {
                goLiveDisplay = `⚠ ${formatted}`;
                goLiveCls = 'text-red-600 font-bold';
              } else if (diffDays <= 30) {
                goLiveDisplay = formatted;
                goLiveCls = 'text-amber-600 font-semibold';
              } else {
                goLiveDisplay = formatted;
                goLiveCls = 'text-green-600';
              }
            }
          %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors proj-row" <%- rowData %>>
            <%# RAG + name %>
            <td class="px-4 py-3">
              <div class="flex items-start gap-2">
                <div class="w-2.5 h-2.5 rounded-full mt-0.5 flex-shrink-0 <%= dotCls %>"></div>
                <a href="<%= odooUrl %>/odoo/project/<%= p.id %>" target="_blank" rel="noopener"
                   class="font-semibold text-slate-800 hover:text-blue-600 transition-colors leading-snug"
                   style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;max-width:220px;"
                   title="<%= p.fullName || p.name %>">
                  <%= p.fullName || p.name %>
                </a>
              </div>
            </td>
            <%# Client %>
            <td class="px-4 py-3 text-slate-600"><%= p.client || '<span class="text-slate-300">Sin cliente</span>' %></td>
            <%# Responsible %>
            <td class="px-4 py-3 text-slate-600"><%= p.responsible || '—' %></td>
            <%# Budget hours %>
            <td class="px-4 py-3">
              <% if (p.totalAlloc > 0) { %>
              <div class="flex items-center justify-between mb-1">
                <span class="text-slate-700 font-medium"><%= p.totalLog %>h / <%= p.totalAlloc %>h</span>
                <span class="font-bold <%= pctText %>"><%= pct %>%</span>
              </div>
              <div class="w-full bg-slate-100 rounded-full h-1.5">
                <div class="h-1.5 rounded-full <%= barColor %>" style="width:<%= Math.min(pct, 100) %>%"></div>
              </div>
              <% if (p.budgetHours > 0 && p.budgetHours !== p.totalAlloc) { %>
              <div class="text-[10px] text-slate-400 mt-0.5">Contrato: <%= p.budgetHours %>h</div>
              <% } %>
              <% } else if (p.totalLog > 0) { %>
              <span class="text-slate-500"><%= p.totalLog %>h registradas</span>
              <% } else { %>
              <span class="text-slate-300">Sin estimación</span>
              <% } %>
            </td>
            <%# Tasks %>
            <td class="px-4 py-3 text-center">
              <span class="font-bold text-slate-800"><%= p.openTasks %></span>
              <span class="text-slate-400"> / <%= p.totalTasks %></span>
            </td>
            <%# Go-live %>
            <td class="px-4 py-3 <%= goLiveCls %> whitespace-nowrap"><%- goLiveDisplay %></td>
            <%# Last activity %>
            <td class="px-4 py-3 text-right">
              <span class="<%= p.daysSinceUpdate >= 14 ? 'text-red-600 font-bold' : p.daysSinceUpdate >= 7 ? 'text-amber-600 font-semibold' : 'text-slate-400' %>">
                <% if (p.daysSinceUpdate > 99) { %>—<% } else { %><%= p.daysSinceUpdate %>d<% } %>
              </span>
            </td>
          </tr>
          <% }) %>
          <% if (!projects.length) { %>
          <tr><td colspan="7" class="py-12 text-center text-slate-400">No hay proyectos disponibles.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <%# ── Capacity section ────────────────────────────────────────────────────── %>
  <section>
    <h2 class="text-lg font-extrabold text-slate-900 mb-1">Capacidad del Equipo</h2>
    <p class="text-sm text-slate-500 mb-4">Horas comprometidas en tareas abiertas vs disponibilidad hasta fin de mes</p>

    <% const capData = capacityData || []; %>
    <% if (capData.length === 0) { %>
    <div class="bg-white rounded-xl border border-slate-200 p-8 text-center text-slate-400">
      No hay datos de capacidad disponibles.
    </div>
    <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      <% capData.forEach(c => {
        const statusMap = {
          overloaded: { label: '🔴 Saturado',    cls: 'border-red-200 bg-red-50',      badgeCls: 'bg-red-100 text-red-700',      barCls: 'bg-red-500' },
          busy:       { label: '🟠 Ocupado',      cls: 'border-amber-200 bg-amber-50',  badgeCls: 'bg-amber-100 text-amber-700',  barCls: 'bg-amber-400' },
          available:  { label: '🟢 Disponible',   cls: 'border-blue-200 bg-blue-50',    badgeCls: 'bg-blue-100 text-blue-700',    barCls: 'bg-blue-400' },
          free:       { label: '⚪ Libre',         cls: 'border-slate-200 bg-slate-50',  badgeCls: 'bg-slate-100 text-slate-600',  barCls: 'bg-slate-300' },
        };
        const sm = statusMap[c.status] || statusMap.free;
      %>
      <div class="bg-white rounded-xl border-2 <%= sm.cls %> p-4">
        <div class="flex items-center justify-between mb-2">
          <div class="font-bold text-slate-900 text-sm truncate"><%= c.name %></div>
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full <%= sm.badgeCls %> whitespace-nowrap ml-2"><%= sm.label %></span>
        </div>
        <div class="mb-2">
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-500"><%= (c.allocated||0).toFixed(1) %>h comprometidas</span>
            <span class="font-bold"><%= c.utilPct %>%</span>
          </div>
          <div class="w-full bg-slate-200 rounded-full h-2">
            <div class="h-2 rounded-full transition-all <%= sm.barCls %>" style="width:<%= Math.min(c.utilPct, 100) %>%"></div>
          </div>
        </div>
        <div class="text-[10px] text-slate-400"><%= (c.allocated||0).toFixed(1) %>h comprometidas / <%= (c.hoursAvailable||0).toFixed(0) %>h disponibles este mes</div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>

  <%# ── Alertas activas ────────────────────────────────────────────────────── %>
  <% const alerts = projectAlerts || []; %>
  <% if (alerts.length > 0) { %>
  <section>
    <h2 class="text-lg font-extrabold text-slate-900 mb-4">Alertas Activas</h2>
    <%
      // Group by project
      const alertsByProject = {};
      alerts.forEach(a => {
        if (!alertsByProject[a.project]) alertsByProject[a.project] = [];
        alertsByProject[a.project].push(a);
      });
    %>
    <div class="space-y-3">
      <% Object.entries(alertsByProject).forEach(([proj, projAlerts]) => { %>
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-2.5 bg-slate-50 border-b border-slate-100 flex items-center gap-2">
          <span class="font-bold text-slate-800 text-sm"><%= proj %></span>
          <span class="text-xs text-slate-400"><%= projAlerts.length %> alerta<%= projAlerts.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="divide-y divide-slate-50">
          <% projAlerts.forEach(a => {
            const isCrit = a.severity === 'critical';
            const dotColor = isCrit ? 'bg-red-500' : 'bg-amber-400';
            const badgeCls = isCrit ? 'bg-red-100 text-red-700 border-red-200' : 'bg-amber-100 text-amber-700 border-amber-200';
            const badgeLabel = isCrit ? 'Crítico' : 'Warning';
          %>
          <div class="px-4 py-2.5 flex items-start gap-3">
            <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 <%= dotColor %>"></div>
            <div class="flex-1 min-w-0">
              <span class="text-xs text-slate-700"><%= a.message %></span>
            </div>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border <%= badgeCls %> flex-shrink-0"><%= badgeLabel %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>

</div><!-- /main -->

<script>
  let currentRagFilter = 'all';

  function setRagFilter(rag) {
    currentRagFilter = rag;
    // Update button states
    ['all','red','amber','green','completed'].forEach(r => {
      const btn = document.getElementById('rag-btn-' + r);
      if (!btn) return;
      btn.classList.toggle('active', r === rag);
    });
    filterTable();
  }

  function filterTable() {
    const search  = (document.getElementById('projectSearch').value || '').toLowerCase();
    const rows    = document.querySelectorAll('.proj-row');

    rows.forEach(row => {
      const rag       = row.dataset.rag       || 'green';
      const completed = row.dataset.completed === 'true';
      const name      = row.dataset.name      || '';
      const client    = row.dataset.client    || '';

      let ragMatch = true;
      if (currentRagFilter === 'completed') {
        ragMatch = completed;
      } else if (currentRagFilter !== 'all') {
        ragMatch = !completed && rag === currentRagFilter;
      } else {
        ragMatch = true;
      }

      const searchMatch = !search || name.includes(search) || client.includes(search);

      row.style.display = (ragMatch && searchMatch) ? '' : 'none';
    });
  }
</script>

</body>
</html>
