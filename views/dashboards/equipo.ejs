<!DOCTYPE html>

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-100 min-h-screen">

<!-- Nav -->
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white text-sm">T</div>
      <span class="font-bold text-slate-900 text-lg">Torus</span>
      <span class="text-slate-400 text-sm font-medium">/ Control de Equipo</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span>Actualizado: <%= lastUpdate %></span>
      </div>
      <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center text-sm font-bold text-slate-600">F</div>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">

<!-- ══════════════════════════════════════════════════════════════ -->
<!-- HERO: ALERTAS (la sección más importante)                    -->
<!-- ══════════════════════════════════════════════════════════════ -->
<section>
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <span class="text-2xl">🚨</span>
      <h2 class="text-xl font-extrabold text-slate-900">Alertas y Validaciones</h2>
    </div>
    <!-- Filter tabs -->
    <div class="flex gap-1 bg-slate-100 rounded-lg p-1" id="alertFilters">
      <button class="alert-filter-btn active px-3 py-1.5 rounded-md text-xs font-bold" data-filter="all">Todas <span class="ml-1"><%= criticalCount + warningCount + infoCount %></span></button>
      <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-red-700 bg-red-100" data-filter="critical">🚨 <%= criticalCount %></button>
      <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-amber-700" data-filter="warning">🟡 <%= warningCount %></button>
      <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-blue-700" data-filter="info">💤 <%= infoCount %></button>
    </div>
  </div>

  <!-- Alert summary cards -->
  <div class="grid grid-cols-3 gap-4 mb-4">
    <div class="bg-white rounded-xl border-2 border-red-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-red-50 transition-colors" onclick="filterAlerts('critical')">
      <div class="text-4xl">🚨</div>
      <div>
        <div class="text-3xl font-black text-red-600"><%= criticalCount %></div>
        <div class="text-xs font-semibold text-red-500 uppercase tracking-wide">Críticas</div>
        <div class="text-xs text-slate-400 mt-0.5">Requieren atención inmediata</div>
      </div>
    </div>
    <div class="bg-white rounded-xl border-2 border-amber-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-amber-50 transition-colors" onclick="filterAlerts('warning')">
      <div class="text-4xl">🟡</div>
      <div>
        <div class="text-3xl font-black text-amber-600"><%= warningCount %></div>
        <div class="text-xs font-semibold text-amber-500 uppercase tracking-wide">Warnings</div>
        <div class="text-xs text-slate-400 mt-0.5">Revisar y corregir</div>
      </div>
    </div>
    <div class="bg-white rounded-xl border-2 border-blue-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-blue-50 transition-colors" onclick="filterAlerts('info')">
      <div class="text-4xl">💤</div>
      <div>
        <div class="text-3xl font-black text-blue-600"><%= infoCount %></div>
        <div class="text-xs font-semibold text-blue-500 uppercase tracking-wide">Info</div>
        <div class="text-xs text-slate-400 mt-0.5">Monitoreo pasivo</div>
      </div>
    </div>
  </div>

  <!-- Alerts table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto max-h-80 overflow-y-auto" id="alertsContainer">
      <table class="w-full text-sm">
        <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
          <tr>
            <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs w-10">#</th>
            <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-16">Nivel</th>
            <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-28">Consultor</th>
            <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs">Mensaje</th>
            <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-28">Categoría</th>
            <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs">Detalle</th>
          </tr>
        </thead>
        <tbody id="alertsTableBody">
          <% anomalies.forEach((a, i) => { %>
          <tr class="alert-row border-b border-slate-50 hover:bg-slate-50 transition-colors" data-type="<%= a.type %>" data-category="<%= a.category %>">
            <td class="py-2.5 px-4 text-slate-400 text-xs"><%= i + 1 %></td>
            <td class="py-2.5 px-3">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold
                <%= a.type === 'critical' ? 'bg-red-100 text-red-700' : a.type === 'warning' ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                <%= a.type === 'critical' ? '🚨' : a.type === 'warning' ? '🟡' : '💤' %>
                <%= a.type.charAt(0).toUpperCase() + a.type.slice(1) %>
              </span>
            </td>
            <td class="py-2.5 px-3">
              <div class="font-medium text-slate-800 text-xs"><%= a.user %></div>
            </td>
            <td class="py-2.5 px-4">
              <div class="font-semibold text-slate-800 text-xs"><%= a.message %></div>
            </td>
            <td class="py-2.5 px-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <%= a.category === 'exceso_dia' ? 'bg-red-50 text-red-600' :
                   a.category === 'horas_inhabituales' ? 'bg-orange-50 text-orange-600' :
                   a.category === 'sin_estimacion' ? 'bg-amber-50 text-amber-600' :
                   a.category === 'descripcion_mecanica' ? 'bg-yellow-50 text-yellow-700' :
                   a.category === 'tarea_sin_fechas' ? 'bg-indigo-50 text-indigo-600' :
                   a.category === 'hijo_sin_sprint' ? 'bg-violet-50 text-violet-600' :
                   a.category === 'inactivo' ? 'bg-slate-100 text-slate-600' :
                   'bg-slate-100 text-slate-600' %>">
                <%= a.category === 'exceso_dia' ? '⚡ Exceso' :
                   a.category === 'horas_inhabituales' ? '📅 Fds/Feriado' :
                   a.category === 'sin_estimacion' ? '📊 Sin estimación' :
                   a.category === 'descripcion_mecanica' ? '🤖 Desc. mecánica' :
                   a.category === 'tarea_sin_fechas' ? '📅 Sin fechas' :
                   a.category === 'hijo_sin_sprint' ? '🔗 Hijo sin sprint' :
                   a.category === 'inactivo' ? '💤 Sin actividad' :
                   a.category %>
              </span>
            </td>
            <td class="py-2.5 px-4">
              <div class="text-xs text-slate-500 max-w-xs truncate" title="<%= a.detail %>"><%= a.detail %></div>
            </td>
          </tr>
          <% }) %>
          <% if (anomalies.length === 0) { %>
          <tr>
            <td colspan="6" class="py-12 text-center">
              <div class="text-4xl mb-2">✅</div>
              <div class="font-bold text-green-600 text-lg">Sin anomalías detectadas</div>
              <div class="text-sm text-slate-400 mt-1">Todo está en orden esta semana</div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════ -->
<!-- BILLABLE VS NON-BILLABLE                                        -->
<!-- ══════════════════════════════════════════════════════════════ -->
<section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- KPI Cards -->
  <div class="lg:col-span-2 grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Horas Semana</div>
      <div class="text-2xl font-black text-slate-900"><%= summary.weekHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.activeUsers %> consultores activos</div>
    </div>
    <div class="bg-white rounded-xl border-2 border-green-200 p-4">
      <div class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">💰 Billable</div>
      <div class="text-2xl font-black text-green-600"><%= summary.billableWeek %>h</div>
      <div class="text-xs text-slate-400 mt-1">
        <%= summary.weekHours > 0 ? Math.round(summary.billableWeek / summary.weekHours * 100) : 0 %>% del total
      </div>
    </div>
    <div class="bg-white rounded-xl border-2 border-orange-200 p-4">
      <div class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">📁 Non-Billable</div>
      <div class="text-2xl font-black text-orange-600"><%= summary.nonBillableWeek %>h</div>
      <div class="text-xs text-slate-400 mt-1">
        <%= summary.weekHours > 0 ? Math.round(summary.nonBillableWeek / summary.weekHours * 100) : 0 %>% del total
      </div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Horas Mes</div>
      <div class="text-2xl font-black text-slate-900"><%= summary.monthHours %>h</div>
      <div class="text-xs text-slate-400 mt-1">
        <%= summary.billableMonth %> billable / <%= summary.nonBillableMonth %> non
      </div>
    </div>
  </div>

  <!-- Donut Chart -->
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-3">Billable vs Non-Billable (semana)</div>
    <div style="height: 160px;">
      <canvas id="billableChart"></canvas>
    </div>
    <div class="flex justify-center gap-6 mt-3">
      <div class="flex items-center gap-1.5 text-xs">
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
        <span class="font-medium text-slate-700">Billable <%= summary.weekHours > 0 ? Math.round(summary.billableWeek / summary.weekHours * 100) : 0 %>%</span>
      </div>
      <div class="flex items-center gap-1.5 text-xs">
        <div class="w-3 h-3 rounded-full bg-orange-400"></div>
        <span class="font-medium text-slate-700">Non-Billable <%= summary.weekHours > 0 ? Math.round(summary.nonBillableWeek / summary.weekHours * 100) : 0 %>%</span>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════ -->
<!-- WEEKLY CHART + CONSULTANTS                                      -->
<!-- ══════════════════════════════════════════════════════════════ -->
<section class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Weekly Hours Chart -->
  <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="font-bold text-slate-800 mb-4">📈 Horas por Semana</h3>
    <div style="height: 200px;">
      <canvas id="weeklyChart"></canvas>
    </div>
  </div>

  <!-- Top Consultants -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="font-bold text-slate-800 mb-3">👥 Top Consultores</h3>
    <div class="space-y-3 max-h-52 overflow-y-auto">
      <% consultants.slice(0, 8).forEach((c, i) => { %>
      <div class="flex items-center gap-2 <%= !c.hasHours ? 'opacity-40' : '' %>">
        <div class="w-7 h-7 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">
          <%= (c.name || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase() %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-xs font-semibold text-slate-800 truncate"><%= c.name %></div>
          <% if (c.job) { %><div class="text-xs text-slate-400 truncate"><%= c.job %></div><% } %>
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-sm font-bold <%= c.hasHours ? 'text-slate-900' : 'text-slate-400' %>"><%= c.hoursThisWeek %>h</div>
          <div class="text-xs <%= c.billableWeek > c.nonBillableWeek ? 'text-green-600' : 'text-orange-500' %>">
            💰<%= c.billableWeek %> / 📁<%= c.nonBillableWeek %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

</section>

<!-- ══════════════════════════════════════════════════════════════ -->
<!-- PROJECT STATUS TABLE                                             -->
<!-- ══════════════════════════════════════════════════════════════ -->
<section class="bg-white rounded-xl border border-slate-200 p-5">
  <h3 class="font-bold text-slate-800 mb-4">📋 Estado de Proyectos</h3>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b-2 border-slate-100">
          <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Proyecto</th>
          <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Avance</th>
          <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Log</th>
          <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Estimado</th>
          <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Ab. / Hechas</th>
          <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Backlog</th>
          <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Actualización</th>
        </tr>
      </thead>
      <tbody>
        <% projectStatuses.forEach(p => { %>
        <tr class="border-b border-slate-50 hover:bg-slate-50 <%= p.needsAttention ? 'bg-red-50' : '' %>">
          <td class="py-2 px-3">
            <div class="font-medium text-slate-800 text-xs"><%= p.name %></div>
            <% if (p.needsAttention) { %><span class="text-xs text-red-600 font-semibold">⚠️ Revisar</span><% } %>
          </td>
          <td class="py-2 px-3 text-center">
            <span class="font-bold <%= p.stageProgress > 80 ? 'text-green-600' : p.stageProgress > 50 ? 'text-amber-500' : 'text-slate-400' %>"><%= p.stageProgress %>%</span>
          </td>
          <td class="py-2 px-3 text-right <%= p.hoursPct && p.hoursPct > 120 ? 'text-red-600 font-bold' : p.hoursPct && p.hoursPct > 100 ? 'text-amber-600' : 'text-green-600' %>">
            <%= p.totalLog %>h<%= p.hoursPct ? ` (${p.hoursPct}%)` : '' %>
          </td>
          <td class="py-2 px-3 text-right text-slate-400"><%= p.totalAlloc > 0 ? p.totalAlloc + 'h' : '—' %></td>
          <td class="py-2 px-3 text-center text-slate-500"><%= p.openTasks %> / <%= p.doneTasks %></td>
          <td class="py-2 px-3 text-center text-slate-400"><%= p.backlogTasks %></td>
          <td class="py-2 px-3 text-center">
            <span class="<%= p.daysSinceUpdate > 14 ? 'text-red-600 font-bold' : p.daysSinceUpdate > 7 ? 'text-amber-500' : 'text-green-600' %> text-xs font-semibold">
              <%= p.daysSinceUpdate > 14 ? '🔴' : p.daysSinceUpdate > 7 ? '🟡' : '🟢' %>
              <%= p.daysSinceUpdate > 99 ? 'Nunca' : `Hace ${p.daysSinceUpdate}d` %>
            </span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

</div>

<footer class="text-center text-xs text-slate-400 py-6 mt-8">
  Torus Dashboard Platform · <%= new Date().getFullYear() %>
</footer>

<script>
// ── Alert Filter ─────────────────────────────────────────────────
let currentFilter = 'all';

function filterAlerts(type) {
  currentFilter = type;
  document.querySelectorAll('.alert-filter-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.filter === type);
    btn.classList.toggle('bg-slate-100', btn.dataset.filter !== type);
    btn.classList.toggle('text-slate-600', btn.dataset.filter !== type);
    if (btn.dataset.filter === 'critical') {
      btn.classList.toggle('bg-red-100', btn.dataset.filter === 'critical');
    }
  });
  document.querySelectorAll('.alert-row').forEach(row => {
    const show = type === 'all' || row.dataset.type === type;
    row.style.display = show ? '' : 'none';
  });
}

document.querySelectorAll('.alert-filter-btn').forEach(btn => {
  btn.addEventListener('click', () => filterAlerts(btn.dataset.filter));
});

// ── Charts ────────────────────────────────────────────────────────
const billableData = {
  labels: ['Billable', 'Non-Billable'],
  datasets: [{
    data: [<%= summary.billableWeek %>, <%= summary.nonBillableWeek %>],
    backgroundColor: ['#10B981', '#FB923C'],
    borderWidth: 0,
    hoverOffset: 4
  }]
};

new Chart(document.getElementById('billableChart'), {
  type: 'doughnut',
  data: billableData,
  options: {
    responsive: true,
    maintainAspectRatio: false,
    cutout: '65%',
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw}h` } }
    }
  }
});

const weeklyLabels = <%= JSON.stringify(weeklyLabels) %>;
const weeklyHours = <%= JSON.stringify(weeklyHours) %>;

new Chart(document.getElementById('weeklyChart'), {
  type: 'bar',
  data: {
    labels: weeklyLabels,
    datasets: [{
      label: 'Horas',
      data: weeklyHours,
      backgroundColor: weeklyHours.map((_, i) => i === weeklyHours.length - 1 ? '#3B82F6' : '#BFDBFE'),
      borderRadius: 6,
      borderSkipped: false
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.raw}h` } } },
    scales: {
      y: { beginAtZero: true, grid: { color: '#F1F5F9' }, ticks: { callback: v => v + 'h' } },
      x: { grid: { display: false }, ticks: { font: { size: 11 } } }
    }
  }
});
</script>

</body>
</html>
