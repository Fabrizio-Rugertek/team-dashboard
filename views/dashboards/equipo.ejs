let ganttRendered = false;
function renderGantt() {
  if (ganttRendered) return;
  ganttRendered = true;
  const container = document.getElementById('gantt-container');
  if (!container) return;

  const projectsWithTasks = ganttProjects.filter(p => p.tasks && p.tasks.length > 0);
  if (!projectsWithTasks.length) {
    container.innerHTML = '<div class="py-16 text-center text-slate-400 text-sm">Ningún proyecto tiene tareas con fechas definidas en Odoo.</div>';
    return;
  }

  // ── Global date range ────────────────────────────────────────────────────────
  let minMs = Infinity, maxMs = -Infinity;
  for (const p of projectsWithTasks) {
    for (const t of p.tasks) {
      if (t.start) { const ms = +new Date(t.start); if (ms < minMs) minMs = ms; }
      if (t.end)   { const ms = +new Date(t.end) + 86400000; if (ms > maxMs) maxMs = ms; }
    }
  }
  const todayMs = new Date().setHours(0, 0, 0, 0);
  if (!isFinite(minMs)) minMs = todayMs - 30 * 86400000;
  if (!isFinite(maxMs)) maxMs = todayMs + 30 * 86400000;
  minMs -= 10 * 86400000;   // padding left
  maxMs += 10 * 86400000;   // padding right
  const totalMs = maxMs - minMs;

  function pct(ms) { return Math.max(0, Math.min(100, (ms - minMs) / totalMs * 100)); }
  const todayPct = pct(todayMs).toFixed(2);

  // ── Month grid ───────────────────────────────────────────────────────────────
  const months = [];
  const d = new Date(minMs); d.setDate(1); d.setHours(0, 0, 0, 0);
  const now = new Date();
  while (d.getTime() < maxMs) {
    const nxt = new Date(d); nxt.setMonth(nxt.getMonth() + 1);
    const isCur = d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
    months.push({
      label:    d.toLocaleDateString('es-ES', { month: 'short', year: '2-digit' }),
      pct:      pct(d.getTime()),
      endPct:   pct(Math.min(nxt.getTime(), maxMs)),
      isCurrent: isCur,
    });
    d.setMonth(d.getMonth() + 1);
  }

  // Shared background layer: month highlight + today line (reused in each project)
  const bgHTML =
    months.filter(m => m.isCurrent).map(m =>
      `<div class="absolute top-0 bottom-0" style="left:${m.pct.toFixed(2)}%;width:${(m.endPct-m.pct).toFixed(2)}%;background:rgba(59,130,246,0.07);pointer-events:none"></div>`
    ).join('') +
    `<div class="absolute top-0 bottom-0 w-px" style="left:${todayPct}%;background:#F87171;opacity:0.8;pointer-events:none" title="Hoy · ${now.toLocaleDateString('es-ES')}"></div>`;

  // Month header labels
  const monthHeaderHTML = months.map(m =>
    `<div class="absolute flex items-start h-full" style="left:${m.pct.toFixed(2)}%">
       <div class="w-px h-full ${m.isCurrent ? 'bg-blue-200' : 'bg-slate-100'}"></div>
       <span class="text-[9px] ml-0.5 mt-0.5 ${m.isCurrent ? 'text-blue-500 font-bold' : 'text-slate-300 font-medium'}">${m.label}</span>
     </div>`
  ).join('') +
  `<div class="absolute top-0 flex items-center" style="left:${todayPct}%">
     <div class="w-px h-full bg-red-400 opacity-80"></div>
     <span class="text-[9px] text-red-400 font-bold ml-0.5">hoy</span>
   </div>`;

  // ── Controls bar ─────────────────────────────────────────────────────────────
  let html = `<div class="flex items-center flex-wrap gap-2 mb-4">
    <button onclick="ganttToggleAll(true)"  class="px-2.5 py-1 text-xs rounded-lg border border-slate-200 hover:bg-slate-100 text-slate-600 transition-colors">▸ Expandir subtareas</button>
    <button onclick="ganttToggleAll(false)" class="px-2.5 py-1 text-xs rounded-lg border border-slate-200 hover:bg-slate-100 text-slate-600 transition-colors">▾ Colapsar subtareas</button>
    <div class="flex items-center gap-4 ml-2 text-[11px] text-slate-400">
      <span class="flex items-center gap-1.5"><span class="w-3 h-2 rounded inline-block" style="background:#3B82F6;opacity:0.85"></span>En curso</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-2 rounded inline-block bg-green-400"></span>Completada</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-2 rounded inline-block bg-red-400"></span>Vencida</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-px h-3.5 bg-red-400 opacity-80"></span><span class="inline-block w-2.5 h-1 rounded" style="background:rgba(59,130,246,0.2)"></span> Mes actual</span>
    </div>
    <span class="text-[11px] text-slate-400 ml-2">Clic en tarea o barra para abrir en Odoo</span>
  </div>`;

  // ── Per-project blocks ────────────────────────────────────────────────────────
  projectsWithTasks.forEach((p, pi) => {
    // Separate parent vs child tasks
    const parentTasks = p.tasks.filter(t => !t.parentId);
    const childMap = {};
    p.tasks.forEach(t => {
      if (t.parentId) {
        if (!childMap[t.parentId]) childMap[t.parentId] = [];
        childMap[t.parentId].push(t);
      }
    });

    // Build label + bar rows as parallel strings
    let labelRows = `<div class="h-7 flex items-end pb-1 pr-2">
      <span class="text-[9px] text-slate-300 uppercase tracking-wide font-semibold">Tarea</span>
    </div>`;
    let barRows = `<div class="relative h-7 border-b border-slate-100">${monthHeaderHTML}</div>`;

    function addRow(t, isChild) {
      if (!t.start && !t.end) return;
      const s = t.start ? +new Date(t.start) : null;
      const e = t.end   ? +new Date(t.end) + 86400000 : s ? s + 86400000 : null;
      const barLeft  = pct(s || e).toFixed(2);
      const barWidth = Math.max(0.4, pct(e) - pct(s || e)).toFixed(2);
      const isOverdue = !t.done && t.end && +new Date(t.end) < todayMs;
      const barColor  = t.done ? '#4ADE80' : isOverdue ? '#F87171' : '#3B82F6';
      const barOpacity = t.done ? '1' : '0.85';
      const labelCls  = isChild ? 'text-[10px] text-slate-400 pl-5' : 'text-[11px] text-slate-700 font-medium';
      const hasKids   = !isChild && childMap[t.id] && childMap[t.id].length > 0;
      const lbl       = parseFloat(barWidth) > 5 ? escHtml(t.name.slice(0, 22)) : '';
      const tooltip   = `${escHtml(t.name)}${t.assignee ? ' · ' + escHtml(t.assignee) : ''}${t.allocHours ? ' · ' + t.allocHours + 'h est.' : ''}`;

      labelRows += `<div class="h-5 flex items-center gap-0.5 group pr-2">
        ${hasKids
          ? `<button class="text-slate-300 hover:text-blue-500 w-3 shrink-0 text-[10px] leading-none transition-colors"
               onclick="ganttToggleKids(${pi},${t.id},this)" title="Expandir subtareas">▸</button>`
          : `<span class="w-3 shrink-0"></span>`}
        <a href="https://www.torus.dev/web#id=${t.id}&model=project.task" target="_blank" rel="noopener"
           class="${labelCls} truncate hover:text-blue-600 transition-colors leading-tight" title="${tooltip}">
          ${escHtml(t.name)}
        </a>
      </div>`;

      barRows += `<div class="relative h-5">
        <a href="https://www.torus.dev/web#id=${t.id}&model=project.task" target="_blank" rel="noopener"
           class="absolute top-0.5 h-4 rounded flex items-center px-1 overflow-hidden transition-opacity hover:opacity-100 cursor-pointer"
           style="left:${barLeft}%;width:${barWidth}%;background:${barColor};opacity:${barOpacity}"
           title="${tooltip}: ${t.start||'?'} → ${t.end||'?'}">
          <span class="text-[10px] text-white font-semibold truncate whitespace-nowrap">${lbl}</span>
        </a>
      </div>`;

      if (hasKids) {
        const kids = childMap[t.id];
        labelRows += `<div id="gantt-lk-${pi}-${t.id}" class="hidden">`;
        barRows   += `<div id="gantt-bk-${pi}-${t.id}" class="hidden">`;
        kids.forEach(ct => addRow(ct, true));
        labelRows += `</div>`;
        barRows   += `</div>`;
      }
    }

    parentTasks.forEach(t => addRow(t, false));

    const responsibleHTML = p.responsible
      ? `<span class="text-xs text-slate-400 flex items-center gap-1 shrink-0">
           <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
           ${escHtml(p.responsible)}
         </span>`
      : '';

    html += `<div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-3">
      <div class="flex items-center justify-between px-4 py-3 bg-slate-50/70 border-b border-slate-100">
        <div class="min-w-0 flex-1">
          <div class="font-bold text-slate-900 text-sm leading-snug">${escHtml(p.name)}</div>
          <div class="flex items-center gap-4 mt-0.5">
            ${responsibleHTML}
            <span class="text-xs text-slate-400">${p.tasks.length} tareas con fechas</span>
            ${Object.keys(childMap).length > 0 ? `<span class="text-xs text-slate-400">· ${p.tasks.filter(t=>t.parentId).length} subtareas (▸ para expandir)</span>` : ''}
          </div>
        </div>
        <a href="https://www.torus.dev/web#id=${p.id}&model=project.project" target="_blank" rel="noopener"
           class="ml-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-100 text-xs font-semibold text-slate-500 hover:bg-blue-100 hover:text-blue-600 transition-colors shrink-0">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Abrir proyecto
        </a>
      </div>
      <div class="p-3 overflow-x-auto">
        <div class="flex" style="min-width:600px">
          <div class="w-48 shrink-0 relative z-10">${labelRows}</div>
          <div class="flex-1 relative">
            <div class="absolute inset-0 pointer-events-none z-0">${bgHTML}</div>
            <div class="relative z-10">${barRows}</div>
          </div>
        </div>
      </div>
    </div>`;
  });

  container.innerHTML = html;
}

function ganttToggleKids(pi, taskId, btn) {
  const lk = document.getElementById(`gantt-lk-${pi}-${taskId}`);
  const bk = document.getElementById(`gantt-bk-${pi}-${taskId}`);
  if (!lk || !bk) return;
  const expanding = lk.classList.contains('hidden');
  lk.classList.toggle('hidden', !expanding);
  bk.classList.toggle('hidden', !expanding);
  btn.textContent = expanding ? '▾' : '▸';
}

function ganttToggleAll(expand) {
  document.querySelectorAll('[id^="gantt-lk-"],[id^="gantt-bk-"]').forEach(el => el.classList.toggle('hidden', !expand));
  document.querySelectorAll('button[onclick^="ganttToggleKids"]').forEach(btn => { btn.textContent = expand ? '▾' : '▸'; });
}

// ── Manual refresh ─────────────────────────────────────────────────────────────
async function manualRefresh() {
  const btn = document.getElementById('refreshBtn');
  const dot = document.getElementById('refreshDot');
  if (btn) { btn.textContent = '...'; btn.disabled = true; }
  if (dot) { dot.classList.remove('bg-green-500'); dot.classList.add('bg-amber-400'); }
  try {
    const res = await fetch('/equipo/refresh', { method: 'POST' });
    if (res.ok) {
      window.location.reload();
    } else {
      alert('Error al actualizar. Intentá de nuevo.');
      if (btn) { btn.textContent = '↺'; btn.disabled = false; }
      if (dot) { dot.classList.remove('bg-amber-400'); dot.classList.add('bg-green-500'); }
    }
  } catch(e) {
    alert('Error de conexión.');
    if (btn) { btn.textContent = '↺'; btn.disabled = false; }
    if (dot) { dot.classList.remove('bg-amber-400'); dot.classList.add('bg-green-500'); }
  }
}
</script>
</body>
</html>
