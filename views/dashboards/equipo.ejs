// ── Scrum Charts ──────────────────────────────────────────────────────────────
const SCRUM_COLORS = ['#3B82F6','#10B981','#8B5CF6','#F59E0B','#EF4444','#06B6D4'];
const _miniVelCharts   = {};
let   _spDistChart     = null;
let   _velocityHistChart = null;

const _scrumTeams = <%- JSON.stringify(scrumTeams || []) %>;

function renderMiniVelChart(teamId, history, colorIdx) {
  const canvas = document.getElementById(`velChart_${teamId}`);
  if (!canvas) return;
  if (_miniVelCharts[teamId]) { _miniVelCharts[teamId].destroy(); }
  const color = SCRUM_COLORS[colorIdx % SCRUM_COLORS.length];
  _miniVelCharts[teamId] = new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: {
      labels: history.map(h => h.name),
      datasets: [
        { label: 'SP Done',        data: history.map(h => h.spCompleted), backgroundColor: color + 'CC', borderRadius: 3, borderSkipped: false, order: 1 },
        { label: 'SP Comprometidos', data: history.map(h => h.spCommitted), backgroundColor: '#E2E8F0', borderRadius: 3, borderSkipped: false, order: 2 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.raw} SP` } } },
      scales: { y: { beginAtZero: true, display: false }, x: { grid: { display: false }, ticks: { font: { size: 9 } } } }
    }
  });
}

function renderSpDistChart(teams) {
  const canvas = document.getElementById('spDistChart');
  if (!canvas) return;
  if (_spDistChart) { _spDistChart.destroy(); }
  const SP_LABELS = ['1','2','3','5','8','13'];
  const datasets = teams.map((team, i) => ({
    label: team.name,
    data:  SP_LABELS.map(v => (team.spDistribution || {})[parseInt(v)] || 0),
    backgroundColor: SCRUM_COLORS[i % SCRUM_COLORS.length] + 'CC',
    borderRadius: 4, borderSkipped: false,
  }));
  _spDistChart = new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: { labels: SP_LABELS.map(v => `${v} SP`), datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 12 } } },
      scales: { y: { beginAtZero: true, grid: { color: '#F1F5F9' }, ticks: { precision: 0 } }, x: { grid: { display: false } } }
    }
  });
}

function renderVelocityHistChart(teams) {
  const canvas = document.getElementById('velocityHistChart');
  if (!canvas) return;
  if (_velocityHistChart) { _velocityHistChart.destroy(); }
  const teamsWithHistory = teams.filter(t => t.velocityHistory && t.velocityHistory.length > 0);
  if (!teamsWithHistory.length) {
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#94A3B8'; ctx.font = '12px Inter,sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('Sin sprints cerrados aún', canvas.width / 2, canvas.height / 2);
    return;
  }
  const maxLen  = Math.max(...teamsWithHistory.map(t => t.velocityHistory.length));
  const labels  = Array.from({ length: maxLen }, (_, i) => i === maxLen - 1 ? 'Último' : `S-${maxLen - 1 - i}`);
  const datasets = teamsWithHistory.map((team, i) => {
    const pad = Array(maxLen - team.velocityHistory.length).fill(null);
    return {
      label: team.name,
      data:  [...pad, ...team.velocityHistory.map(h => h.spCompleted)],
      borderColor:     SCRUM_COLORS[i % SCRUM_COLORS.length],
      backgroundColor: SCRUM_COLORS[i % SCRUM_COLORS.length] + '22',
      borderWidth: 2, pointRadius: 3, tension: 0.3, fill: true, spanGaps: false,
    };
  });
  _velocityHistChart = new Chart(canvas.getContext('2d'), {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 12 } } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#F1F5F9' }, ticks: { callback: v => `${v} SP` } },
        x: { grid: { display: false } }
      }
    }
  });
}

function renderScrumCharts() {
  _scrumTeams.forEach((team, i) => {
    if (team.velocityHistory && team.velocityHistory.length > 0) {
      renderMiniVelChart(team.id, team.velocityHistory, i);
    }
  });
  renderSpDistChart(_scrumTeams);
  renderVelocityHistChart(_scrumTeams);
}

