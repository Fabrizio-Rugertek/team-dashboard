            </div>
            <span class="text-[11px] font-bold text-blue-700 shrink-0"><%= team.activeSprint.taskDoneCount %>/<%= team.activeSprint.taskCount %></span>
          </div>
          <%# SP metrics %>
          <div class="grid grid-cols-3 gap-1 text-center">
            <div class="bg-white rounded p-1.5">
              <div class="text-sm font-black text-slate-800"><%= team.activeSprint.spBaseline || '—' %></div>
