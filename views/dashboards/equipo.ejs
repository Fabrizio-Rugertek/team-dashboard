    <h3 class="text-base font-extrabold text-slate-900 mb-3">Scrum Teams</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-4" id="scrumTeamsGrid">
      <% scrumTeams.forEach((team, ti) => { %>
      <div class="bg-white rounded-xl border border-slate-200 p-5 flex flex-col gap-3">

        <%# Header %>
        <div class="flex items-start justify-between">
          <div>
            <div class="font-extrabold text-slate-900 text-sm"><%= team.name %></div>
            <div class="text-xs text-slate-400 mt-0.5">PO: <%= team.po || '—' %> · <%= team.memberCount %> miembros</div>
          </div>
          <span class="text-xs font-bold bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full"><%= team.code %></span>
        </div>

        <%# Sprint Status %>
        <% if (team.activeSprint) { %>
        <div class="bg-blue-50 border border-blue-100 rounded-lg p-3">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-bold text-blue-700">🚀 Sprint activo</span>
            <span class="text-xs text-blue-500"><%= team.activeSprint.dateStart %> → <%= team.activeSprint.dateEnd %></span>
          </div>
