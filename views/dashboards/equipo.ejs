<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .alert-filter-btn.active { background: #0f172a; color: white; }
    .filter-btn.active { background: #3B82F6; color: white; border-color: #3B82F6; }
    .filter-btn:hover:not(.active) { background: #EFF6FF; }
    .log-day { min-width: 48px; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white text-sm">T</div>
      <span class="font-bold text-slate-900 text-lg">Torus</span>
      <span class="text-slate-400 text-sm font-medium">/ Control de Equipo</span>
      <span class="text-slate-300">·</span>
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">Ver todos</a>
      <span class="text-slate-300">·</span>
      <a href="/finanzas" class="text-sm font-medium text-green-600 hover:text-green-800 transition-colors">Finanzas</a>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span>Actualizado: <span id="lastUpdate"><%= lastUpdate %></span></span>
      </div>
      <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center text-sm font-bold text-slate-600">F</div>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">
  <% const lc = loggingControl || { overview: {}, displayDates: [], people: [] }; %>
  <% const lco = lc.overview || {}; %>
  <div id="staleBanner" class="hidden">
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
      <div class="font-bold text-amber-900">Mostrando snapshot guardado</div>
      <div class="text-sm text-amber-700" id="staleBannerText"></div>
    </div>
  </div>

  <%# ── Alerts Section ─────────────────────────────────────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="text-2xl">🚨</span>
        <h2 class="text-xl font-extrabold text-slate-900">Alertas y Validaciones</h2>
      </div>
      <div class="flex gap-1 bg-slate-100 rounded-lg p-1" id="alertFilters">
        <button class="alert-filter-btn active px-3 py-1.5 rounded-md text-xs font-bold" data-filter="all">Todas <span class="ml-1" id="alertFilterAllCount"><%= criticalCount + warningCount + infoCount %></span></button>
        <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-red-700 bg-red-100" data-filter="critical">🚨 <span id="alertFilterCriticalCount"><%= criticalCount %></span></button>
        <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-amber-700" data-filter="warning">🟡 <span id="alertFilterWarningCount"><%= warningCount %></span></button>
        <button class="alert-filter-btn px-3 py-1.5 rounded-md text-xs font-bold text-blue-700" data-filter="info">💤 <span id="alertFilterInfoCount"><%= infoCount %></span></button>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-4">
      <div class="bg-white rounded-xl border-2 border-red-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-red-50 transition-colors" onclick="filterAlerts('critical')">
        <div class="text-4xl">🚨</div>
        <div>
          <div class="text-3xl font-black text-red-600" id="criticalCount"><%= criticalCount %></div>
          <div class="text-xs font-semibold text-red-500 uppercase tracking-wide">Criticas</div>
          <div class="text-xs text-slate-400 mt-0.5">Requieren atencion inmediata</div>
        </div>
      </div>
      <div class="bg-white rounded-xl border-2 border-amber-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-amber-50 transition-colors" onclick="filterAlerts('warning')">
        <div class="text-4xl">🟡</div>
        <div>
          <div class="text-3xl font-black text-amber-600" id="warningCount"><%= warningCount %></div>
          <div class="text-xs font-semibold text-amber-500 uppercase tracking-wide">Warnings</div>
          <div class="text-xs text-slate-400 mt-0.5">Revisar y corregir</div>
        </div>
      </div>
      <div class="bg-white rounded-xl border-2 border-blue-200 p-4 flex items-center gap-4 cursor-pointer hover:bg-blue-50 transition-colors" onclick="filterAlerts('info')">
        <div class="text-4xl">💤</div>
        <div>
          <div class="text-3xl font-black text-blue-600" id="infoCount"><%= infoCount %></div>
          <div class="text-xs font-semibold text-blue-500 uppercase tracking-wide">Info</div>
          <div class="text-xs text-slate-400 mt-0.5">Monitoreo pasivo</div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto max-h-80 overflow-y-auto" id="alertsContainer">
        <table class="w-full text-sm">
          <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
            <tr>
              <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs w-10">#</th>
              <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-16">Nivel</th>
              <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-28">Consultor</th>
              <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs">Mensaje</th>
              <th class="text-left py-2.5 px-3 font-semibold text-slate-600 text-xs w-28">Categoria</th>
              <th class="text-left py-2.5 px-4 font-semibold text-slate-600 text-xs">Detalle</th>
            </tr>
          </thead>
          <tbody id="alertsTableBody">
            <% anomalies.forEach((a, i) => { %>
            <tr class="alert-row border-b border-slate-50 hover:bg-slate-50 transition-colors" data-type="<%= a.type %>">
              <td class="py-2.5 px-4 text-slate-400 text-xs"><%= i + 1 %></td>
              <td class="py-2.5 px-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold <%= a.type === 'critical' ? 'bg-red-100 text-red-700' : a.type === 'warning' ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                  <%= a.type === 'critical' ? '🚨' : a.type === 'warning' ? '🟡' : '💤' %>
                  <%= a.type.charAt(0).toUpperCase() + a.type.slice(1) %>
                </span>
              </td>
              <td class="py-2.5 px-3"><div class="font-medium text-slate-800 text-xs"><%= a.user %></div></td>
              <td class="py-2.5 px-4"><div class="font-semibold text-slate-800 text-xs"><%= a.message %></div></td>
              <td class="py-2.5 px-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600"><%= a.category %></span>
              </td>
              <td class="py-2.5 px-4"><div class="text-xs text-slate-500 max-w-xs truncate" title="<%= a.detail %>"><%= a.detail %></div></td>
            </tr>
            <% }) %>
            <% if (anomalies.length === 0) { %>
            <tr>
              <td colspan="6" class="py-12 text-center">
                <div class="text-4xl mb-2">✅</div>
                <div class="font-bold text-green-600 text-lg">Sin anomalias detectadas</div>
                <div class="text-sm text-slate-400 mt-1">Todo esta en orden esta semana</div>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <%# ── KPIs ─────────────────────────────────────────────────────────────── %>
  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Horas Semana</div>
        <div class="text-2xl font-black text-slate-900" id="kpiWeekHours"><%= summary.weekHours %>h</div>
        <div class="text-xs text-slate-400 mt-1"><span id="kpiActiveUsers"><%= summary.activeUsers %></span> consultores activos</div>
      </div>
      <div class="bg-white rounded-xl border-2 border-green-200 p-4">
        <div class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Billable</div>
        <div class="text-2xl font-black text-green-600" id="kpiBillableWeek"><%= summary.billableWeek || 0 %>h</div>
        <div class="text-xs text-slate-400 mt-1" id="kpiBillableWeekPct"><%= summary.weekHours > 0 ? Math.round((summary.billableWeek || 0) / summary.weekHours * 100) : 0 %>% del total</div>
      </div>
      <div class="bg-white rounded-xl border-2 border-orange-200 p-4">
        <div class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Non-Billable</div>
        <div class="text-2xl font-black text-orange-600" id="kpiNonBillableWeek"><%= summary.nonBillableWeek || 0 %>h</div>
        <div class="text-xs text-slate-400 mt-1" id="kpiNonBillableWeekPct"><%= summary.weekHours > 0 ? Math.round((summary.nonBillableWeek || 0) / summary.weekHours * 100) : 0 %>% del total</div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Horas Mes</div>
        <div class="text-2xl font-black text-slate-900" id="kpiMonthHours"><%= summary.monthHours %>h</div>
        <div class="text-xs text-slate-400 mt-1"><span id="kpiBillableMonth"><%= summary.billableMonth || 0 %></span> billable / <span id="kpiNonBillableMonth"><%= summary.nonBillableMonth || 0 %></span> non</div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-3">Billable vs Non-Billable (semana)</div>
      <div style="height: 160px;">
        <canvas id="billableChart"></canvas>
      </div>
      <div class="flex justify-center gap-6 mt-3">
        <div class="flex items-center gap-1.5 text-xs">
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="font-medium text-slate-700" id="billableLegend">Billable <%= summary.weekHours > 0 ? Math.round((summary.billableWeek || 0) / summary.weekHours * 100) : 0 %>%</span>
        </div>
        <div class="flex items-center gap-1.5 text-xs">
          <div class="w-3 h-3 rounded-full bg-orange-400"></div>
          <span class="font-medium text-slate-700" id="nonBillableLegend">Non-Billable <%= summary.weekHours > 0 ? Math.round((summary.nonBillableWeek || 0) / summary.weekHours * 100) : 0 %>%</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── Weekly Chart + Top Consultants ─────────────────────────────────────── %>
  <%# Logging Discipline %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3 mb-5">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Disciplina de Logeo</h3>
        <p class="text-sm text-slate-500">Control historico de carga sobre los ultimos <span id="loggingWindowLabel"><%= lco.complianceDays || 0 %></span> dias habiles. Buscamos ausencia de logeo, carga tardia y patrones de baja calidad.</p>
      </div>
      <div class="text-xs text-slate-400">Referencia actual: <span id="loggingLatestBusinessLabel"><%= lco.latestBusinessLabel || '-' %></span></div>
    </div>

    <div class="grid grid-cols-2 xl:grid-cols-4 gap-4 mb-5">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Compliance</div>
        <div class="text-2xl font-black text-slate-900" id="loggingCompliancePct"><%= lco.compliancePct || 0 %>%</div>
        <div class="text-xs text-slate-400 mt-1"><span id="loggingPeopleCount"><%= lco.peopleCount || 0 %></span> personas activas</div>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50 p-4">
        <div class="text-xs font-semibold text-red-600 uppercase tracking-wide mb-1">Sin log ultimo dia habil</div>
        <div class="text-2xl font-black text-red-600" id="loggingMissingLatestCount"><%= lco.missingLatestBusinessDayCount || 0 %></div>
        <div class="text-xs text-red-500 mt-1">Sobre <span id="loggingLatestBusinessLabelCard"><%= lco.latestBusinessLabel || '-' %></span></div>
      </div>
      <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
        <div class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-1">Sin log esta semana</div>
        <div class="text-2xl font-black text-amber-600" id="loggingNoWeekCount"><%= lco.noLogThisWeekCount || 0 %></div>
        <div class="text-xs text-amber-600 mt-1">Riesgo operativo inmediato</div>
      </div>
      <div class="rounded-xl border border-indigo-200 bg-indigo-50 p-4">
        <div class="text-xs font-semibold text-indigo-700 uppercase tracking-wide mb-1">Carga sospechosa</div>
        <div class="text-2xl font-black text-indigo-700" id="loggingSuspiciousCount"><%= lco.suspiciousCount || 0 %></div>
        <div class="text-xs text-indigo-500 mt-1"><span id="loggingCriticalCount"><%= lco.criticalCount || 0 %></span> criticos / <span id="loggingWarningCount"><%= lco.warningCount || 0 %></span> warning</div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-slate-100 align-bottom">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Persona</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Compliance</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Semana</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Calidad</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Ultimos dias habiles</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Estado</th>
          </tr>
          <tr class="border-b border-slate-100 text-[11px] text-slate-400" id="loggingDatesHeaderRow">
            <th></th>
            <th></th>
            <th></th>
            <th></th>
            <th class="py-2 px-3">
              <div class="flex gap-1">
                <% lc.displayDates.forEach((day) => { %>
                  <span class="log-day text-center"><%= day.label %></span>
                <% }) %>
              </div>
            </th>
            <th></th>
          </tr>
        </thead>
        <tbody id="loggingTableBody">
          <% lc.people.forEach((person) => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-3 px-3 align-top">
              <div class="font-semibold text-slate-900 text-xs"><%= person.name %></div>
              <div class="text-xs text-slate-400 mt-1"><%= person.job || 'Sin rol' %><% if (person.department) { %> - <%= person.department %><% } %></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-black <%= person.compliancePct >= 85 ? 'text-green-600' : person.compliancePct >= 65 ? 'text-amber-600' : 'text-red-600' %>"><%= person.compliancePct %>%</div>
              <div class="text-xs text-slate-400"><%= person.loggedDays %>/<%= person.expectedDays %> dias - faltan <%= person.missingDays %></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-bold text-slate-900"><%= person.hoursThisWeek %>h</div>
              <div class="text-xs text-slate-400"><%= person.entriesThisWeek %> cargas - ultimo log <%= person.lastLogDate || '-' %></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-xs text-slate-500">desc cortas <span class="font-semibold text-slate-700"><%= person.quality.shortDescPct %>%</span></div>
              <div class="text-xs text-slate-500">cargas tardias <span class="font-semibold text-slate-700"><%= person.quality.latePct %>%</span></div>
              <div class="text-xs text-slate-500">cargas redondas <span class="font-semibold text-slate-700"><%= person.quality.roundPct %>%</span></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="flex gap-1">
                <% person.recentDays.forEach((day) => { %>
                  <div class="log-day rounded-md border px-1.5 py-1 text-center text-[11px] font-semibold <%= day.isMissing ? 'bg-red-50 border-red-200 text-red-600' : day.hours >= 8 ? 'bg-indigo-50 border-indigo-200 text-indigo-700' : day.hours >= 4 ? 'bg-blue-50 border-blue-200 text-blue-700' : 'bg-amber-50 border-amber-200 text-amber-700' %>" title="<%= `${day.label}: ${day.hours}h / ${day.entries} cargas${day.lateEntries ? ` / tardias: ${day.lateEntries}` : ''}` %>">
                    <div><%= day.hours > 0 ? `${day.hours}h` : '0' %></div>
                    <div class="text-[10px] <%= day.lateEntries ? 'text-amber-500' : 'text-slate-300' %>"><%= day.lateEntries ? 'T' : '.' %></div>
                  </div>
                <% }) %>
              </div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold <%= person.status === 'critical' ? 'bg-red-100 text-red-700' : person.status === 'warning' ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700' %>">
                <%= person.status === 'critical' ? 'Critico' : person.status === 'warning' ? 'Warning' : 'Sano' %>
                &nbsp;|&nbsp;<%= person.suspiciousScore %>
              </div>
              <% if (person.flags.length) { %>
              <div class="mt-2 space-y-1 max-w-xs">
                <% person.flags.forEach((flag) => { %>
                <div class="text-xs text-slate-500">- <%= flag %></div>
                <% }) %>
              </div>
              <% } else { %>
              <div class="mt-2 text-xs text-slate-400">Sin alertas relevantes</div>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!lc.people.length) { %>
          <tr>
            <td colspan="6" class="py-10 text-center text-slate-400">No hay datos de logeo para mostrar.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>


  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-bold text-slate-800 mb-4">Horas por Semana</h3>
      <div style="height: 200px;">
        <canvas id="weeklyChart"></canvas>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-bold text-slate-800 mb-3">Top Consultores</h3>
      <div class="space-y-3 max-h-52 overflow-y-auto" id="topConsultantsList">
        <% consultants.slice(0, 8).forEach((c) => { %>
        <div class="flex items-center gap-2 <%= !c.hasHours ? 'opacity-40' : '' %>">
          <div class="w-7 h-7 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0"><%= (c.name || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase() %></div>
          <div class="flex-1 min-w-0">
            <div class="text-xs font-semibold text-slate-800 truncate"><%= c.name %></div>
            <% if (c.job) { %><div class="text-xs text-slate-400 truncate"><%= c.job %></div><% } %>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-sm font-bold <%= c.hasHours ? 'text-slate-900' : 'text-slate-400' %>"><%= c.hoursThisWeek %>h</div>
            <div class="text-xs <%= (c.billableWeek || 0) > (c.nonBillableWeek || 0) ? 'text-green-600' : 'text-orange-500' %>">B <%= c.billableWeek || 0 %> / N <%= c.nonBillableWeek || 0 %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%# ── Metodología Compliance ───────────────────────────────────────────── %>
  <% const meth = methodology || {}; %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Cumplimiento Metodologico</h3>
        <p class="text-sm text-slate-500">Adopcion de la metodologia Torus en tareas activas (excluye backlog).</p>
      </div>
      <div class="text-xs text-slate-400"><%= meth.totalActiveTasks || 0 %> tareas activas</div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <%# Story Points %>
      <div class="rounded-xl border p-4 <%= (meth.spPct || 0) >= 70 ? 'border-green-200 bg-green-50' : (meth.spPct || 0) >= 40 ? 'border-amber-200 bg-amber-50' : 'border-red-200 bg-red-50' %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold uppercase tracking-wide <%= (meth.spPct || 0) >= 70 ? 'text-green-700' : (meth.spPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>">Story Points</span>
          <span class="text-2xl font-black <%= (meth.spPct || 0) >= 70 ? 'text-green-700' : (meth.spPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>"><%= meth.spPct || 0 %>%</span>
        </div>
        <div class="w-full bg-white rounded-full h-2 mb-2">
          <div class="h-2 rounded-full <%= (meth.spPct || 0) >= 70 ? 'bg-green-500' : (meth.spPct || 0) >= 40 ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= meth.spPct || 0 %>%"></div>
        </div>
        <div class="text-xs text-slate-600"><%= meth.tasksWithSP || 0 %> / <%= meth.totalActiveTasks || 0 %> tareas con SP</div>
        <% if ((meth.tasksWithHoursAndNoSP || 0) > 0) { %>
        <div class="mt-1 text-xs font-semibold text-red-600">⚠ <%= meth.tasksWithHoursAndNoSP %> con horas pero sin SP</div>
        <% } %>
      </div>

      <%# Sprint %>
      <div class="rounded-xl border p-4 <%= (meth.sprintPct || 0) >= 70 ? 'border-green-200 bg-green-50' : (meth.sprintPct || 0) >= 40 ? 'border-amber-200 bg-amber-50' : 'border-red-200 bg-red-50' %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold uppercase tracking-wide <%= (meth.sprintPct || 0) >= 70 ? 'text-green-700' : (meth.sprintPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>">Sprint asignado</span>
          <span class="text-2xl font-black <%= (meth.sprintPct || 0) >= 70 ? 'text-green-700' : (meth.sprintPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>"><%= meth.sprintPct || 0 %>%</span>
        </div>
        <div class="w-full bg-white rounded-full h-2 mb-2">
          <div class="h-2 rounded-full <%= (meth.sprintPct || 0) >= 70 ? 'bg-green-500' : (meth.sprintPct || 0) >= 40 ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= meth.sprintPct || 0 %>%"></div>
        </div>
        <div class="text-xs text-slate-600"><%= meth.tasksWithSprint || 0 %> / <%= meth.totalActiveTasks || 0 %> tareas en un sprint</div>
      </div>

      <%# Horas estimadas %>
      <div class="rounded-xl border p-4 <%= (meth.hoursPct || 0) >= 70 ? 'border-green-200 bg-green-50' : (meth.hoursPct || 0) >= 40 ? 'border-amber-200 bg-amber-50' : 'border-red-200 bg-red-50' %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold uppercase tracking-wide <%= (meth.hoursPct || 0) >= 70 ? 'text-green-700' : (meth.hoursPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>">Horas estimadas</span>
          <span class="text-2xl font-black <%= (meth.hoursPct || 0) >= 70 ? 'text-green-700' : (meth.hoursPct || 0) >= 40 ? 'text-amber-700' : 'text-red-700' %>"><%= meth.hoursPct || 0 %>%</span>
        </div>
        <div class="w-full bg-white rounded-full h-2 mb-2">
          <div class="h-2 rounded-full <%= (meth.hoursPct || 0) >= 70 ? 'bg-green-500' : (meth.hoursPct || 0) >= 40 ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= meth.hoursPct || 0 %>%"></div>
        </div>
        <div class="text-xs text-slate-600"><%= meth.tasksWithHours || 0 %> / <%= meth.totalActiveTasks || 0 %> tareas con estimacion</div>
      </div>
    </div>
  </section>

  <%# ── Horas por Proyecto ─────────────────────────────────────────────────── %>
  <% const cols = topProjectCols || []; %>
  <% if (cols.length > 0 && consultants.length > 0) { %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Horas por Proyecto</h3>
        <p class="text-sm text-slate-500">Distribucion de horas del mes por consultor y proyecto (top <%= cols.length %>).</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b-2 border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 min-w-28">Consultor</th>
            <th class="text-right py-2 px-3 font-bold text-slate-700 min-w-16">Total mes</th>
            <% cols.forEach(col => { %>
            <th class="text-right py-2 px-2 font-semibold text-slate-500 min-w-20 max-w-28">
              <div class="truncate" title="<%= col.name %>"><%= col.name %></div>
              <div class="text-slate-400 font-normal"><%= col.total %>h total</div>
            </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% consultants.forEach(c => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-2 px-3">
              <div class="font-semibold text-slate-800"><%= c.name %></div>
              <% if (c.job) { %><div class="text-slate-400"><%= c.job %></div><% } %>
            </td>
            <td class="py-2 px-3 text-right font-bold text-slate-900"><%= c.hoursThisMonth %>h</td>
            <% (c.projectHours || []).forEach((h, i) => { %>
            <td class="py-2 px-2 text-right <%= h > 0 ? 'text-blue-700 font-semibold' : 'text-slate-300' %>">
              <%= h > 0 ? h + 'h' : '-' %>
            </td>
            <% }) %>
          </tr>
          <% }) %>
          <%# Totals row %>
          <tr class="border-t-2 border-slate-200 bg-slate-50 font-bold">
            <td class="py-2 px-3 text-slate-700">Total</td>
            <td class="py-2 px-3 text-right text-slate-900"><%= consultants.reduce((s,c) => s + (c.hoursThisMonth||0), 0).toFixed(1) %>h</td>
            <% cols.forEach((col, i) => { %>
            <td class="py-2 px-2 text-right text-slate-700"><%= col.total %>h</td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>

  <%# ── Projects Section with Filters ────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <%# Filter bar %>
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <div class="flex items-center gap-2">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Estado:</span>
        <div class="flex gap-1" id="statusFilters">
          <% statusFilters.forEach(f => { %>
          <button
            class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold transition-colors<%= activeFilters.status === f.value ? ' active' : '' %>"
            data-filter-type="status"
            data-filter-value="<%= f.value %>"
          ><%= f.label %></button>
          <% }) %>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Etiqueta:</span>
        <div class="flex gap-1" id="tagFilters">
          <% tagFilters.forEach(f => { %>
          <button
            class="filter-btn px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold transition-colors<%= activeFilters.tag === f.value ? ' active' : '' %>"
            data-filter-type="tag"
            data-filter-value="<%= f.value %>"
          ><%= f.label %></button>
          <% }) %>
        </div>
      </div>
      <% if (activeFilters.status !== 'all' || activeFilters.tag !== 'all') { %>
      <a href="?" class="ml-auto text-xs text-red-500 hover:text-red-700 font-semibold flex items-center gap-1">
        ✕ Limpiar filtros
      </a>
      <% } %>
    </div>

    <%# Pagination bar %>
    <div class="flex items-center justify-between gap-4 mb-4">
      <h3 class="font-bold text-slate-800">Estado de Proyectos</h3>
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <button id="projectsPrev" class="px-3 py-1 rounded border border-slate-200 disabled:opacity-40 disabled:cursor-not-allowed">Anterior</button>
        <span id="projectsPageLabel">Pagina 1</span>
        <button id="projectsNext" class="px-3 py-1 rounded border border-slate-200 disabled:opacity-40 disabled:cursor-not-allowed">Siguiente</button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Proyecto</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Avance</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Log</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Estimado</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Ab. / Hechas</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Backlog</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Actualizacion</th>
          </tr>
        </thead>
        <tbody id="projectsTable">
          <% projectStatuses.slice(0, 20).forEach((p) => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 <%= p.needsAttention ? 'bg-red-50' : '' %>">
            <td class="py-2 px-3">
              <div class="font-medium text-slate-800 text-xs"><%= p.name %></div>
              <% if (p.needsAttention) { %><span class="text-xs text-red-600 font-semibold">Atencion</span><% } %>
            </td>
            <td class="py-2 px-3 text-center"><span class="font-bold <%= p.stageProgress > 80 ? 'text-green-600' : p.stageProgress > 50 ? 'text-amber-500' : 'text-slate-400' %>"><%= p.stageProgress %>%</span></td>
            <td class="py-2 px-3 text-right <%= p.hoursPct && p.hoursPct > 120 ? 'text-red-600 font-bold' : p.hoursPct && p.hoursPct > 100 ? 'text-amber-600' : 'text-green-600' %>"><%= p.totalLog %>h<%= p.hoursPct ? ` (${p.hoursPct}%)` : '' %></td>
            <td class="py-2 px-3 text-right text-slate-400"><%= p.totalAlloc > 0 ? p.totalAlloc + 'h' : '-' %></td>
            <td class="py-2 px-3 text-center text-slate-500"><%= p.openTasks %> / <%= p.doneTasks %></td>
            <td class="py-2 px-3 text-center text-slate-400"><%= p.backlogTasks %></td>
            <td class="py-2 px-3 text-center"><span class="<%= p.daysSinceUpdate > 14 ? 'text-red-600 font-bold' : p.daysSinceUpdate > 7 ? 'text-amber-500' : 'text-green-600' %> text-xs font-semibold"><%= p.daysSinceUpdate > 14 ? '🔴' : p.daysSinceUpdate > 7 ? '🟡' : '🟢' %> <%= p.daysSinceUpdate > 99 ? 'Nunca' : `Hace ${p.daysSinceUpdate}d` %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mt-3 text-xs text-slate-400" id="projectsPageMeta"><%= projectStatuses.length %> proyectos<%= activeFilters.status !== 'all' || activeFilters.tag !== 'all' ? ' (filtrados)' : '' %></div>
  </section>
</div>

<footer class="text-center text-xs text-slate-400 py-6 mt-8">
  Torus Dashboard Platform · <%= new Date().getFullYear() %>
</footer>

<script>
const API = '/api';
const PROJECTS_PAGE_SIZE = 20;

// Read filters from URL query string
function getUrlFilters() {
  const params = new URLSearchParams(window.location.search);
  return {
    status:  params.get('status') || 'all',
    tag:     params.get('tag')    || 'all',
    page:    Number(params.get('page') || 1),
  };
}

// Build URL from filter state
function buildFilterUrl(overrides) {
  const f = { ...getUrlFilters(), ...overrides };
  const params = new URLSearchParams();
  if (f.status  && f.status  !== 'all') params.set('status', f.status);
  if (f.tag     && f.tag     !== 'all') params.set('tag',    f.tag);
  if (f.page    && f.page    > 1)       params.set('page',   f.page);
  const qs = params.toString();
  return qs ? '?' + qs : '.';
}

// Navigate to new filter URL (full page navigation; server re-renders)
function applyFilters(overrides) {
  window.location.href = buildFilterUrl(overrides);
}

// ── State ────────────────────────────────────────────────────────────────────
let currentFilter = 'all';
let projectsState = {
  page:       1,
  totalPages: Math.max(1, Math.ceil(<%= projectStatuses.length %> / PROJECTS_PAGE_SIZE)),
  totalItems: <%= projectStatuses.length %>,
  status:     '<%= activeFilters.status %>',
  tag:        '<%= activeFilters.tag %>',
};
let weeklyChart;
let billableChart;

// ── Initial data (server-rendered) ──────────────────────────────────────────
const weeklyLabels = <%- JSON.stringify(weeklyLabels) %>;
const weeklyHours  = <%- JSON.stringify(weeklyHours) %>;
const initialSummary        = <%- JSON.stringify(summary) %>;
const initialConsultants    = <%- JSON.stringify(consultants) %>;
const initialAnomalies      = <%- JSON.stringify(anomalies) %>;
const initialLoggingControl = <%- JSON.stringify(loggingControl) %>;

// ── Charts ───────────────────────────────────────────────────────────────────
function renderBillableChart(summary) {
  const ctx = document.getElementById('billableChart').getContext('2d');
  const data = [summary.billableWeek || 0, summary.nonBillableWeek || 0];
  if (billableChart) billableChart.destroy();
  billableChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Billable', 'Non-Billable'],
      datasets: [{ data, backgroundColor: ['#10B981', '#FB923C'], borderWidth: 0, hoverOffset: 4 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, cutout: '65%',
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw}h` } } }
    }
  });
}

function renderWeeklyChart(labels, hours) {
  const ctx = document.getElementById('weeklyChart').getContext('2d');
  if (weeklyChart) weeklyChart.destroy();
  weeklyChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Horas',
        data: hours,
        backgroundColor: hours.map((_, i) => i === hours.length - 1 ? '#3B82F6' : '#BFDBFE'),
        borderRadius: 6, borderSkipped: false
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.raw}h` } } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#F1F5F9' }, ticks: { callback: v => `${v}h` } },
        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
      }
    }
  });
}

// ── Alert filters ────────────────────────────────────────────────────────────
function updateAlertCounters(anomalies) {
  const critical = anomalies.filter(a => a.type === 'critical').length;
  const warning  = anomalies.filter(a => a.type === 'warning').length;
  const info     = anomalies.filter(a => a.type === 'info').length;
  document.getElementById('criticalCount').textContent = critical;
  document.getElementById('warningCount').textContent  = warning;
  document.getElementById('infoCount').textContent     = info;
  document.getElementById('alertFilterAllCount').textContent      = critical + warning + info;
  document.getElementById('alertFilterCriticalCount').textContent  = critical;
  document.getElementById('alertFilterWarningCount').textContent  = warning;
  document.getElementById('alertFilterInfoCount').textContent     = info;
}

function filterAlerts(type) {
  currentFilter = type;
  document.querySelectorAll('.alert-filter-btn').forEach(btn => {
    const isActive = btn.dataset.filter === type;
    btn.classList.toggle('active', isActive);
    btn.classList.toggle('bg-slate-100', !isActive && btn.dataset.filter === 'all');
    btn.classList.toggle('text-slate-600', !isActive && btn.dataset.filter === 'all');
  });
  document.querySelectorAll('.alert-row').forEach(row => {
    row.style.display = (type === 'all' || row.dataset.type === type) ? '' : 'none';
  });
}

// ── Render helpers ────────────────────────────────────────────────────────────
function renderStaleState(payload) {
  const banner    = document.getElementById('staleBanner');
  const bannerTxt = document.getElementById('staleBannerText');
  if (payload.stale) {
    banner.classList.remove('hidden');
    bannerTxt.textContent = payload.staleReason
      ? `Odoo no respondió. Snapshot válido del ${new Date(payload.generatedAt).toLocaleString('es-ES')}. Motivo: ${payload.staleReason}`
      : `Odoo no respondió. Se muestra el último snapshot válido (${new Date(payload.generatedAt).toLocaleString('es-ES')}).`;
  } else {
    banner.classList.add('hidden');
  }
}

function renderSummary(summary) {
  document.getElementById('kpiWeekHours').textContent  = `${summary.weekHours || 0}h`;
  document.getElementById('kpiActiveUsers').textContent = summary.activeUsers || 0;
  document.getElementById('kpiBillableWeek').textContent   = `${summary.billableWeek || 0}h`;
  document.getElementById('kpiNonBillableWeek').textContent = `${summary.nonBillableWeek || 0}h`;
  document.getElementById('kpiMonthHours').textContent  = `${summary.monthHours || 0}h`;
  document.getElementById('kpiBillableMonth').textContent   = summary.billableMonth || 0;
  document.getElementById('kpiNonBillableMonth').textContent = summary.nonBillableMonth || 0;
  const totalWeek   = summary.weekHours || 0;
  const billablePct    = totalWeek > 0 ? Math.round(((summary.billableWeek || 0)    / totalWeek) * 100) : 0;
  const nonBillablePct = totalWeek > 0 ? Math.round(((summary.nonBillableWeek || 0) / totalWeek) * 100) : 0;
  document.getElementById('kpiBillableWeekPct').textContent  = `${billablePct}% del total`;
  document.getElementById('kpiNonBillableWeekPct').textContent = `${nonBillablePct}% del total`;
  document.getElementById('billableLegend').textContent    = `Billable ${billablePct}%`;
  document.getElementById('nonBillableLegend').textContent = `Non-Billable ${nonBillablePct}%`;
}


function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function getLoggingStatusClass(status) {
  if (status === 'critical') return 'bg-red-100 text-red-700';
  if (status === 'warning') return 'bg-amber-100 text-amber-700';
  return 'bg-green-100 text-green-700';
}

function getLoggingStatusLabel(status) {
  if (status === 'critical') return 'Critico';
  if (status === 'warning') return 'Warning';
  return 'Sano';
}

function getLoggingDayClass(day) {
  if (day.isMissing) return 'bg-red-50 border-red-200 text-red-600';
  if ((day.hours || 0) >= 8) return 'bg-indigo-50 border-indigo-200 text-indigo-700';
  if ((day.hours || 0) >= 4) return 'bg-blue-50 border-blue-200 text-blue-700';
  return 'bg-amber-50 border-amber-200 text-amber-700';
}

function renderLoggingControl(loggingControl) {
  const overview = loggingControl?.overview || {};
  const dates = loggingControl?.displayDates || [];
  const people = loggingControl?.people || [];

  document.getElementById('loggingWindowLabel').textContent = overview.complianceDays || 0;
  document.getElementById('loggingLatestBusinessLabel').textContent = overview.latestBusinessLabel || '-';
  document.getElementById('loggingCompliancePct').textContent = `${overview.compliancePct || 0}%`;
  document.getElementById('loggingPeopleCount').textContent = overview.peopleCount || 0;
  document.getElementById('loggingMissingLatestCount').textContent = overview.missingLatestBusinessDayCount || 0;
  document.getElementById('loggingLatestBusinessLabelCard').textContent = overview.latestBusinessLabel || '-';
  document.getElementById('loggingNoWeekCount').textContent = overview.noLogThisWeekCount || 0;
  document.getElementById('loggingSuspiciousCount').textContent = overview.suspiciousCount || 0;
  document.getElementById('loggingCriticalCount').textContent = overview.criticalCount || 0;
  document.getElementById('loggingWarningCount').textContent = overview.warningCount || 0;

  document.getElementById('loggingDatesHeaderRow').innerHTML = `
    <th></th>
    <th></th>
    <th></th>
    <th></th>
    <th class="py-2 px-3">
      <div class="flex gap-1">
        ${dates.map(day => `<span class="log-day text-center">${escapeHtml(day.label)}</span>`).join('')}
      </div>
    </th>
    <th></th>`;

  const tbody = document.getElementById('loggingTableBody');
  tbody.innerHTML = people.length ? people.map(person => {
    const flags = (person.flags || []).length
      ? `<div class="mt-2 space-y-1 max-w-xs">${person.flags.map(flag => `<div class="text-xs text-slate-500">- ${escapeHtml(flag)}</div>`).join('')}</div>`
      : '<div class="mt-2 text-xs text-slate-400">Sin alertas relevantes</div>';
    const days = (person.recentDays || []).map(day => {
      const title = `${day.label}: ${day.hours || 0}h / ${day.entries || 0} cargas${day.lateEntries ? ` / tardias: ${day.lateEntries}` : ''}`;
      return `
        <div class="log-day rounded-md border px-1.5 py-1 text-center text-[11px] font-semibold ${getLoggingDayClass(day)}" title="${escapeHtml(title)}">
          <div>${(day.hours || 0) > 0 ? `${day.hours}h` : '0'}</div>
          <div class="text-[10px] ${day.lateEntries ? 'text-amber-500' : 'text-slate-300'}">${day.lateEntries ? 'T' : '.'}</div>
        </div>`;
    }).join('');

    const complianceColor = person.compliancePct >= 85
      ? 'text-green-600'
      : person.compliancePct >= 65
      ? 'text-amber-600'
      : 'text-red-600';

    return `
      <tr class="border-b border-slate-50 hover:bg-slate-50">
        <td class="py-3 px-3 align-top">
          <div class="font-semibold text-slate-900 text-xs">${escapeHtml(person.name || '')}</div>
          <div class="text-xs text-slate-400 mt-1">${escapeHtml(person.job || 'Sin rol')}${person.department ? ` - ${escapeHtml(person.department)}` : ''}</div>
        </td>
        <td class="py-3 px-3 align-top">
          <div class="text-sm font-black ${complianceColor}">${person.compliancePct || 0}%</div>
          <div class="text-xs text-slate-400">${person.loggedDays || 0}/${person.expectedDays || 0} dias - faltan ${person.missingDays || 0}</div>
        </td>
        <td class="py-3 px-3 align-top">
          <div class="text-sm font-bold text-slate-900">${person.hoursThisWeek || 0}h</div>
          <div class="text-xs text-slate-400">${person.entriesThisWeek || 0} cargas - ultimo log ${escapeHtml(person.lastLogDate || '-')}</div>
        </td>
        <td class="py-3 px-3 align-top">
          <div class="text-xs text-slate-500">desc cortas <span class="font-semibold text-slate-700">${person.quality?.shortDescPct || 0}%</span></div>
          <div class="text-xs text-slate-500">cargas tardias <span class="font-semibold text-slate-700">${person.quality?.latePct || 0}%</span></div>
          <div class="text-xs text-slate-500">cargas redondas <span class="font-semibold text-slate-700">${person.quality?.roundPct || 0}%</span></div>
        </td>
        <td class="py-3 px-3 align-top"><div class="flex gap-1">${days}</div></td>
        <td class="py-3 px-3 align-top">
          <div class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold ${getLoggingStatusClass(person.status)}">${getLoggingStatusLabel(person.status)}&nbsp;|&nbsp;${person.suspiciousScore || 0}</div>
          ${flags}
        </td>
      </tr>`;
  }).join('') : '<tr><td colspan="6" class="py-10 text-center text-slate-400">No hay datos de logeo para mostrar.</td></tr>';
}

function renderTopConsultants(consultants) {
  const container = document.getElementById('topConsultantsList');
  const top = [...consultants].sort((a, b) => (b.hoursThisWeek || 0) - (a.hoursThisWeek || 0)).slice(0, 8);
  container.innerHTML = top.map(c => {
    const initials = (c.name || '?').split(' ').map(w => w[0] || '').join('').slice(0, 2).toUpperCase();
    const faded    = c.hasHours === false ? 'opacity-40' : '';
    const color     = (c.billableWeek || 0) > (c.nonBillableWeek || 0) ? 'text-green-600' : 'text-orange-500';
    return `
      <div class="flex items-center gap-2 ${faded}">
        <div class="w-7 h-7 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">${initials}</div>
        <div class="flex-1 min-w-0">
          <div class="text-xs font-semibold text-slate-800 truncate">${c.name || ''}</div>
          ${c.job ? `<div class="text-xs text-slate-400 truncate">${c.job}</div>` : ''}
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-sm font-bold ${c.hasHours === false ? 'text-slate-400' : 'text-slate-900'}">${c.hoursThisWeek || 0}h</div>
          <div class="text-xs ${color}">B ${c.billableWeek || 0} / N ${c.nonBillableWeek || 0}</div>
        </div>
      </div>`;
  }).join('');
}

function renderProjects(projectsPayload) {
  const tbody      = document.getElementById('projectsTable');
  const projects   = projectsPayload.items || [];
  const pagination = projectsPayload.pagination || { page: 1, totalPages: 1, totalItems: projects.length, hasPrev: false, hasNext: false };

  projectsState.page       = pagination.page;
  projectsState.totalPages = pagination.totalPages;
  projectsState.totalItems = pagination.totalItems;

  tbody.innerHTML = projects.map(p => {
    const hoursColor  = !p.hoursPct ? 'text-slate-400' : p.hoursPct > 120 ? 'text-red-600 font-bold' : p.hoursPct > 100 ? 'text-amber-600' : 'text-green-600';
    const progColor   = p.stageProgress > 80 ? 'text-green-600' : p.stageProgress > 50 ? 'text-amber-500' : 'text-slate-400';
    const updateColor = p.daysSinceUpdate > 14 ? 'text-red-600 font-bold' : p.daysSinceUpdate > 7 ? 'text-amber-500' : 'text-green-600';
    const updateIcon  = p.daysSinceUpdate > 14 ? '🔴' : p.daysSinceUpdate > 7 ? '🟡' : '🟢';
    const updateLabel = p.daysSinceUpdate > 99 ? 'Nunca' : `Hace ${p.daysSinceUpdate}d`;
    return `
      <tr class="border-b border-slate-50 hover:bg-slate-50 ${p.needsAttention ? 'bg-red-50' : ''}">
        <td class="py-2 px-3">
          <div class="font-medium text-slate-800 text-xs">${p.name}</div>
          ${p.needsAttention ? '<span class="text-xs text-red-600 font-semibold">Atencion</span>' : ''}
        </td>
        <td class="py-2 px-3 text-center"><span class="font-bold ${progColor}">${p.stageProgress}%</span></td>
        <td class="py-2 px-3 text-right ${hoursColor}">${p.totalLog}h${p.hoursPct ? ` (${p.hoursPct}%)` : ''}</td>
        <td class="py-2 px-3 text-right text-slate-400">${p.totalAlloc > 0 ? `${p.totalAlloc}h` : '-'}</td>
        <td class="py-2 px-3 text-center text-slate-500">${p.openTasks} / ${p.doneTasks}</td>
        <td class="py-2 px-3 text-center text-slate-400">${p.backlogTasks}</td>
        <td class="py-2 px-3 text-center"><span class="text-xs font-semibold ${updateColor}">${updateIcon} ${updateLabel}</span></td>
      </tr>`;
  }).join('');

  document.getElementById('projectsPageLabel').textContent = `Página ${pagination.page} de ${pagination.totalPages}`;
  document.getElementById('projectsPageMeta').textContent  =
    `${pagination.totalItems} proyectos${projectsState.status !== 'all' || projectsState.tag !== 'all' ? ' (filtrados)' : ''} — ${projects.length} visibles`;
  document.getElementById('projectsPrev').disabled = !pagination.hasPrev;
  document.getElementById('projectsNext').disabled = !pagination.hasNext;
}

// ── Bootstrap loader ─────────────────────────────────────────────────────────
async function loadBootstrap(page = 1) {
  const filters = getUrlFilters();
  const targetPage = page || filters.page || 1;

  try {
    const params = new URLSearchParams({
      page:      targetPage,
      pageSize:  PROJECTS_PAGE_SIZE,
      status:    filters.status,
      tag:       filters.tag,
    });
    const response = await fetch(`${API}/equipo/bootstrap?${params}`);
    if (!response.ok) throw new Error(`Bootstrap failed ${response.status}`);
    const payload = await response.json();

    renderStaleState(payload);
    renderSummary(payload.summary    || {});
    updateAlertCounters(payload.anomalies || []);
    renderProjects(payload.projects  || {});
    renderLoggingControl(payload.loggingControl || { overview: {}, displayDates: [], people: [] });
    renderTopConsultants(payload.consultants || []);
    renderWeeklyChart(
      (payload.weekly || []).map(w => w.label),
      (payload.weekly || []).map(w => w.hours)
    );
    renderBillableChart(payload.summary || {});
    document.getElementById('lastUpdate').textContent =
      new Date(payload.generatedAt).toLocaleString('es-ES', { dateStyle: 'medium', timeStyle: 'short' });
    filterAlerts(currentFilter);

    // Update filter button active states from server response
    if (payload.filters) {
      projectsState.status = payload.filters.status || 'all';
      projectsState.tag    = payload.filters.tag    || 'all';
    }
  } catch (error) {
    console.error('Error loading bootstrap:', error);
  }
}

// ── Event listeners ──────────────────────────────────────────────────────────
// Alert filter buttons
document.querySelectorAll('.alert-filter-btn')
  .forEach(btn => btn.addEventListener('click', () => filterAlerts(btn.dataset.filter)));

// Project filter buttons — update URL (full page reload via server)
document.querySelectorAll('.filter-btn[data-filter-type]')
  .forEach(btn => {
    btn.addEventListener('click', () => {
      const type  = btn.dataset.filterType;
      const value = btn.dataset.filterValue;
      applyFilters({ [type]: value, page: 1 });
    });
  });

// Pagination — AJAX refresh only
document.getElementById('projectsPrev').addEventListener('click', () => {
  if (projectsState.page > 1) loadBootstrap(projectsState.page - 1);
});
document.getElementById('projectsNext').addEventListener('click', () => {
  if (projectsState.page < projectsState.totalPages) loadBootstrap(projectsState.page + 1);
});

// ── Init ─────────────────────────────────────────────────────────────────────
renderWeeklyChart(weeklyLabels, weeklyHours);
renderBillableChart(initialSummary);
renderLoggingControl(initialLoggingControl || { overview: {}, displayDates: [], people: [] });
filterAlerts('all');
loadBootstrap();
setInterval(() => loadBootstrap(projectsState.page), 5 * 60 * 1000);
</script>
</body>
</html>
