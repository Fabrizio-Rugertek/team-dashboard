<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .range-btn.active  { background:#2563EB; color:#fff; border-color:#2563EB; }
    .filter-btn.active { background:#2563EB; color:#fff; border-color:#2563EB; }
    .filter-btn:hover:not(.active) { background:#EFF6FF; }
    .log-day { min-width: 48px; }
    details > summary { cursor: pointer; list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    details[open] .chevron { transform: rotate(180deg); }
    .heatmap-0  { background:#F8FAFC; color:#CBD5E1; }
    .heatmap-xs { background:#DBEAFE; color:#1E40AF; }
    .heatmap-sm { background:#BFDBFE; color:#1D4ED8; }
    .heatmap-md { background:#93C5FD; color:#1E3A8A; }
    .heatmap-lg { background:#3B82F6; color:#fff; }
    .heatmap-xl { background:#1D4ED8; color:#fff; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

<%# ── Nav ──────────────────────────────────────────────────────────────────── %>
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white text-sm">T</div>
      <span class="font-bold text-slate-900 text-lg">Torus</span>
      <span class="text-slate-400 text-sm font-medium">/ Control de Equipo</span>
      <span class="text-slate-300">·</span>
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800">Ver todos</a>
      <span class="text-slate-300">·</span>
      <a href="/finanzas" class="text-sm font-medium text-green-600 hover:text-green-800">Finanzas</a>
      <% if (activeFilters.range !== '30d' || activeFilters.consultant !== 'all') { %>
      <span class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold">
        Filtrado
        <a href="/equipo" class="text-blue-500 hover:text-blue-800 ml-1">✕</a>
      </span>
      <% } %>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span>Actualizado: <%= lastUpdate %></span>
      </div>
      <div class="w-8 h-8 bg-slate-200 rounded-full flex items-center justify-center text-sm font-bold text-slate-600">F</div>
    </div>
  </div>
</nav>

<%# ── Sticky Filter Bar ─────────────────────────────────────────────────────── %>
<div class="sticky top-[57px] z-40 bg-white border-b border-slate-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap items-center gap-4">

    <%# Period buttons %>
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Período:</span>
      <div class="flex gap-1">
        <% dateRanges.forEach(r => { %>
        <a href="<%= buildQuery({range: r.value}) %>"
           class="range-btn px-3 py-1 rounded-lg border border-slate-200 text-xs font-semibold transition-colors hover:bg-blue-50 <%= activeFilters.range === r.value ? 'active' : 'text-slate-600' %>">
          <%= r.label %>
        </a>
        <% }) %>
      </div>
    </div>

    <%# Consultant dropdown %>
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Consultor:</span>
      <select onchange="window.location.href = '<%= buildQuery({consultant: '__LOGIN__'}) %>'.replace('__LOGIN__', this.value)"
              class="text-xs border border-slate-200 rounded-lg px-3 py-1.5 bg-white text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-300">
        <option value="all" <%= activeFilters.consultant === 'all' ? 'selected' : '' %>>Todos los consultores</option>
        <% consultantOptions.forEach(c => { %>
        <option value="<%= c.login %>" <%= activeFilters.consultant === c.login ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>

    <% if (activeFilters.range !== '30d' || activeFilters.consultant !== 'all') { %>
    <a href="/equipo" class="ml-auto text-xs text-red-500 hover:text-red-700 font-semibold">✕ Limpiar filtros</a>
    <% } %>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%# ── KPI Row ───────────────────────────────────────────────────────────────── %>
  <%
    const round = v => Math.round(v * 10) / 10;
    const rangeLabel = dateRanges.find(r => r.value === activeFilters.range)?.label || '30 días';
    const meth = methodology || {};
    const lc = loggingControl || { overview: {}, displayDates: [], people: [] };
    const lco = lc.overview || {};
  %>
  <section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Hrs semana</div>
      <div class="text-2xl font-black text-slate-900"><%= summary.weekHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.activeUsers %> activos hoy</div>
    </div>
    <div class="bg-white rounded-xl border-2 border-blue-200 p-4">
      <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-1">Hrs <%= rangeLabel %></div>
      <div class="text-2xl font-black text-blue-700"><%= summary.rangeHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.billableRangePct %>% billable</div>
    </div>
    <div class="bg-white rounded-xl border-2 border-green-200 p-4">
      <div class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Billable semana</div>
      <div class="text-2xl font-black text-green-600"><%= summary.billableWeek %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.weekHours > 0 ? Math.round((summary.billableWeek||0)/summary.weekHours*100) : 0 %>% del total</div>
    </div>
    <div class="bg-white rounded-xl border p-4 <%= (meth.spPct||0) < 20 ? 'border-red-200' : 'border-slate-200' %>">
      <div class="text-xs font-semibold <%= (meth.spPct||0) < 20 ? 'text-red-500' : 'text-slate-500' %> uppercase tracking-wide mb-1">Story Points</div>
      <div class="text-2xl font-black <%= (meth.spPct||0) < 20 ? 'text-red-600' : (meth.spPct||0) < 60 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.spPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithSP||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">En Sprint</div>
      <div class="text-2xl font-black <%= (meth.sprintPct||0) < 40 ? 'text-red-600' : (meth.sprintPct||0) < 70 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.sprintPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithSprint||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Estimadas</div>
      <div class="text-2xl font-black <%= (meth.hoursPct||0) < 40 ? 'text-red-600' : (meth.hoursPct||0) < 70 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.hoursPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithHours||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
  </section>

  <%# ── Estado del Equipo (Consultor Cards) ──────────────────────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-xl font-extrabold text-slate-900">Estado del Equipo</h2>
        <p class="text-sm text-slate-500">Período: <span class="font-semibold"><%= rangeLabel %></span> · <%= consultantCards.length %> consultores</p>
      </div>
      <div class="flex gap-2 text-xs">
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-red-100 text-red-700 font-semibold">🔴 <%= lco.criticalCount || 0 %> críticos</span>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-amber-100 text-amber-700 font-semibold">🟡 <%= lco.warningCount || 0 %> warnings</span>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-green-100 text-green-700 font-semibold">🟢 <%= (lco.peopleCount||0) - (lco.suspiciousCount||0) %> sanos</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% consultantCards.forEach(person => {
        const statusColor = person.status === 'critical' ? 'border-red-300 bg-red-50' : person.status === 'warning' ? 'border-amber-300 bg-amber-50' : 'border-green-200 bg-green-50';
        const dotColor    = person.status === 'critical' ? 'bg-red-500' : person.status === 'warning' ? 'bg-amber-400' : 'bg-green-500';
        const initials    = (person.name || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
        const avatarBg    = person.status === 'critical' ? 'bg-red-200 text-red-800' : person.status === 'warning' ? 'bg-amber-200 text-amber-800' : 'bg-blue-200 text-blue-800';
      %>
      <a href="<%= buildQuery({consultant: person.login}) %>"
         class="block bg-white rounded-xl border-2 <%= statusColor %> p-4 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 <%= avatarBg %> rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"><%= initials %></div>
            <div>
              <div class="font-bold text-slate-900 text-sm"><%= person.name %></div>
              <div class="text-xs text-slate-500"><%= person.job || 'Sin rol' %></div>
            </div>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full <%= dotColor %>"></div>
            <span class="text-xs font-bold <%= person.status === 'critical' ? 'text-red-600' : person.status === 'warning' ? 'text-amber-600' : 'text-green-600' %>">
              <%= person.status === 'critical' ? 'Crítico' : person.status === 'warning' ? 'Warning' : 'Sano' %>
            </span>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-2 mb-3 text-center">
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <div class="text-sm font-black text-slate-900"><%= person.hoursInRange %>h</div>
            <div class="text-[10px] text-slate-400 font-medium uppercase"><%= rangeLabel %></div>
          </div>
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <div class="text-sm font-black <%= person.hoursThisWeek > 0 ? 'text-slate-900' : 'text-red-500' %>"><%= person.hoursThisWeek %>h</div>
            <div class="text-[10px] text-slate-400 font-medium uppercase">Esta semana</div>
          </div>
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <div class="text-sm font-black <%= person.billablePct >= 60 ? 'text-green-600' : person.billablePct > 0 ? 'text-amber-600' : 'text-slate-400' %>"><%= person.billablePct %>%</div>
            <div class="text-[10px] text-slate-400 font-medium uppercase">Billable</div>
          </div>
        </div>

        <div class="mb-2">
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-500 font-medium">Compliance logeo</span>
            <span class="font-bold <%= person.compliancePct >= 85 ? 'text-green-600' : person.compliancePct >= 65 ? 'text-amber-600' : 'text-red-600' %>"><%= person.compliancePct %>%</span>
          </div>
          <div class="w-full bg-slate-200 rounded-full h-1.5">
            <div class="h-1.5 rounded-full <%= person.compliancePct >= 85 ? 'bg-green-500' : person.compliancePct >= 65 ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= person.compliancePct %>%"></div>
          </div>
        </div>

        <% if (person.flags.length) { %>
        <div class="space-y-1 mt-2">
          <% person.flags.slice(0,2).forEach(flag => { %>
          <div class="text-xs text-slate-600 flex items-center gap-1">
            <span class="text-amber-500">⚠</span> <%= flag %>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="text-xs text-green-600 mt-2 flex items-center gap-1"><span>✓</span> Sin alertas</div>
        <% } %>
      </a>
      <% }) %>
    </div>
  </section>

  <%# ── Charts Row ────────────────────────────────────────────────────────────── %>
  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-slate-900">Horas por Semana</h3>
        <div class="text-xs text-slate-400">Últimas 8 semanas</div>
      </div>
      <div style="height: 220px;">
        <canvas id="weeklyChart"></canvas>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-bold text-slate-900 mb-1">Billable vs Non-Billable</h3>
      <p class="text-xs text-slate-400 mb-4">Esta semana</p>
      <div style="height: 160px;">
        <canvas id="billableChart"></canvas>
      </div>
      <div class="mt-4 space-y-2">
        <div class="flex items-center justify-between text-xs">
          <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-green-500"></div><span class="text-slate-600">Billable</span></div>
          <span class="font-bold text-green-600"><%= summary.billableWeek || 0 %>h</span>
        </div>
        <div class="flex items-center justify-between text-xs">
          <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-orange-400"></div><span class="text-slate-600">Non-Billable</span></div>
          <span class="font-bold text-orange-500"><%= summary.nonBillableWeek || 0 %>h</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── Cumplimiento Metodológico ──────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Cumplimiento Metodológico</h3>
        <p class="text-sm text-slate-500">Adopción en tareas activas (excluye backlog) · <%= meth.totalActiveTasks || 0 %> tareas</p>
      </div>
      <% if ((meth.tasksWithHoursAndNoSP || 0) > 0) { %>
      <div class="text-xs font-bold text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
        ⚠ <%= meth.tasksWithHoursAndNoSP %> tareas con horas pero sin SP
      </div>
      <% } %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <% [
        { label: 'Story Points', pct: meth.spPct||0, done: meth.tasksWithSP||0, icon: '🎯' },
        { label: 'Sprint asignado', pct: meth.sprintPct||0, done: meth.tasksWithSprint||0, icon: '🏃' },
        { label: 'Horas estimadas', pct: meth.hoursPct||0, done: meth.tasksWithHours||0, icon: '⏱' },
      ].forEach(item => {
        const color = item.pct >= 70 ? 'green' : item.pct >= 40 ? 'amber' : 'red';
      %>
      <div class="rounded-xl border p-4 <%= color === 'green' ? 'border-green-200 bg-green-50' : color === 'amber' ? 'border-amber-200 bg-amber-50' : 'border-red-200 bg-red-50' %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold uppercase tracking-wide flex items-center gap-1 <%= color === 'green' ? 'text-green-700' : color === 'amber' ? 'text-amber-700' : 'text-red-700' %>">
            <%= item.icon %> <%= item.label %>
          </span>
          <span class="text-2xl font-black <%= color === 'green' ? 'text-green-700' : color === 'amber' ? 'text-amber-700' : 'text-red-700' %>"><%= item.pct %>%</span>
        </div>
        <div class="w-full bg-white rounded-full h-2 mb-2">
          <div class="h-2 rounded-full <%= color === 'green' ? 'bg-green-500' : color === 'amber' ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= item.pct %>%"></div>
        </div>
        <div class="text-xs text-slate-600"><%= item.done %> / <%= meth.totalActiveTasks||0 %> tareas</div>
      </div>
      <% }) %>
    </div>
  </section>

  <%# ── Horas por Proyecto (Heatmap) ──────────────────────────────────────────── %>
  <% const cols = topProjectCols || []; %>
  <% if (cols.length > 0 && consultants.length > 0) { %>
  <%
    // Compute max hours for heatmap scale
    const maxHours = Math.max(...cols.map(c => c.total), 1);
    function heatClass(h) {
      if (!h || h === 0) return 'heatmap-0';
      const pct = h / maxHours;
      if (pct < 0.10) return 'heatmap-xs';
      if (pct < 0.25) return 'heatmap-sm';
      if (pct < 0.50) return 'heatmap-md';
      if (pct < 0.75) return 'heatmap-lg';
      return 'heatmap-xl';
    }
  %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Horas por Proyecto</h3>
        <p class="text-sm text-slate-500">Período: <%= rangeLabel %> · Top <%= cols.length %> proyectos por volumen</p>
      </div>
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <div class="flex gap-1 items-center">
          <div class="w-3 h-3 rounded heatmap-xs border"></div>
          <div class="w-3 h-3 rounded heatmap-sm border"></div>
          <div class="w-3 h-3 rounded heatmap-md border"></div>
          <div class="w-3 h-3 rounded heatmap-lg border"></div>
          <div class="w-3 h-3 rounded heatmap-xl border"></div>
        </div>
        <span>bajo → alto</span>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b-2 border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 min-w-36">Consultor</th>
            <th class="text-right py-2 px-3 font-bold text-slate-700 min-w-20">Total</th>
            <% cols.forEach(col => { %>
            <th class="text-center py-2 px-2 font-medium text-slate-500 min-w-20">
              <div class="truncate max-w-20" title="<%= col.name %>"><%= col.name %></div>
              <div class="text-slate-400 font-normal mt-0.5"><%= col.total %>h</div>
            </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% consultants.forEach(c => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-2 px-3">
              <div class="font-semibold text-slate-800"><%= c.name %></div>
              <% if (c.job) { %><div class="text-slate-400"><%= c.job.replace(' Consultant', '') %></div><% } %>
            </td>
            <td class="py-2 px-3 text-right font-bold text-slate-900"><%= c.hoursInRange %>h</td>
            <% (c.projectHours || []).forEach((h, i) => { %>
            <td class="py-1 px-1">
              <div class="rounded-md text-center py-1.5 font-semibold <%= heatClass(h) %>">
                <%= h > 0 ? h + 'h' : '-' %>
              </div>
            </td>
            <% }) %>
          </tr>
          <% }) %>
          <tr class="border-t-2 border-slate-200 bg-slate-50">
            <td class="py-2 px-3 font-bold text-slate-700 text-xs">Total</td>
            <td class="py-2 px-3 text-right font-bold text-slate-900"><%= round(consultants.reduce((s,c)=>s+(c.hoursInRange||0),0)) %>h</td>
            <% cols.forEach(col => { %>
            <td class="py-2 px-1 text-center font-bold text-slate-700"><%= col.total %>h</td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>

  <%# ── Alertas Detalladas (colapsable) ──────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <details>
      <summary class="flex items-center justify-between px-5 py-4 hover:bg-slate-50 transition-colors select-none">
        <div class="flex items-center gap-3">
          <span class="text-lg font-extrabold text-slate-900">Alertas Detalladas</span>
          <div class="flex gap-1.5">
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-700"><%= criticalCount %> críticas</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700"><%= warningCount %> warnings</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700"><%= infoCount %> info</span>
          </div>
        </div>
        <svg class="chevron w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="border-t border-slate-100">
        <div class="flex gap-1 bg-slate-50 px-5 py-2 border-b border-slate-100" id="alertFilters">
          <button class="alert-filter-btn active px-3 py-1 rounded text-xs font-bold bg-slate-800 text-white" data-filter="all">Todas (<%= criticalCount + warningCount + infoCount %>)</button>
          <button class="alert-filter-btn px-3 py-1 rounded text-xs font-bold text-red-700 bg-red-100 hover:bg-red-200" data-filter="critical">🚨 <%= criticalCount %></button>
          <button class="alert-filter-btn px-3 py-1 rounded text-xs font-bold text-amber-700 bg-amber-100 hover:bg-amber-200" data-filter="warning">🟡 <%= warningCount %></button>
          <button class="alert-filter-btn px-3 py-1 rounded text-xs font-bold text-blue-700 bg-blue-100 hover:bg-blue-200" data-filter="info">💤 <%= infoCount %></button>
        </div>
        <div class="overflow-x-auto max-h-80 overflow-y-auto">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="text-left py-2 px-3 font-semibold text-slate-600 w-8">#</th>
                <th class="text-left py-2 px-3 font-semibold text-slate-600 w-16">Nivel</th>
                <th class="text-left py-2 px-3 font-semibold text-slate-600 w-24">Consultor</th>
                <th class="text-left py-2 px-3 font-semibold text-slate-600">Mensaje</th>
                <th class="text-left py-2 px-3 font-semibold text-slate-600 w-28">Categoría</th>
                <th class="text-left py-2 px-3 font-semibold text-slate-600">Detalle</th>
              </tr>
            </thead>
            <tbody id="alertsTableBody">
              <% anomalies.forEach((a, i) => { %>
              <tr class="alert-row border-b border-slate-50 hover:bg-slate-50" data-type="<%= a.type %>">
                <td class="py-2 px-3 text-slate-400"><%= i+1 %></td>
                <td class="py-2 px-3">
                  <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-bold <%= a.type==='critical'?'bg-red-100 text-red-700':a.type==='warning'?'bg-amber-100 text-amber-700':'bg-blue-100 text-blue-700' %>">
                    <%= a.type==='critical'?'🚨':a.type==='warning'?'🟡':'💤' %>
                  </span>
                </td>
                <td class="py-2 px-3 font-medium text-slate-800"><%= a.user %></td>
                <td class="py-2 px-3 font-semibold text-slate-800"><%= a.message %></td>
                <td class="py-2 px-3"><span class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-600 font-medium"><%= a.category %></span></td>
                <td class="py-2 px-3 text-slate-500 max-w-xs truncate" title="<%= a.detail %>"><%= a.detail %></td>
              </tr>
              <% }) %>
              <% if (!anomalies.length) { %>
              <tr><td colspan="6" class="py-10 text-center text-slate-400">✅ Sin anomalías detectadas</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </details>
  </section>

  <%# ── Disciplina de Logeo ────────────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3 mb-5">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Disciplina de Logeo</h3>
        <p class="text-sm text-slate-500">Últimos <span id="loggingWindowLabel"><%= lco.complianceDays || 0 %></span> días hábiles · Referencia: <span id="loggingLatestBusinessLabel"><%= lco.latestBusinessLabel || '-' %></span></p>
      </div>
      <div class="grid grid-cols-4 gap-2 text-center">
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
          <div class="text-xs font-semibold text-slate-500 uppercase mb-0.5">Compliance</div>
          <div class="text-xl font-black text-slate-900" id="loggingCompliancePct"><%= lco.compliancePct || 0 %>%</div>
        </div>
        <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2">
          <div class="text-xs font-semibold text-red-600 uppercase mb-0.5">Sin log hoy</div>
          <div class="text-xl font-black text-red-600" id="loggingMissingLatestCount"><%= lco.missingLatestBusinessDayCount || 0 %></div>
        </div>
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
          <div class="text-xs font-semibold text-amber-700 uppercase mb-0.5">Sin semana</div>
          <div class="text-xl font-black text-amber-600" id="loggingNoWeekCount"><%= lco.noLogThisWeekCount || 0 %></div>
        </div>
        <div class="rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2">
          <div class="text-xs font-semibold text-indigo-700 uppercase mb-0.5">Sospechosos</div>
          <div class="text-xl font-black text-indigo-700" id="loggingSuspiciousCount"><%= lco.suspiciousCount || 0 %></div>
        </div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-slate-100 align-bottom">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Persona</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Compliance</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Semana</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Calidad</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Últimos días hábiles</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Estado</th>
          </tr>
          <tr class="border-b border-slate-100 text-[11px] text-slate-400" id="loggingDatesHeaderRow">
            <th></th><th></th><th></th><th></th>
            <th class="py-2 px-3">
              <div class="flex gap-1">
                <% lc.displayDates.forEach((day) => { %>
                <span class="log-day text-center"><%= day.label %></span>
                <% }) %>
              </div>
            </th>
            <th></th>
          </tr>
        </thead>
        <tbody id="loggingTableBody">
          <% lc.people.forEach((person) => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-3 px-3 align-top">
              <div class="font-semibold text-slate-900 text-xs"><%= person.name %></div>
              <div class="text-xs text-slate-400 mt-0.5"><%= person.job || 'Sin rol' %></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-black <%= person.compliancePct>=85?'text-green-600':person.compliancePct>=65?'text-amber-600':'text-red-600' %>"><%= person.compliancePct %>%</div>
              <div class="text-xs text-slate-400"><%= person.loggedDays %>/<%= person.expectedDays %> días</div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-bold text-slate-900"><%= person.hoursThisWeek %>h</div>
              <div class="text-xs text-slate-400"><%= person.entriesThisWeek %> cargas</div>
            </td>
            <td class="py-3 px-3 align-top text-xs text-slate-500 space-y-0.5">
              <div>Desc. cortas <span class="font-semibold text-slate-700"><%= person.quality.shortDescPct %>%</span></div>
              <div>Tardías <span class="font-semibold text-slate-700"><%= person.quality.latePct %>%</span></div>
              <div>Pre-logeo <span class="font-semibold <%= person.quality.preLogPct > 10 ? 'text-red-600' : 'text-slate-700' %>"><%= person.quality.preLogPct %>%</span></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="flex gap-1">
                <% person.recentDays.forEach((day) => { %>
                <div class="log-day rounded-md border px-1.5 py-1 text-center text-[11px] font-semibold
                  <%= day.isMissing ? 'bg-red-50 border-red-200 text-red-600' : day.hours>=8 ? 'bg-indigo-50 border-indigo-200 text-indigo-700' : day.hours>=4 ? 'bg-blue-50 border-blue-200 text-blue-700' : 'bg-amber-50 border-amber-200 text-amber-700' %>"
                  title="<%= `${day.label}: ${day.hours}h / ${day.entries} cargas${day.lateEntries ? ' / tardías: '+day.lateEntries : ''}${day.preLogEntries ? ' / pre-logeo: '+day.preLogEntries : ''}` %>">
                  <div><%= day.hours > 0 ? `${day.hours}h` : '0' %></div>
                  <div class="text-[10px] <%= day.lateEntries ? 'text-amber-500' : day.preLogEntries ? 'text-purple-500' : 'text-slate-300' %>"><%= day.lateEntries ? 'T' : day.preLogEntries ? 'P' : '.' %></div>
                </div>
                <% }) %>
              </div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold
                <%= person.status==='critical'?'bg-red-100 text-red-700':person.status==='warning'?'bg-amber-100 text-amber-700':'bg-green-100 text-green-700' %>">
                <%= person.status==='critical'?'Crítico':person.status==='warning'?'Warning':'Sano' %> · <%= person.suspiciousScore %>
              </div>
              <% if (person.flags.length) { %>
              <div class="mt-1.5 space-y-0.5">
                <% person.flags.forEach(flag => { %><div class="text-xs text-slate-500">- <%= flag %></div><% }) %>
              </div>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!lc.people.length) { %>
          <tr><td colspan="6" class="py-10 text-center text-slate-400">No hay datos de logeo para el período seleccionado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <%# ── Estado de Proyectos ─────────────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <h3 class="font-bold text-slate-900 text-lg">Estado de Proyectos</h3>
      <div class="flex gap-1 ml-auto" id="statusFilters">
        <span class="text-xs font-semibold text-slate-500 self-center mr-1">Estado:</span>
        <% statusFilters.forEach(f => { %>
        <a href="<%= buildQuery({status: f.value}) %>"
           class="filter-btn px-2.5 py-1 rounded-lg border border-slate-200 text-xs font-semibold transition-colors hover:bg-blue-50 <%= activeFilters.status === f.value ? 'active' : 'text-slate-600' %>"><%= f.label %></a>
        <% }) %>
      </div>
      <div class="flex gap-1">
        <span class="text-xs font-semibold text-slate-500 self-center mr-1">Etiqueta:</span>
        <% tagFilters.forEach(f => { %>
        <a href="<%= buildQuery({tag: f.value}) %>"
           class="filter-btn px-2.5 py-1 rounded-lg border border-slate-200 text-xs font-semibold transition-colors hover:bg-blue-50 <%= activeFilters.tag === f.value ? 'active' : 'text-slate-600' %>"><%= f.label %></a>
        <% }) %>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Proyecto</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Progreso</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Log</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-600 text-xs">Estimado</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Abiertas / Hechas</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Backlog</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-600 text-xs">Actualización</th>
          </tr>
        </thead>
        <tbody id="projectsTable">
          <% projectStatuses.slice(0, 20).forEach((p) => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 <%= p.needsAttention ? 'bg-red-50/50' : '' %>">
            <td class="py-2 px-3">
              <div class="font-medium text-slate-800 text-xs"><%= p.name %></div>
              <% if (p.needsAttention) { %><span class="text-xs text-red-600 font-semibold">⚠ Atención</span><% } %>
            </td>
            <td class="py-2 px-3">
              <div class="flex items-center gap-2">
                <div class="flex-1 bg-slate-100 rounded-full h-1.5 min-w-16">
                  <div class="h-1.5 rounded-full <%= p.stageProgress>80?'bg-green-500':p.stageProgress>50?'bg-blue-400':'bg-slate-300' %>" style="width:<%= p.stageProgress %>%"></div>
                </div>
                <span class="text-xs font-bold <%= p.stageProgress>80?'text-green-600':p.stageProgress>50?'text-blue-500':'text-slate-400' %>"><%= p.stageProgress %>%</span>
              </div>
            </td>
            <td class="py-2 px-3 text-right text-xs <%= p.hoursPct&&p.hoursPct>120?'text-red-600 font-bold':p.hoursPct&&p.hoursPct>100?'text-amber-600':'text-green-600' %>">
              <%= p.totalLog %>h<% if (p.hoursPct) { %> <span class="text-slate-400">(<%= p.hoursPct %>%)</span><% } %>
            </td>
            <td class="py-2 px-3 text-right text-xs text-slate-400"><%= p.totalAlloc > 0 ? p.totalAlloc + 'h' : '-' %></td>
            <td class="py-2 px-3 text-center text-xs text-slate-500"><%= p.openTasks %> / <%= p.doneTasks %></td>
            <td class="py-2 px-3 text-center text-xs text-slate-400"><%= p.backlogTasks %></td>
            <td class="py-2 px-3 text-center text-xs">
              <span class="<%= p.daysSinceUpdate>14?'text-red-600 font-bold':p.daysSinceUpdate>7?'text-amber-500':'text-green-600' %>">
                <%= p.daysSinceUpdate>14?'🔴':p.daysSinceUpdate>7?'🟡':'🟢' %> <%= p.daysSinceUpdate>99?'Nunca':`Hace ${p.daysSinceUpdate}d` %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mt-3 text-xs text-slate-400"><%= projectStatuses.length %> proyectos<%= activeFilters.status!=='all'||activeFilters.tag!=='all'?' (filtrados)':'' %></div>
  </section>

</div>

<footer class="text-center text-xs text-slate-400 py-6 mt-4">
  Torus Dashboard Platform · <%= new Date().getFullYear() %>
</footer>

<script>
// ── Charts ────────────────────────────────────────────────────────────────────
const weeklyLabels = <%- JSON.stringify(weeklyLabels) %>;
const weeklyHours  = <%- JSON.stringify(weeklyHours) %>;

function renderWeeklyChart() {
  const ctx = document.getElementById('weeklyChart')?.getContext('2d');
  if (!ctx) return;
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: weeklyLabels,
      datasets: [{
        label: 'Horas',
        data: weeklyHours,
        backgroundColor: weeklyHours.map((_, i) => i === weeklyHours.length - 1 ? '#3B82F6' : '#BFDBFE'),
        borderRadius: 6, borderSkipped: false,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.raw}h` } } },
      scales: {
        y: { beginAtZero: true, grid: { color: '#F1F5F9' }, ticks: { callback: v => `${v}h`, font: { size: 11 } } },
        x: { grid: { display: false }, ticks: { font: { size: 10 } } }
      }
    }
  });
}

function renderBillableChart() {
  const ctx = document.getElementById('billableChart')?.getContext('2d');
  if (!ctx) return;
  const billable    = <%= summary.billableWeek || 0 %>;
  const nonBillable = <%= summary.nonBillableWeek || 0 %>;
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Billable', 'Non-Billable'],
      datasets: [{ data: [billable, nonBillable], backgroundColor: ['#10B981', '#FB923C'], borderWidth: 0, hoverOffset: 4 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, cutout: '65%',
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw}h` } } }
    }
  });
}

// ── Alert filter buttons ──────────────────────────────────────────────────────
function filterAlerts(type) {
  document.querySelectorAll('.alert-filter-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.filter === type);
    if (btn.dataset.filter === type) {
      btn.style.background = '#0f172a'; btn.style.color = '#fff';
    } else {
      btn.style.background = ''; btn.style.color = '';
    }
  });
  document.querySelectorAll('.alert-row').forEach(row => {
    row.style.display = (type === 'all' || row.dataset.type === type) ? '' : 'none';
  });
}

document.getElementById('alertFilters')?.addEventListener('click', e => {
  const btn = e.target.closest('[data-filter]');
  if (btn) filterAlerts(btn.dataset.filter);
});

// ── Consultant select: preserve other query params ────────────────────────────
// (handled inline via onchange in the template)

// ── Init ──────────────────────────────────────────────────────────────────────
renderWeeklyChart();
renderBillableChart();
</script>
</body>
</html>
