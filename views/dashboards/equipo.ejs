<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .filter-btn.active { background:#2563EB; color:#fff; border-color:#2563EB; }
    .filter-btn:hover:not(.active) { background:#EFF6FF; }
    .log-day { min-width: 48px; }
    details > summary { cursor: pointer; list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    details[open] .chevron { transform: rotate(180deg); }
    .heatmap-0  { background:#F8FAFC; color:#CBD5E1; }
    .heatmap-xs { background:#DBEAFE; color:#1E40AF; }
    .heatmap-sm { background:#BFDBFE; color:#1D4ED8; }
    .heatmap-md { background:#93C5FD; color:#1E3A8A; }
    .heatmap-lg { background:#3B82F6; color:#fff; }
    .heatmap-xl    { background:#1D4ED8; color:#fff; }
    .heatmap-leave { background:#EDE9FE; color:#7C3AED; }   /* approved leave day */
    /* Date picker */
    #datePicker { min-width: 440px; }
    .preset-btn.active { background:#EFF6FF; color:#2563EB; font-weight:700; }
    .preset-btn:hover:not(.active) { background:#F8FAFC; }
    /* Consultant picker */
    #consultantPicker { min-width: 320px; max-height: 380px; overflow-y:auto; }
    .consultant-check:checked + label { color:#1D4ED8; font-weight:600; }
    /* Dropdown overlay */
    .picker-overlay { position:fixed; inset:0; z-index:30; }
    /* Tooltip for truncated headers */
    .has-tooltip { position: relative; cursor: default; }
    .has-tooltip .tt {
      display:none; position:absolute; bottom:100%; left:50%; transform:translateX(-50%);
      background:#1E293B; color:#fff; font-size:11px; font-weight:500;
      white-space:nowrap; padding:4px 8px; border-radius:6px; z-index:100;
      pointer-events:none; margin-bottom:4px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .has-tooltip:hover .tt { display:block; }
    /* Heatmap cell link */
    .heatmap-cell { cursor:pointer; transition:opacity .15s; }
    .heatmap-cell:hover { opacity:.8; }
    /* Tabs */
    .tab-btn { border-bottom: 2px solid transparent; }
    .tab-btn.active { border-bottom-color: #2563EB; color: #2563EB; font-weight: 700; }
    .tab-btn:not(.active) { color: #64748B; }
    .tab-btn:hover:not(.active) { color: #334155; border-bottom-color: #CBD5E1; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

<%# ── Nav ──────────────────────────────────────────────────────────────────── %>
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <img src="/img/torus-icon-green.png" alt="Torus" class="h-8 w-auto">

      <span class="text-slate-400 text-sm font-medium">/ Control de Equipo</span>
      <span class="text-slate-300">·</span>
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800">Inicio</a>
      <% if (user && ['admin','director'].includes(user.role)) { %>
      <span class="text-slate-300">·</span>
      <a href="/finanzas" class="text-sm font-medium text-green-600 hover:text-green-800">Finanzas</a>
      <% } %>
      <% if (user && user.role === 'admin') { %>
      <span class="text-slate-300">·</span>
      <a href="/admin/users" class="text-sm font-medium text-slate-500 hover:text-slate-700">Usuarios</a>
      <% } %>
      <% if (activeFilters.range !== '30d' || selectedLogins.size > 0 || activeFilters.status !== 'all' || activeFilters.tag !== 'all') { %>
      <span class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold">
        Filtrado
        <a href="/equipo" class="text-blue-500 hover:text-blue-800 ml-1">✕</a>
      </span>
      <% } %>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse" id="refreshDot"></div>
        <span>Actualizado: <%= lastUpdate %></span>
        <button id="refreshBtn" onclick="manualRefresh()" title="Actualizar datos desde Odoo"
          class="px-2 py-0.5 rounded-md bg-slate-100 hover:bg-blue-100 text-slate-400 hover:text-blue-600 transition-colors font-bold text-sm leading-none">↺</button>
        <span class="px-1.5 py-0.5 rounded bg-slate-100 font-mono text-[10px] text-slate-400"
              title="Deploy: <%= appDeployAt %>">v<%= appVersion %></span>
      </div>
      <% if (user) { %>
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-2">
          <% if (user.picture) { %>
          <img src="<%= user.picture %>" class="w-7 h-7 rounded-full border border-slate-200" alt="">
          <% } else { %>
          <div class="w-7 h-7 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold text-blue-800">
            <%= (user.name||user.email).slice(0,1).toUpperCase() %>
          </div>
          <% } %>
          <span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span>
          <span class="text-xs px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-500 font-semibold capitalize"><%= user.role %></span>
        </div>
        <form action="/auth/logout" method="POST" class="inline">
          <button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Salir</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</nav>

<%# ── Sticky Filter Bar (tabs + context filters) ────────────────────────────── %>
<div class="sticky top-[57px] z-40 bg-white border-b border-slate-200 shadow-sm">
  <%# Tab row %>
  <div class="max-w-7xl mx-auto px-4 flex items-center gap-0 border-b border-slate-100">
    <button onclick="switchTab('equipo')" id="tab-btn-equipo"
            class="tab-btn active px-5 py-2.5 text-sm font-semibold transition-all">
      👥 Equipo
    </button>
    <button onclick="switchTab('proyectos')" id="tab-btn-proyectos"
            class="tab-btn px-5 py-2.5 text-sm font-semibold transition-all">
      📁 Proyectos
      <span class="ml-1.5 text-xs font-bold text-slate-400"><%= projectStatuses.length %></span>
    </button>
    <button onclick="switchTab('capacidad')" id="tab-btn-capacidad"
            class="tab-btn px-5 py-2.5 text-sm font-semibold transition-all">
      ⚡ Capacidad
    </button>
    <button onclick="switchTab('sprints')" id="tab-btn-sprints"
            class="tab-btn px-5 py-2.5 text-sm font-semibold transition-all">
      🏃 Sprints
      <% if (sprintOverview && sprintOverview.length > 0) { %><span class="ml-1.5 text-xs font-bold text-slate-400"><%= sprintOverview.length %></span><% } %>
    </button>
    <button onclick="switchTab('alertas')" id="tab-btn-alertas"
            class="tab-btn px-5 py-2.5 text-sm font-semibold transition-all">
      🚨 Alertas
      <% const critAlerts = (projectAlerts || []).filter(a => a.severity === 'critical').length; if (critAlerts > 0) { %><span class="ml-1.5 text-xs font-bold bg-red-500 text-white rounded-full px-1.5 py-0.5"><%= critAlerts %></span><% } %>
    </button>
  </div>
  <%# Filter row %>
  <div class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap items-center gap-3">

    <%# ── Date Picker Button ── %>
    <div class="relative" id="datePickerWrap">
      <button onclick="toggleDatePicker()" id="datePickerBtn"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-xs font-semibold text-slate-700 hover:border-blue-300 hover:bg-blue-50 transition-colors select-none">
        <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span id="datePickerLabel"><%= rangeLabel %></span>
        <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>

      <%# ── Date Picker Dropdown ── %>
      <div id="datePicker" class="hidden absolute top-full left-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-xl z-50 overflow-hidden">
        <div class="flex">
          <%# Presets column %>
          <div class="w-40 border-r border-slate-100 py-2">
            <% dateRanges.forEach(r => { %>
            <button class="preset-btn w-full text-left px-4 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors <%= activeFilters.range === r.value ? 'active' : '' %>"
                    data-range="<%= r.value %>" onclick="selectPreset('<%= r.value %>')">
              <%= r.label %>
            </button>
            <% }) %>
            <div class="border-t border-slate-100 my-1"></div>
            <button class="preset-btn w-full text-left px-4 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors <%= activeFilters.range === 'custom' ? 'active' : '' %>"
                    data-range="custom" onclick="selectPreset('custom')">
              Personalizado
            </button>
          </div>
          <%# Info / custom inputs panel %>
          <div class="flex-1 p-4 min-w-56" id="datePickerPanel">
            <% if (activeFilters.range === 'custom' && activeFilters.from && activeFilters.to) { %>
            <div id="customPanel" class="">
            <% } else { %>
            <div id="customPanel" class="hidden">
            <% } %>
              <div class="text-xs font-bold text-slate-700 mb-3">Rango personalizado</div>
              <div class="space-y-2">
                <div>
                  <label class="text-xs text-slate-500 font-semibold block mb-1">Desde</label>
                  <input type="date" id="customFrom" value="<%= activeFilters.from || '' %>"
                         class="w-full text-xs border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-300">
                </div>
                <div>
                  <label class="text-xs text-slate-500 font-semibold block mb-1">Hasta</label>
                  <input type="date" id="customTo" value="<%= activeFilters.to || '' %>"
                         class="w-full text-xs border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-300">
                </div>
                <button onclick="applyCustomDate()"
                        class="w-full bg-blue-600 text-white text-xs font-bold py-2 rounded-lg hover:bg-blue-700 mt-2 transition-colors">
                  Aplicar rango
                </button>
              </div>
            </div>
            <div id="presetInfoPanel" class="<%= activeFilters.range === 'custom' ? 'hidden' : '' %>">
              <div class="text-xs font-bold text-slate-700 mb-2">Período activo</div>
              <div class="text-sm font-black text-blue-700 mb-1" id="presetInfoLabel"><%= rangeLabel %></div>
              <div class="text-xs text-slate-400">Seleccioná un período de la lista o definí un rango personalizado.</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Context: Equipo filters (consultant) ── %>
    <div id="ctx-equipo" class="flex items-center gap-3">
    <div class="relative" id="consultantPickerWrap">
      <button onclick="toggleConsultantPicker()" id="consultantPickerBtn"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-xs font-semibold text-slate-700 hover:border-blue-300 hover:bg-blue-50 transition-colors select-none">
        <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span id="consultantPickerLabel"><%= consultantLabel %></span>
        <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>

      <%# ── Consultant Picker Dropdown ── %>
      <div id="consultantPicker" class="hidden absolute top-full left-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-xl z-50">
        <%# Quick group buttons %>
        <div class="px-3 pt-3 pb-2 border-b border-slate-100 flex items-center gap-2">
          <button onclick="selectGroup('all')" class="group-btn text-xs px-2.5 py-1 rounded-lg bg-slate-100 text-slate-700 font-semibold hover:bg-blue-100 hover:text-blue-700 transition-colors">Todos</button>
          <button onclick="selectGroup('technical')" class="group-btn text-xs px-2.5 py-1 rounded-lg bg-slate-100 text-slate-700 font-semibold hover:bg-blue-100 hover:text-blue-700 transition-colors">Solo Técnicos</button>
          <button onclick="selectGroup('functional')" class="group-btn text-xs px-2.5 py-1 rounded-lg bg-slate-100 text-slate-700 font-semibold hover:bg-blue-100 hover:text-blue-700 transition-colors">Solo Funcionales</button>
        </div>
        <div class="px-3 py-2">
          <%# Group: Técnicos %>
          <% const technicos = consultantOptions.filter(c => c.jobType === 'technical'); %>
          <% const funcionales = consultantOptions.filter(c => c.jobType === 'functional'); %>
          <% if (technicos.length > 0) { %>
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider px-1 mb-1.5 mt-1">Técnicos</div>
          <% technicos.forEach(c => { %>
          <label class="flex items-center gap-2.5 px-2 py-1.5 rounded-lg hover:bg-slate-50 cursor-pointer group">
            <input type="checkbox" class="consultant-checkbox w-3.5 h-3.5 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                   value="<%= c.login %>" data-type="technical"
                   <%= selectedLogins.has(c.login) ? 'checked' : '' %>>
            <span class="text-xs text-slate-700 group-hover:text-blue-700 font-medium"><%= c.name %></span>
          </label>
          <% }) %>
          <% } %>
          <% if (funcionales.length > 0) { %>
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider px-1 mb-1.5 mt-3">Funcionales</div>
          <% funcionales.forEach(c => { %>
          <label class="flex items-center gap-2.5 px-2 py-1.5 rounded-lg hover:bg-slate-50 cursor-pointer group">
            <input type="checkbox" class="consultant-checkbox w-3.5 h-3.5 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                   value="<%= c.login %>" data-type="functional"
                   <%= selectedLogins.has(c.login) ? 'checked' : '' %>>
            <span class="text-xs text-slate-700 group-hover:text-blue-700 font-medium"><%= c.name %></span>
          </label>
          <% }) %>
          <% } %>
        </div>
        <div class="px-3 pb-3 pt-2 border-t border-slate-100">
          <button onclick="applyConsultantFilter()"
                  class="w-full bg-blue-600 text-white text-xs font-bold py-2 rounded-lg hover:bg-blue-700 transition-colors">
            Aplicar filtro
          </button>
        </div>
      </div>
    </div>
    </div><!-- /ctx-equipo -->

    <%# ── Context: Proyectos filters (estado + tag) ── %>
    <div id="ctx-proyectos" class="hidden items-center gap-3" style="display:none">
      <div class="flex items-center gap-1 border-l border-slate-200 pl-3">
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mr-1">Estado:</span>
        <% statusFilters.forEach(f => { %>
        <a href="<%= buildQuery({status: f.value}) %>"
           onclick="event.preventDefault(); applyProjectFilter('<%= buildQuery({status: f.value}) %>')"
           class="filter-btn px-2 py-1 rounded-lg border border-slate-200 text-[10px] font-semibold transition-colors hover:bg-blue-50 <%= activeFilters.status === f.value ? 'active' : 'text-slate-600' %>"><%= f.label %></a>
        <% }) %>
      </div>
      <div class="flex items-center gap-1">
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mr-1">Etiqueta:</span>
        <% tagFilters.forEach(f => { %>
        <a href="<%= buildQuery({tag: f.value}) %>"
           onclick="event.preventDefault(); applyProjectFilter('<%= buildQuery({tag: f.value}) %>')"
           class="filter-btn px-2 py-1 rounded-lg border border-slate-200 text-[10px] font-semibold transition-colors hover:bg-blue-50 <%= activeFilters.tag === f.value ? 'active' : 'text-slate-600' %>"><%= f.label %></a>
        <% }) %>
      </div>
    </div><!-- /ctx-proyectos -->

    <% if (activeFilters.range !== '30d' || selectedLogins.size > 0 || activeFilters.status !== 'all' || activeFilters.tag !== 'all') { %>
    <a href="/equipo" class="ml-auto text-xs text-red-500 hover:text-red-700 font-semibold">✕ Limpiar</a>
    <% } %>
  </div>
</div>

<div id="tab-equipo" class="max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%# ── KPI Row ───────────────────────────────────────────────────────────────── %>
  <%
    const round = v => Math.round(v * 10) / 10;
    const meth = methodology || {};
    const lc = loggingControl || { overview: {}, displayDates: [], people: [] };
    const lco = lc.overview || {};
  %>
  <section class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Hrs semana</div>
      <div class="text-2xl font-black text-slate-900"><%= summary.weekHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.activeUsers %> activos hoy</div>
    </div>
    <div class="bg-white rounded-xl border-2 border-blue-200 p-4">
      <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-1 truncate" title="<%= rangeLabel %>">Hrs período</div>
      <div class="text-2xl font-black text-blue-700"><%= summary.rangeHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.billableRangePct %>% billable</div>
    </div>
    <div class="bg-white rounded-xl border-2 border-green-200 p-4">
      <div class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Billable semana</div>
      <div class="text-2xl font-black text-green-600"><%= summary.billableWeek %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.weekHours > 0 ? Math.round((summary.billableWeek||0)/summary.weekHours*100) : 0 %>% del total</div>
    </div>
    <div class="bg-white rounded-xl border p-4 <%= (meth.spPct||0) < 20 ? 'border-red-200' : 'border-slate-200' %>">
      <div class="text-xs font-semibold <%= (meth.spPct||0) < 20 ? 'text-red-500' : 'text-slate-500' %> uppercase tracking-wide mb-1">Story Points</div>
      <div class="text-2xl font-black <%= (meth.spPct||0) < 20 ? 'text-red-600' : (meth.spPct||0) < 60 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.spPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithSP||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">En Sprint</div>
      <div class="text-2xl font-black <%= (meth.sprintPct||0) < 40 ? 'text-red-600' : (meth.sprintPct||0) < 70 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.sprintPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithSprint||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Estimadas</div>
      <div class="text-2xl font-black <%= (meth.hoursPct||0) < 40 ? 'text-red-600' : (meth.hoursPct||0) < 70 ? 'text-amber-600' : 'text-green-600' %>"><%= meth.hoursPct||0 %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= meth.tasksWithHours||0 %> / <%= meth.totalActiveTasks||0 %> tareas</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <% const cr = summary.completionRate || 0; %>
      <div class="text-xs font-semibold <%= cr >= 70 ? 'text-green-600' : cr >= 40 ? 'text-amber-600' : 'text-red-500' %> uppercase tracking-wide mb-1">Completadas</div>
      <div class="text-2xl font-black <%= cr >= 70 ? 'text-green-600' : cr >= 40 ? 'text-amber-600' : 'text-red-600' %>"><%= cr %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= summary.doneTasks || 0 %> / <%= summary.totalTasks || 0 %> tareas</div>
    </div>
  </section>

  <%# ── Estado del Equipo (Consultor Cards) ──────────────────────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-xl font-extrabold text-slate-900">Estado del Equipo</h2>
        <p class="text-sm text-slate-500">
          <span class="font-semibold text-blue-600"><%= rangeLabel %></span> · <%= consultantCards.length %> consultores
          <% if (selectedLogins.size > 0) { %><span class="ml-2 text-blue-600 font-semibold">· <%= consultantLabel %></span><% } %>
        </p>
      </div>
      <div class="flex gap-2 text-xs flex-wrap">
        <% const leaveCount = consultantCards.filter(p => p.status === 'leave').length; %>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-red-100 text-red-700 font-semibold">🔴 <%= lco.criticalCount || 0 %> críticos</span>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-amber-100 text-amber-700 font-semibold">🟡 <%= lco.warningCount || 0 %> warnings</span>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-green-100 text-green-700 font-semibold">🟢 <%= (lco.peopleCount||0) - (lco.suspiciousCount||0) - leaveCount %> sanos</span>
        <% if (leaveCount > 0) { %>
        <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-violet-100 text-violet-700 font-semibold">🏖 <%= leaveCount %> en licencia</span>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% consultantCards.forEach(person => {
        const isLeave     = person.status === 'leave';
        const statusColor = person.status === 'critical' ? 'border-red-300 bg-red-50'
                          : person.status === 'warning'  ? 'border-amber-300 bg-amber-50'
                          : isLeave                      ? 'border-violet-200 bg-violet-50'
                          :                                'border-green-200 bg-green-50';
        const dotColor    = person.status === 'critical' ? 'bg-red-500'
                          : person.status === 'warning'  ? 'bg-amber-400'
                          : isLeave                      ? 'bg-violet-400'
                          :                                'bg-green-500';
        const initials    = (person.name || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
        const avatarBg    = person.status === 'critical' ? 'bg-red-200 text-red-800'
                          : person.status === 'warning'  ? 'bg-amber-200 text-amber-800'
                          : isLeave                      ? 'bg-violet-200 text-violet-800'
                          :                                'bg-blue-200 text-blue-800';
        const statusLabel = person.status === 'critical' ? 'Crítico'
                          : person.status === 'warning'  ? 'Warning'
                          : isLeave                      ? 'En Licencia'
                          :                                'Sano';
        const statusTextCls = person.status === 'critical' ? 'text-red-600'
                            : person.status === 'warning'  ? 'text-amber-600'
                            : isLeave                      ? 'text-violet-600'
                            :                                'text-green-600';
        const odooEmpUrl  = `https://www.torus.dev/odoo/employees`;
      %>
      <div class="bg-white rounded-xl border-2 <%= statusColor %> p-4 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 <%= avatarBg %> rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"><%= initials %></div>
            <div>
              <div class="font-bold text-slate-900 text-sm"><%= person.name %></div>
              <div class="text-xs text-slate-500"><%= person.job || 'Sin rol' %></div>
            </div>
          </div>
          <div class="flex flex-col items-end gap-1">
            <div class="flex items-center gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full <%= dotColor %>"></div>
              <span class="text-xs font-bold <%= statusTextCls %>"><%= statusLabel %></span>
            </div>
            <% if (isLeave) { %>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700 border border-violet-200">
              🏖 En licencia
            </span>
            <% } else if (person.onLeaveToday) { %>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700 border border-violet-200">
              🏖 Licencia parcial
            </span>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-2 mb-3 text-center">
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <div class="text-sm font-black text-slate-900"><%= person.hoursInRange %>h</div>
            <div class="text-[10px] text-slate-400 font-medium uppercase">Período</div>
          </div>
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <%
              const prevH = person.hoursPrevWeek || 0;
              const currH = person.hoursThisWeek || 0;
              const trendPct = prevH > 0 ? Math.round((currH - prevH) / prevH * 100) : null;
              const trendArrow = trendPct === null ? '' : trendPct > 5 ? '↑' : trendPct < -5 ? '↓' : '→';
              const trendCls   = trendPct === null ? '' : trendPct > 5 ? 'text-green-500' : trendPct < -5 ? 'text-red-400' : 'text-slate-400';
            %>
            <div class="text-sm font-black <%= currH > 0 ? 'text-slate-900' : 'text-red-500' %>">
              <%= currH %>h<% if (trendArrow) { %><span class="text-[10px] ml-0.5 <%= trendCls %>"><%= trendArrow %></span><% } %>
            </div>
            <div class="text-[10px] text-slate-400 font-medium uppercase">Esta semana</div>
            <% if (prevH > 0) { %><div class="text-[9px] text-slate-300">sem ant: <%= prevH %>h</div><% } %>
          </div>
          <div class="bg-white rounded-lg p-2 border border-slate-100">
            <% if (isLeave || person.leaveDaysInPeriod > 0) { %>
            <div class="text-sm font-black text-violet-600"><%= person.leaveDaysInPeriod || 0 %>d</div>
            <div class="text-[10px] text-violet-400 font-medium uppercase">Licencia</div>
            <% } else { %>
            <div class="text-sm font-black <%= person.billablePct >= 60 ? 'text-green-600' : person.billablePct > 0 ? 'text-amber-600' : 'text-slate-400' %>"><%= person.billablePct %>%</div>
            <div class="text-[10px] text-slate-400 font-medium uppercase">Billable</div>
            <% } %>
          </div>
        </div>

        <div class="mb-2">
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-500 font-medium">Compliance logeo</span>
            <span class="font-bold <%= person.compliancePct >= 85 ? 'text-green-600' : person.compliancePct >= 65 ? 'text-amber-600' : 'text-red-600' %>"><%= person.compliancePct %>%</span>
          </div>
          <div class="w-full bg-slate-200 rounded-full h-1.5">
            <div class="h-1.5 rounded-full <%= person.compliancePct >= 85 ? 'bg-green-500' : person.compliancePct >= 65 ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= person.compliancePct %>%"></div>
          </div>
        </div>

        <% if (person.flags.length) { %>
        <div class="space-y-1 mt-2">
          <% person.flags.slice(0,2).forEach(flag => { %>
          <div class="text-xs text-slate-600 flex items-center gap-1">
            <span class="text-amber-500">⚠</span> <%= flag %>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="text-xs text-green-600 mt-2 flex items-center gap-1"><span>✓</span> Sin alertas</div>
        <% } %>

        <%# Card actions %>
        <div class="flex items-center gap-2 mt-3 pt-2 border-t border-slate-100">
          <a href="<%= buildQuery({consultants: person.login}) %>"
             class="flex-1 text-center text-xs font-semibold text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-lg py-1 transition-colors">
            Ver solo este
          </a>
          <a href="<%= odooEmpUrl %>" target="_blank" rel="noopener"
             class="flex-1 text-center text-xs font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 rounded-lg py-1 transition-colors flex items-center justify-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Odoo
          </a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <%# ── Charts Row ────────────────────────────────────────────────────────────── %>
  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-slate-900">Horas por Semana</h3>
        <div class="text-xs text-slate-400">Últimas 8 semanas</div>
      </div>
      <div style="height: 220px;">
        <canvas id="weeklyChart"></canvas>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="font-bold text-slate-900 mb-1">Billable vs Non-Billable</h3>
      <p class="text-xs text-slate-400 mb-4">Esta semana</p>
      <div style="height: 160px;">
        <canvas id="billableChart"></canvas>
      </div>
      <div class="mt-4 space-y-2">
        <div class="flex items-center justify-between text-xs">
          <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-green-500"></div><span class="text-slate-600">Billable</span></div>
          <span class="font-bold text-green-600"><%= summary.billableWeek || 0 %>h</span>
        </div>
        <div class="flex items-center justify-between text-xs">
          <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-orange-400"></div><span class="text-slate-600">Non-Billable</span></div>
          <span class="font-bold text-orange-500"><%= summary.nonBillableWeek || 0 %>h</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── Cumplimiento Metodológico ──────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Cumplimiento Metodológico</h3>
        <p class="text-sm text-slate-500">Adopción en tareas activas (excluye backlog) · <%= meth.totalActiveTasks || 0 %> tareas</p>
      </div>
      <% if ((meth.tasksWithHoursAndNoSP || 0) > 0) { %>
      <div class="text-xs font-bold text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
        ⚠ <%= meth.tasksWithHoursAndNoSP %> tareas con horas pero sin SP
      </div>
      <% } %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <% [
        { label: 'Story Points', pct: meth.spPct||0, done: meth.tasksWithSP||0, icon: '🎯' },
        { label: 'Sprint asignado', pct: meth.sprintPct||0, done: meth.tasksWithSprint||0, icon: '🏃' },
        { label: 'Horas estimadas', pct: meth.hoursPct||0, done: meth.tasksWithHours||0, icon: '⏱' },
      ].forEach(item => {
        const color = item.pct >= 70 ? 'green' : item.pct >= 40 ? 'amber' : 'red';
      %>
      <div class="rounded-xl border p-4 <%= color === 'green' ? 'border-green-200 bg-green-50' : color === 'amber' ? 'border-amber-200 bg-amber-50' : 'border-red-200 bg-red-50' %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-bold uppercase tracking-wide flex items-center gap-1 <%= color === 'green' ? 'text-green-700' : color === 'amber' ? 'text-amber-700' : 'text-red-700' %>">
            <%= item.icon %> <%= item.label %>
          </span>
          <span class="text-2xl font-black <%= color === 'green' ? 'text-green-700' : color === 'amber' ? 'text-amber-700' : 'text-red-700' %>"><%= item.pct %>%</span>
        </div>
        <div class="w-full bg-white rounded-full h-2 mb-2">
          <div class="h-2 rounded-full <%= color === 'green' ? 'bg-green-500' : color === 'amber' ? 'bg-amber-400' : 'bg-red-500' %>" style="width:<%= item.pct %>%"></div>
        </div>
        <div class="text-xs text-slate-600"><%= item.done %> / <%= meth.totalActiveTasks||0 %> tareas</div>
      </div>
      <% }) %>
    </div>
  </section>

  <%# ── Horas por Proyecto (Heatmap) ──────────────────────────────────────────── %>
  <% const cols = topProjectCols || []; %>
  <% if (cols.length > 0 && consultants.length > 0) { %>
  <%
    const maxHours = Math.max(...cols.map(c => c.total), 1);
    function heatClass(h) {
      if (!h || h === 0) return 'heatmap-0';
      const pct = h / maxHours;
      if (pct < 0.10) return 'heatmap-xs';
      if (pct < 0.25) return 'heatmap-sm';
      if (pct < 0.50) return 'heatmap-md';
      if (pct < 0.75) return 'heatmap-lg';
      return 'heatmap-xl';
    }
  %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Horas por Proyecto</h3>
        <p class="text-sm text-slate-500">Período: <span class="font-semibold text-blue-600"><%= rangeLabel %></span> · Top <%= cols.length %> proyectos por volumen</p>
      </div>
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <div class="flex gap-1 items-center">
          <div class="w-3 h-3 rounded heatmap-xs border"></div>
          <div class="w-3 h-3 rounded heatmap-sm border"></div>
          <div class="w-3 h-3 rounded heatmap-md border"></div>
          <div class="w-3 h-3 rounded heatmap-lg border"></div>
          <div class="w-3 h-3 rounded heatmap-xl border"></div>
        </div>
        <span>bajo → alto</span>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b-2 border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 min-w-36">Consultor</th>
            <th class="text-right py-2 px-3 font-bold text-slate-700 min-w-20">Total</th>
            <% cols.forEach(col => { %>
            <th class="text-center py-2 px-2 font-medium text-slate-500 min-w-[88px]">
              <div class="font-semibold text-slate-700 text-[11px] leading-tight mx-auto" style="max-width:96px;white-space:normal;word-break:break-word;"><%= col.name %></div>
              <div class="text-slate-400 font-normal mt-1">
                <a href="https://www.torus.dev/web#id=<%= col.id %>&model=project.project" target="_blank" rel="noopener"
                   class="hover:text-blue-500 transition-colors text-[11px]" title="Ver en Odoo">
                  <%= col.total %>h ↗
                </a>
              </div>
            </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% consultants.forEach(c => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-2 px-3">
              <div class="font-semibold text-slate-800"><%= c.name %></div>
              <% if (c.job) { %><div class="text-slate-400"><%= c.job.replace('Consultor ', '').replace(' Consultant', '') %></div><% } %>
            </td>
            <td class="py-2 px-3 text-right font-bold text-slate-900"><%= c.hoursInRange %>h</td>
            <% (c.projectHours || []).forEach((h, i) => {
               const col = cols[i];
               const odooProjectUrl = col ? `https://www.torus.dev/web#id=${col.id}&model=project.project` : '#';
            %>
            <td class="py-1 px-1">
              <% if (h > 0) { %>
              <button onclick="openHeatmapDrilldown('<%= c.login %>',<%= col ? col.id : 0 %>,'<%= c.name.replace(/'/g,"\\'") %>','<%= col ? col.name.replace(/'/g,"\\'") : '' %>')"
                 class="heatmap-cell block w-full rounded-md text-center py-1.5 font-semibold <%= heatClass(h) %>"
                 title="<%= c.name %> · <%= col ? col.name : '' %>: <%= h %>h — clic para detalles">
                <%= h %>h
              </button>
              <% } else { %>
              <div class="rounded-md text-center py-1.5 font-semibold heatmap-0">-</div>
              <% } %>
            </td>
            <% }) %>
          </tr>
          <% }) %>
          <tr class="border-t-2 border-slate-200 bg-slate-50">
            <td class="py-2 px-3 font-bold text-slate-700 text-xs">Total</td>
            <td class="py-2 px-3 text-right font-bold text-slate-900"><%= round(consultants.reduce((s,c)=>s+(c.hoursInRange||0),0)) %>h</td>
            <% cols.forEach(col => { %>
            <td class="py-2 px-1 text-center font-bold text-slate-700"><%= col.total %>h</td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>

  <%# ── Alertas Detalladas (colapsable) ──────────────────────────────────────── %>
  <%
    const _catLabels = {
      sin_estimacion:     'Sin estimación',
      horas_inhabituales: 'H. inhabituales',
      descripcion_mecanica:'Desc. mecánica',
      tarea_sin_proyecto: 'Sin proyecto',
      fin_de_semana:      'Fin de semana',
      horas_bajas:        'Horas bajas',
      horas_altas:        'Horas altas',
      sin_actividad:      'Sin actividad',
      descripcion_vacia:  'Desc. vacía',
      pre_logeo:          'Pre-logeo',
      carga_tardia:       'Carga tardía',
    };
    const _consultantMap = {};
    (consultants || []).forEach(c => { _consultantMap[c.login] = c.name; });
    const _totalAlerts = criticalCount + warningCount + infoCount;
  %>
  <section class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <details>
      <summary class="flex items-center justify-between px-6 py-4 hover:bg-slate-50/80 transition-colors select-none cursor-pointer">
        <div class="flex items-center gap-4">
          <div>
            <h3 class="text-base font-bold text-slate-900">Alertas Detalladas</h3>
            <p class="text-xs text-slate-400 mt-0.5"><%= _totalAlerts %> eventos en el período · haga clic para expandir</p>
          </div>
          <div class="flex gap-2">
            <% if (criticalCount > 0) { %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-red-50 text-red-600 border border-red-200 ring-1 ring-red-100">
              <span class="w-1.5 h-1.5 rounded-full bg-red-500 inline-block animate-pulse"></span>
              <%= criticalCount %> críticas
            </span>
            <% } else { %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-slate-50 text-slate-400 border border-slate-200">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-300 inline-block"></span>
              0 críticas
            </span>
            <% } %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-50 text-amber-600 border border-amber-200">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
              <%= warningCount %> warnings
            </span>
            <% if (infoCount > 0) { %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-blue-50 text-blue-600 border border-blue-200">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
              <%= infoCount %> info
            </span>
            <% } %>
          </div>
        </div>
        <svg class="chevron w-4 h-4 text-slate-400 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="border-t border-slate-100">
        <%# Filter tabs %>
        <div class="flex items-center gap-1 px-6 py-3 bg-slate-50/60 border-b border-slate-100" id="alertFilters">
          <button class="alert-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-white transition-all" data-filter="all">
            Todas (<%= _totalAlerts %>)
          </button>
          <button class="alert-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-500 hover:bg-slate-200 transition-all" data-filter="critical">
            <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-500 inline-block"></span>Críticas (<%= criticalCount %>)</span>
          </button>
          <button class="alert-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-500 hover:bg-slate-200 transition-all" data-filter="warning">
            <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-amber-400 inline-block"></span>Warnings (<%= warningCount %>)</span>
          </button>
          <button class="alert-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-500 hover:bg-slate-200 transition-all" data-filter="info">
            <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>Info (<%= infoCount %>)</span>
          </button>
          <div class="ml-auto text-xs text-slate-400 italic">
            Nota: "warnings" incluye tareas sin estimación de horas (normal si hay muchas tareas abiertas)
          </div>
        </div>
        <%# Table %>
        <div class="overflow-x-auto" style="max-height:380px;overflow-y:auto">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-white border-b border-slate-200 z-10 shadow-sm">
              <tr>
                <th class="py-2.5 px-1 w-1"></th>
                <th class="text-left py-2.5 px-3 font-semibold text-slate-400 uppercase tracking-wide text-[10px] w-28">Consultor</th>
                <th class="text-left py-2.5 px-3 font-semibold text-slate-400 uppercase tracking-wide text-[10px]">Evento</th>
                <th class="text-left py-2.5 px-3 font-semibold text-slate-400 uppercase tracking-wide text-[10px] w-36">Tipo</th>
                <th class="text-left py-2.5 px-3 font-semibold text-slate-400 uppercase tracking-wide text-[10px]">Detalle</th>
                <th class="w-10"></th>
              </tr>
            </thead>
            <tbody id="alertsTableBody">
              <% anomalies.forEach((a, i) => { %>
              <%
                const _isCrit = a.type === 'critical';
                const _isInfo = a.type === 'info';
                const _accent = _isCrit ? '#EF4444' : _isInfo ? '#60A5FA' : '#F59E0B';
                const _rowHover = _isCrit ? 'hover:bg-red-50/40' : _isInfo ? 'hover:bg-blue-50/30' : 'hover:bg-amber-50/30';
                const _dotCls  = _isCrit ? 'bg-red-500' : _isInfo ? 'bg-blue-400' : 'bg-amber-400';
                const _catLbl  = _catLabels[a.category] || a.category.replace(/_/g,' ');
                const _catCls  = _isCrit
                  ? 'bg-red-50 text-red-600 border border-red-100'
                  : _isInfo
                    ? 'bg-blue-50 text-blue-600 border border-blue-100'
                    : 'bg-amber-50 text-amber-600 border border-amber-100';
                const _person = _consultantMap[a.user] || (a.user||'').split('@')[0];
              %>
              <tr class="alert-row border-b border-slate-50 <%= _rowHover %> transition-colors"
                  data-type="<%= a.type %>">
                <td class="py-0 px-0">
                  <div class="h-full w-[3px] rounded-r" style="background:<%= _accent %>;min-height:36px;"></div>
                </td>
                <td class="py-2.5 px-3">
                  <span class="font-semibold text-slate-700"><%= _person %></span>
                </td>
                <td class="py-2.5 px-3 text-slate-700 font-medium"><%= a.message %></td>
                <td class="py-2.5 px-3">
                  <span class="inline-flex px-2 py-0.5 rounded-md text-[11px] font-semibold <%= _catCls %>"><%= _catLbl %></span>
                </td>
                <td class="py-2.5 px-3 text-slate-500 max-w-xs truncate" title="<%= a.detail %>"><%= a.detail %></td>
                <td class="py-2.5 pr-4 text-right">
                  <% if (a.taskId) { %>
                  <a href="https://www.torus.dev/web#id=<%= a.taskId %>&model=project.task" target="_blank" rel="noopener"
                     class="inline-flex items-center justify-center w-6 h-6 rounded-md bg-slate-100 text-slate-400 hover:bg-blue-100 hover:text-blue-600 transition-colors" title="Ver tarea en Odoo">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% if (!anomalies.length) { %>
              <tr><td colspan="6" class="py-12 text-center">
                <div class="flex flex-col items-center gap-2">
                  <svg class="w-10 h-10 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span class="text-sm text-slate-400 font-medium">Sin anomalías detectadas</span>
                </div>
              </td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </details>
  </section>

  <%# ── Disciplina de Logeo ────────────────────────────────────────────────────── %>
  <section class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3 mb-5">
      <div>
        <h3 class="font-bold text-slate-900 text-lg">Disciplina de Logeo</h3>
        <p class="text-sm text-slate-500">Últimos <span><%= lco.complianceDays || 0 %></span> días hábiles · Referencia: <span><%= lco.latestBusinessLabel || '-' %></span></p>
        <div class="flex flex-wrap items-center gap-3 mt-2">
          <span class="text-[10px] text-slate-400 font-semibold uppercase tracking-wide">Leyenda días:</span>
          <span class="inline-flex items-center gap-1.5 text-[11px] text-slate-500">
            <span class="text-[10px] bg-violet-100 text-violet-600 font-bold px-1.5 py-0.5 rounded leading-tight">🏖</span>
            Licencia aprobada (excluida del control)
          </span>
          <span class="inline-flex items-center gap-1.5 text-[11px] text-slate-500">
            <span class="text-[10px] bg-amber-100 text-amber-700 font-bold px-1.5 py-0.5 rounded leading-tight">T</span>
            Carga tardía (registrada 2+ días después)
          </span>
          <span class="inline-flex items-center gap-1.5 text-[11px] text-slate-500">
            <span class="text-[10px] bg-purple-100 text-purple-600 font-bold px-1.5 py-0.5 rounded leading-tight">P</span>
            Pre-logeo (registrada antes de la fecha de trabajo)
          </span>
        </div>
      </div>
      <div class="grid grid-cols-4 gap-2 text-center">
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
          <div class="text-xs font-semibold text-slate-500 uppercase mb-0.5">Compliance</div>
          <div class="text-xl font-black text-slate-900"><%= lco.compliancePct || 0 %>%</div>
        </div>
        <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2">
          <div class="text-xs font-semibold text-red-600 uppercase mb-0.5">Sin log hoy</div>
          <div class="text-xl font-black text-red-600"><%= lco.missingLatestBusinessDayCount || 0 %></div>
        </div>
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
          <div class="text-xs font-semibold text-amber-700 uppercase mb-0.5">Sin semana</div>
          <div class="text-xl font-black text-amber-600"><%= lco.noLogThisWeekCount || 0 %></div>
        </div>
        <div class="rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2">
          <div class="text-xs font-semibold text-indigo-700 uppercase mb-0.5">Sospechosos</div>
          <div class="text-xl font-black text-indigo-700"><%= lco.suspiciousCount || 0 %></div>
        </div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-slate-100 align-bottom">
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Persona</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Compliance</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Semana</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Calidad</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Últimos días hábiles</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-600 text-xs">Estado</th>
          </tr>
          <tr class="border-b border-slate-100 text-[11px] text-slate-400">
            <th></th><th></th><th></th><th></th>
            <th class="py-2 px-3">
              <div class="flex gap-1">
                <% lc.displayDates.forEach((day) => { %>
                <span class="log-day text-center"><%= day.label %></span>
                <% }) %>
              </div>
            </th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% lc.people.forEach((person) => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-3 px-3 align-top">
              <div class="font-semibold text-slate-900 text-xs"><%= person.name %></div>
              <div class="text-xs text-slate-400 mt-0.5"><%= person.job || 'Sin rol' %></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-black <%= person.compliancePct>=85?'text-green-600':person.compliancePct>=65?'text-amber-600':'text-red-600' %>"><%= person.compliancePct %>%</div>
              <div class="text-xs text-slate-400"><%= person.loggedDays %>/<%= person.expectedDays %> días</div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="text-sm font-bold text-slate-900"><%= person.hoursThisWeek %>h</div>
              <div class="text-xs text-slate-400"><%= person.entriesThisWeek %> cargas</div>
            </td>
            <td class="py-3 px-3 align-top text-xs text-slate-500 space-y-0.5">
              <div>Desc. cortas <span class="font-semibold text-slate-700"><%= person.quality.shortDescPct %>%</span></div>
              <div>Tardías <span class="font-semibold text-slate-700"><%= person.quality.latePct %>%</span></div>
              <div>Pre-logeo <span class="font-semibold <%= person.quality.preLogPct > 10 ? 'text-red-600' : 'text-slate-700' %>"><%= person.quality.preLogPct %>%</span></div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="flex gap-1">
                <% person.recentDays.forEach((day) => { %>
                <button onclick="openLogDayModal('<%= person.login %>','<%= day.date %>','<%= person.name.replace(/'/g,"\\'") %>','<%= day.label %>')"
                  class="log-day rounded-md border px-1.5 py-1 text-center text-[11px] font-semibold cursor-pointer hover:ring-2 hover:ring-blue-300 transition-all
                  <%=
                    day.isLeave  ? 'bg-violet-50 border-violet-200 text-violet-600' :
                    day.isMissing ? 'bg-red-50 border-red-200 text-red-600' :
                    day.hours>=8  ? 'bg-indigo-50 border-indigo-200 text-indigo-700' :
                    day.hours>=4  ? 'bg-blue-50 border-blue-200 text-blue-700' :
                                    'bg-amber-50 border-amber-200 text-amber-700'
                  %>"
                  title="<%= day.isLeave ? `${day.label}: Licencia aprobada` : `${day.label}: ${day.hours}h · clic para ver detalles` %>">
                  <div><%= day.isLeave ? '🏖' : day.hours > 0 ? `${day.hours}h` : '0' %></div>
                  <div class="text-[10px] <%= day.isLeave ? 'text-violet-400' : day.lateEntries ? 'text-amber-500' : day.preLogEntries ? 'text-purple-500' : 'text-slate-300' %>"><%= day.isLeave ? '·' : day.lateEntries ? 'T' : day.preLogEntries ? 'P' : '·' %></div>
                </button>
                <% }) %>
              </div>
            </td>
            <td class="py-3 px-3 align-top">
              <div class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold
                <%=
                  person.status==='critical' ? 'bg-red-100 text-red-700' :
                  person.status==='warning'  ? 'bg-amber-100 text-amber-700' :
                  person.status==='leave'    ? 'bg-violet-100 text-violet-700' :
                                               'bg-green-100 text-green-700'
                %>">
                <%=
                  person.status==='critical' ? 'Crítico' :
                  person.status==='warning'  ? 'Warning' :
                  person.status==='leave'    ? '🏖 Licencia' :
                                               'Sano'
                %> · <%= person.suspiciousScore %>
              </div>
              <% if (person.flags.length) { %>
              <div class="mt-1.5 space-y-0.5">
                <% person.flags.forEach(flag => { %><div class="text-xs text-slate-500">- <%= flag %></div><% }) %>
              </div>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!lc.people.length) { %>
          <tr><td colspan="6" class="py-10 text-center text-slate-400">No hay datos de logeo para el período seleccionado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>


</div><!-- /tab-equipo -->

<%# ── Proyectos Tab ──────────────────────────────────────────────────────────── %>
<div id="tab-proyectos" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%# View toggle %>
  <div class="flex items-center gap-2">
    <button id="view-btn-cards" onclick="setProyectosView('cards')"
      class="px-3 py-1.5 rounded-lg border text-xs font-semibold bg-blue-600 text-white border-blue-600 transition-colors">
      ▦ Tarjetas
    </button>
    <button id="view-btn-gantt" onclick="setProyectosView('gantt')"
      class="px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 hover:border-blue-300 hover:bg-blue-50 transition-colors">
      ▤ Gantt
    </button>
    <span class="text-xs text-slate-400 ml-2"><%= projectStatuses.length %> proyectos</span>
  </div>

  <%# Project cards grid %>
  <div id="proj-cards-view" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    <% projectStatuses.forEach(p => {
      const pctColor   = p.hoursPct && p.hoursPct > 120 ? 'red' : p.hoursPct && p.hoursPct > 90 ? 'amber' : 'green';
      const statusBadge = p.isCompleted ? { label: 'Completado', cls: 'bg-green-100 text-green-700' }
                        : p.needsAttention ? { label: 'Requiere atención', cls: 'bg-red-100 text-red-700' }
                        : p.isOnHold      ? { label: 'En pausa', cls: 'bg-slate-100 text-slate-500' }
                        : { label: 'En curso', cls: 'bg-blue-100 text-blue-700' };
      const borderColor = p.needsAttention ? 'border-red-200' : p.isCompleted ? 'border-green-200' : 'border-slate-200';
    %>
    <div class="bg-white rounded-xl border-2 <%= borderColor %> p-5 hover:shadow-md transition-shadow">
      <%# Header %>
      <div class="flex items-start justify-between gap-2 mb-3">
        <div class="flex-1 min-w-0">
          <div class="font-bold text-slate-900 text-sm leading-snug" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;" title="<%= p.fullName || p.name %>">
            <%= p.fullName || p.name %>
          </div>
          <div class="flex flex-wrap items-center gap-1.5 mt-1.5">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusBadge.cls %>"><%= statusBadge.label %></span>
            <% if (p.backlogTasks > 0) { %><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-purple-100 text-purple-700"><%= p.backlogTasks %> backlog</span><% } %>
            <% if (p.responsible) { %><span class="inline-flex items-center gap-1 text-[10px] text-slate-400"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><%= p.responsible %></span><% } %>
          </div>
        </div>
        <a href="https://www.torus.dev/web#id=<%= p.id %>&model=project.project" target="_blank" rel="noopener"
           class="flex-shrink-0 inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-slate-50 text-slate-400 hover:bg-blue-50 hover:text-blue-600 border border-slate-200 transition-colors" title="Ver en Odoo">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Odoo
        </a>
      </div>

      <%# Stage progress %>
      <div class="mb-3">
        <div class="flex justify-between text-xs mb-1">
          <span class="text-slate-500 font-medium">Avance</span>
          <span class="font-bold text-slate-700"><%= p.stageProgress %>%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-2">
          <div class="h-2 rounded-full transition-all <%= p.stageProgress >= 80 ? 'bg-green-500' : p.stageProgress >= 50 ? 'bg-blue-400' : 'bg-slate-300' %>"
               style="width:<%= p.stageProgress %>%"></div>
        </div>
      </div>

      <%# Hours gauge %>
      <% if (!p.isInternal) { %>
      <div class="mb-3">
        <div class="flex justify-between text-xs mb-1">
          <span class="text-slate-500 font-medium">Horas consumidas</span>
          <span class="font-bold <%= pctColor === 'red' ? 'text-red-600' : pctColor === 'amber' ? 'text-amber-600' : 'text-green-600' %>">
            <%= p.totalLog %>h<% if (p.hoursPct) { %> · <%= p.hoursPct %>%<% } %>
          </span>
        </div>
        <% if (p.totalAlloc > 0) { %>
        <div class="w-full bg-slate-100 rounded-full h-2">
          <div class="h-2 rounded-full transition-all <%= pctColor === 'red' ? 'bg-red-500' : pctColor === 'amber' ? 'bg-amber-400' : 'bg-green-500' %>"
               style="width:<%= Math.min(p.hoursPct || 0, 100) %>%"></div>
        </div>
        <div class="text-xs text-slate-400 mt-1">Presupuesto: <%= p.totalAlloc %>h</div>
        <% } else { %>
        <div class="text-xs text-slate-400">Sin estimación de tareas · <%= p.totalLog %>h registradas</div>
        <% } %>
      </div>
      <% } else { %>
      <div class="mb-3">
        <span class="text-xs text-slate-400">Actividades internas · <%= p.totalLog %>h registradas</span>
      </div>
      <% } %>

      <%# Stats row %>
      <div class="grid grid-cols-3 gap-2 text-center border-t border-slate-100 pt-3">
        <div>
          <div class="text-sm font-black text-slate-900"><%= p.openTasks %></div>
          <div class="text-[10px] text-slate-400 uppercase font-medium">Abiertas</div>
        </div>
        <div>
          <div class="text-sm font-black text-green-600"><%= p.doneTasks %></div>
          <div class="text-[10px] text-slate-400 uppercase font-medium">Hechas</div>
        </div>
        <div>
          <div class="text-sm font-black <%= p.daysSinceUpdate > 14 ? 'text-red-600' : p.daysSinceUpdate > 7 ? 'text-amber-600' : 'text-green-600' %>">
            <%= p.daysSinceUpdate > 99 ? '—' : p.daysSinceUpdate + 'd' %>
          </div>
          <div class="text-[10px] text-slate-400 uppercase font-medium">Sin actualizar</div>
        </div>
      </div>

      <%# Assignees %>
      <% if (p.assignees && p.assignees.length > 0) { %>
      <div class="mt-3 pt-2 border-t border-slate-100">
        <div class="flex flex-wrap gap-1">
          <% p.assignees.forEach(assignee => { %>
          <span class="text-[10px] px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 font-medium"><%= assignee %></span>
          <% }) %>
        </div>
      </div>
      <% } %>

      <%# Attention flags %>
      <% if (p.needsAttention || p.needsUpdate) { %>
      <div class="mt-2 space-y-1">
        <% if (p.needsAttention) { %><div class="text-xs text-red-600 flex items-center gap-1"><span>⚠</span> Horas al <%= p.hoursPct %>% del presupuesto</div><% } %>
        <% if (p.needsUpdate)    { %><div class="text-xs text-amber-600 flex items-center gap-1"><span>🕐</span> Sin actividad hace <%= p.daysSinceUpdate %> días</div><% } %>
      </div>
      <% } %>
    </div>
    <% }) %>
    <% if (!projectStatuses.length) { %>
    <div class="col-span-full py-16 text-center text-slate-400">
      No hay proyectos que coincidan con los filtros seleccionados.
    </div>
    <% } %>
  </div>

  <%# Gantt view %>
  <div id="gantt-view" class="hidden">
    <div id="gantt-container" class="space-y-3">
      <div class="py-16 text-center text-slate-400 text-sm">Cambiá a vista Gantt para ver el cronograma.</div>
    </div>
  </div>

</div><!-- /tab-proyectos -->

<%# ── Capacidad Tab ──────────────────────────────────────────────────────────── %>
<div id="tab-capacidad" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%
    const capData = capacityData || [];
    const capOverloaded = capData.filter(c => c.status === 'overloaded').length;
    const capBusy       = capData.filter(c => c.status === 'busy').length;
    const capAvailable  = capData.filter(c => c.status === 'available').length;
    const capFree       = capData.filter(c => c.status === 'free').length;
    const totalAllocH   = capData.reduce((s, c) => s + (c.allocated || 0), 0);
    const totalAvailH   = capData.length > 0 ? (capData[0].hoursAvailable * capData.length) : 0;
    const teamUtilPct   = totalAvailH > 0 ? Math.round(totalAllocH / totalAvailH * 100) : 0;
  %>

  <%# KPI bar %>
  <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3">
    <div class="bg-white rounded-xl border border-slate-200 p-4 col-span-2">
      <div class="text-xs text-slate-500 mb-1">Utilización del equipo</div>
      <div class="flex items-end gap-2 mb-2">
        <div class="text-3xl font-black <%= teamUtilPct >= 90 ? 'text-red-600' : teamUtilPct >= 70 ? 'text-amber-500' : 'text-emerald-600' %>"><%= teamUtilPct %>%</div>
        <div class="text-xs text-slate-400 mb-1"><%= totalAllocH.toFixed(0) %>h asignadas / <%= totalAvailH.toFixed(0) %>h disponibles</div>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-2">
        <div class="h-2 rounded-full transition-all <%= teamUtilPct >= 90 ? 'bg-red-500' : teamUtilPct >= 70 ? 'bg-amber-400' : 'bg-emerald-500' %>"
             style="width:<%= Math.min(teamUtilPct, 100) %>%"></div>
      </div>
    </div>
    <div class="bg-red-50 rounded-xl border border-red-100 p-4 text-center">
      <div class="text-2xl font-black text-red-600"><%= capOverloaded %></div>
      <div class="text-xs text-red-500 font-semibold mt-1">Sobrecargados</div>
      <div class="text-[10px] text-slate-400 mt-0.5">&ge;100% utilización</div>
    </div>
    <div class="bg-amber-50 rounded-xl border border-amber-100 p-4 text-center">
      <div class="text-2xl font-black text-amber-600"><%= capBusy %></div>
      <div class="text-xs text-amber-500 font-semibold mt-1">Ocupados</div>
      <div class="text-[10px] text-slate-400 mt-0.5">70–99% utilización</div>
    </div>
    <div class="bg-blue-50 rounded-xl border border-blue-100 p-4 text-center">
      <div class="text-2xl font-black text-blue-600"><%= capAvailable %></div>
      <div class="text-xs text-blue-500 font-semibold mt-1">Disponibles</div>
      <div class="text-[10px] text-slate-400 mt-0.5">30–69% utilización</div>
    </div>
    <div class="bg-emerald-50 rounded-xl border border-emerald-100 p-4 text-center">
      <div class="text-2xl font-black text-emerald-600"><%= capFree %></div>
      <div class="text-xs text-emerald-500 font-semibold mt-1">Libres</div>
      <div class="text-[10px] text-slate-400 mt-0.5">&lt;30% utilización</div>
    </div>
  </div>

  <%# Capacity chart %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="text-sm font-bold text-slate-700 mb-4">Carga por consultor — horas restantes este mes</div>
    <div style="height:240px"><canvas id="chartCapacity"></canvas></div>
  </div>

  <%# Capacity table %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
      <span class="text-sm font-bold text-slate-700">Detalle por consultor</span>
      <span class="text-xs text-slate-400">Horas asignadas en tareas abiertas vs. días hábiles restantes</span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="bg-slate-50 text-slate-500">
            <th class="text-left px-4 py-2 font-semibold">Consultor</th>
            <th class="text-right px-4 py-2 font-semibold">Asignadas</th>
            <th class="text-right px-4 py-2 font-semibold">Disponibles</th>
            <th class="text-right px-4 py-2 font-semibold">Utilización</th>
            <th class="px-4 py-2 font-semibold">Barra</th>
            <th class="text-center px-4 py-2 font-semibold">Estado</th>
          </tr>
        </thead>
        <tbody>
          <% capData.forEach(c => {
            const statusMap = {
              overloaded: { label: 'Sobrecargado', cls: 'bg-red-100 text-red-700' },
              busy:       { label: 'Ocupado',       cls: 'bg-amber-100 text-amber-700' },
              available:  { label: 'Disponible',    cls: 'bg-blue-100 text-blue-700' },
              free:       { label: 'Libre',          cls: 'bg-emerald-100 text-emerald-700' },
            };
            const sb = statusMap[c.status] || statusMap.free;
            const barColor = c.status === 'overloaded' ? 'bg-red-500'
                           : c.status === 'busy'       ? 'bg-amber-400'
                           : c.status === 'available'  ? 'bg-blue-400' : 'bg-emerald-400';
          %>
          <tr class="border-t border-slate-50 hover:bg-slate-50 transition-colors">
            <td class="px-4 py-2.5 font-semibold text-slate-900"><%= c.name %></td>
            <td class="px-4 py-2.5 text-right font-bold text-slate-800"><%= (c.allocated || 0).toFixed(1) %>h</td>
            <td class="px-4 py-2.5 text-right text-slate-500"><%= (c.hoursAvailable || 0).toFixed(0) %>h</td>
            <td class="px-4 py-2.5 text-right font-bold <%= c.utilPct >= 100 ? 'text-red-600' : c.utilPct >= 70 ? 'text-amber-600' : 'text-emerald-600' %>"><%= c.utilPct %>%</td>
            <td class="px-4 py-2.5 w-36">
              <div class="w-full bg-slate-100 rounded-full h-2">
                <div class="h-2 rounded-full transition-all <%= barColor %>" style="width:<%= Math.min(c.utilPct, 100) %>%"></div>
              </div>
            </td>
            <td class="px-4 py-2.5 text-center">
              <span class="px-2 py-0.5 rounded-full text-[10px] font-bold <%= sb.cls %>"><%= sb.label %></span>
            </td>
          </tr>
          <% }) %>
          <% if (!capData.length) { %>
          <tr><td colspan="6" class="px-4 py-8 text-center text-slate-400">Sin datos de capacidad disponibles.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /tab-capacidad -->

<%# ── Sprints Tab ──────────────────────────────────────────────────────────── %>
<div id="tab-sprints" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <%# ── Scrum Teams ──────────────────────────────────────────────────────── %>
