<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .tab-btn { border-bottom: 3px solid transparent; transition: all .15s; }
    .tab-btn.active { border-bottom-color: #2563EB; color: #2563EB; font-weight: 700; }
    .aging-bar { transition: width .4s ease; }
    .kpi-delta-up   { color: #10b981; }
    .kpi-delta-down { color: #ef4444; }
    details > summary::-webkit-details-marker { display:none; }
    details[open] .chevron { transform: rotate(180deg); }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

<!-- ── Loading overlay (shown while navigating to a new filter) ─────────── -->
<div id="finLoadingOverlay" class="hidden fixed inset-0 z-[9999] bg-white/70 backdrop-blur-sm flex flex-col items-center justify-center gap-3 transition-opacity">
  <div class="w-10 h-10 border-4 border-blue-100 border-t-blue-600 rounded-full animate-spin"></div>
  <span class="text-sm font-semibold text-slate-600 tracking-wide">Cargando datos…</span>
</div>

<%
  // Plain text formatters (for title attrs, insights text, chart tooltips)
  const gs  = n => 'Gs.\u00A0' + new Intl.NumberFormat('es-PY', { maximumFractionDigits: 0 }).format(Math.abs(n || 0));
  const gsM = n => {
    const abs = Math.abs(n || 0);
    if (abs >= 1e9) return (abs/1e9).toFixed(1) + ' B';
    if (abs >= 1e6) return (abs/1e6).toFixed(1) + ' M';
    if (abs >= 1e3) return Math.round(abs/1e3) + ' K';
    return String(Math.round(abs));
  };
  // HTML span wrappers — JS toggle reads data-pyg and converts to USD on the fly
  const amt  = n => `<span class="c-amt" data-pyg="${Math.round(n||0)}">Gs.\u00A0${gsM(Math.round(n||0))}</span>`;
  const amtG = n => `<span class="c-amt" data-pyg="${Math.round(n||0)}">${gs(Math.round(n||0))}</span>`;
  const amtC = n => `<span class="c-amt c-amt-compact" data-pyg="${Math.round(n||0)}">${gsM(Math.round(n||0))}</span>`; // compact, no prefix
  const ingRows = fin.eerrRows.filter(r => r.totalRevenue > 0).sort((a,b) => b.totalRevenue - a.totalRevenue);
  const egRows  = fin.eerrRows.filter(r => r.totalRevenue === 0 && r.totalCost > 0).sort((a,b) => b.totalCost - a.totalCost);
  const totalIngRev  = ingRows.reduce((s,r) => s + r.totalRevenue, 0);
  const totalIngCost = ingRows.reduce((s,r) => s + r.totalCost,    0);
  const totalIngMgn  = totalIngRev - totalIngCost;
  const totalIngMgnPct = totalIngRev > 0 ? Math.round(totalIngMgn / totalIngRev * 100) : 0;
  const totalEgCost  = egRows.reduce((s,r) => s + r.totalCost, 0);
  const overdue = (cxc.buckets.d1_30||0) + (cxc.buckets.d31_60||0) + (cxc.buckets.d61_90||0) + (cxc.buckets.d90plus||0);

  // ── YoY deltas ─────────────────────────────────────────────────────────────
  const yoyRevDelta  = yoy.prevRevenue  > 0 ? Math.round((fin.totalRevenue  - yoy.prevRevenue)  / yoy.prevRevenue  * 100) : null;
  const yoyMgnDelta  = yoy.prevMargin   > 0 ? Math.round((totalIngMgn       - yoy.prevMargin)   / Math.abs(yoy.prevMargin) * 100) : null;
  const yoyClientDelta = yoy.prevClientCount > 0 ? clients.clientCount - yoy.prevClientCount : null;

  // ── Service line profitability (from ingRows filtered by [TAG] pattern) ────
  const svcLines  = ingRows.filter(r => /^\[/.test(r.name));
  const projRows  = ingRows.filter(r => /^S\d{4,5}\s*[-\u2013]/.test(r.name));
  const otherRows = ingRows.filter(r => !/^\[/.test(r.name) && !/^S\d{4,5}\s*[-\u2013]/.test(r.name));
  const totalSvcRev  = svcLines.reduce((s,r) => s + r.totalRevenue, 0);
  const totalProjRev = projRows.reduce((s,r) => s + r.totalRevenue, 0);

  // ── Cash flow projection (30/60/90 days) ──────────────────────────────────
  const cashInflow  = { d30: 0, d60: 0, d90: 0, total: cxc.total };
  const cashOutflow = { d30: 0, d60: 0, d90: 0, total: cxp.total };
  for (const inv of cxc.items) {
    if (inv.bucket === 'current' || inv.bucket === 'd1_30') cashInflow.d30 += inv.residual;
    if (inv.bucket === 'current' || inv.bucket === 'd1_30' || inv.bucket === 'd31_60') cashInflow.d60 += inv.residual;
    cashInflow.d90 += inv.residual;
  }
  for (const inv of cxp.items) {
    if (inv.bucket === 'current' || inv.bucket === 'd1_30') cashOutflow.d30 += inv.residual;
    if (inv.bucket === 'current' || inv.bucket === 'd1_30' || inv.bucket === 'd31_60') cashOutflow.d60 += inv.residual;
    cashOutflow.d90 += inv.residual;
  }

  // ── Auto-insights ─────────────────────────────────────────────────────────
  const insights = [];
  if (yoyRevDelta !== null) insights.push({ type: yoyRevDelta >= 0 ? 'good' : 'bad', text: `Ingresos ${yoyRevDelta >= 0 ? 'crecieron' : 'cayeron'} ${Math.abs(yoyRevDelta)}% vs ${year - 1}` });
  if (clients.clients.length > 0) {
    const top = clients.clients[0];
    insights.push({ type: 'info', text: `${top.name} es el cliente #1 con ${top.revPct}% de los ingresos totales` });
    if (clients.top3Pct > 70) insights.push({ type: 'warn', text: `Concentración alta: top 3 clientes = ${clients.top3Pct}% del revenue. Riesgo de dependencia.` });
  }
  if (overdue > cxc.total * 0.3) insights.push({ type: 'bad', text: `${Math.round(overdue/cxc.total*100)}% del CXC está vencido (${gsM(overdue)}). Gestión de cobros urgente.` });
  // CRM stale insight removed — check /crm dashboard for pipeline health
  if (totalIngMgnPct >= 50) insights.push({ type: 'good', text: `Margen de contribución saludable: ${totalIngMgnPct}%` });
  else if (totalIngMgnPct < 25) insights.push({ type: 'bad', text: `Margen de contribución bajo: ${totalIngMgnPct}%. Revisar estructura de costos.` });
  if (closingRate.rate !== null && closingRate.rate < 30) insights.push({ type: 'warn', text: `Tasa de cierre baja: ${closingRate.rate}% en últimos 90 días.` });

  // ── EERR grouping by account name pattern ──────────────────────────────────
  const _TYPE_LABELS = { AUG:'Augmentation', DEDICATED:'Dedicado', CDEV:'Dev a Medida', HOURLY:'Por Hora', WEB:'Web/eCommerce', INF:'Infraestructura', MAINT:'Mantenimiento', HUNTER:'Hunter', DISC:'Descubrimiento' };
  function _classifyAccount(name) {
    if (/^\[/.test(name)) return 'Líneas de Servicio';
    const m = name.match(/^S\d{4,5}\s*[-\u2013]\s*([A-Z]+)/);
    if (m) return 'Proyectos · ' + (_TYPE_LABELS[m[1]] || m[1]);
    return 'Otros / Clientes';
  }
  const _ingGroups = {};
  for (const row of ingRows) {
    const cat = _classifyAccount(row.name);
    if (!_ingGroups[cat]) _ingGroups[cat] = [];
    _ingGroups[cat].push(row);
  }
  const _egGroups = {};
  for (const row of egRows) {
    const cat = _classifyAccount(row.name);
    if (!_egGroups[cat]) _egGroups[cat] = [];
    _egGroups[cat].push(row);
  }

  // ── P&L completo ─────────────────────────────────────────────────────────
  const eerrResult = totalIngRev - totalIngCost - totalEgCost;
  const eerrResultPct = totalIngRev > 0 ? Math.round(eerrResult / totalIngRev * 100) : 0;

  // Period payroll to subtract (year-to-date from contracts)
  const nominaYTD = payroll.totalPayroll || 0;
  const netEstimado = eerrResult - nominaYTD;
  const netEstimadoPct = totalIngRev > 0 ? Math.round(netEstimado / totalIngRev * 100) : 0;

  // Month labels for cashflow projection
  const MONTH_LABELS = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

  // Next 3 months cashflow projection from payroll
  const _today3 = new Date();
  const nextMonthsPayroll = [];
  for (let i = 0; i < 3; i++) {
    const _d = new Date(_today3.getFullYear(), _today3.getMonth() + i, 1);
    const _ms = _d.getFullYear() + '-' + String(_d.getMonth()+1).padStart(2,'0');
    const _pm = (payroll.monthlyPayroll || []).find(m => m.month === _ms);
    nextMonthsPayroll.push({
      month: _ms,
      label: MONTH_LABELS[_d.getMonth()] + ' ' + String(_d.getFullYear()).slice(2),
      salary: _pm ? _pm.amount : (payroll.curPayroll || 0),
      count: _pm ? _pm.activeCount : payroll.contractCount,
    });
  }

  // Pipeline inflows: confirmed (sent) quotes as expected future cash
  const pipelineSent = pipeline.totalSent || 0;
  const pipelineDraft = pipeline.totalDraft || 0;
%>

<!-- ── Navbar ─────────────────────────────────────────────────────────────── -->
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <img src="/img/torus-icon-green.png" alt="Torus" class="h-8 w-auto">
      <span class="text-slate-300 text-sm">·</span>
      <a href="/"       class="text-sm font-semibold text-blue-600 hover:text-blue-800">Inicio</a>
      <span class="text-slate-300 text-sm">·</span>
      <a href="/equipo" class="text-sm font-semibold text-blue-600 hover:text-blue-800">Equipo</a>
      <span class="text-slate-300 text-sm">·</span>
      <span class="text-sm font-bold text-slate-900">Finanzas</span>
      <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <span class="text-slate-300 text-sm">·</span>
      <a href="/admin/users" class="text-sm font-medium text-slate-500 hover:text-slate-700">Usuarios</a>
      <% } %>
    </div>
    <div class="flex items-center gap-3">
      <!-- Date range picker -->
      <%
        const _curY = new Date().getFullYear();
        const _af   = activeFilters || {};
        // Build label for the active filter button
        const _filterLabel = _af.period
          ? ({ q1:'Q1 Ene–Mar', q2:'Q2 Abr–Jun', q3:'Q3 Jul–Sep', q4:'Q4 Oct–Dic' }[_af.period] || _af.period) + ' ' + _af.year
          : (_af.from && _af.to) ? _af.from.slice(0,7) + ' — ' + _af.to.slice(0,7)
          : 'Año ' + (_af.year || year);
      %>
      <div class="relative" id="finDatePicker">
        <button onclick="toggleFinPicker()"
          class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-300 bg-white text-xs font-semibold text-slate-700 hover:border-blue-400 hover:bg-blue-50 transition-colors shadow-sm">
          <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <%= _filterLabel %>
          <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <!-- Dropdown panel -->
        <div id="finPickerPanel" class="hidden absolute right-0 top-10 z-50 bg-white border border-slate-200 rounded-xl shadow-xl p-4 w-72">
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Año completo</div>
          <div class="flex flex-wrap gap-1.5 mb-3">
            <% for (let y = 2024; y <= _curY; y++) { %>
            <a href="/finanzas?year=<%= y %>"
               class="px-3 py-1 rounded-lg border text-xs font-bold transition-colors
               <%= (!_af.period && !_af.from && (_af.year||year) === y) ? 'bg-blue-600 text-white border-blue-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-600' %>">
              <%= y %>
            </a>
            <% } %>
          </div>
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Trimestre (<%= _curY %>)</div>
          <div class="grid grid-cols-2 gap-1.5 mb-3">
            <% ['q1','q2','q3','q4'].forEach(function(q) {
              const qLabels = { q1:'Q1  Ene–Mar', q2:'Q2  Abr–Jun', q3:'Q3  Jul–Sep', q4:'Q4  Oct–Dic' };
              const isActive = _af.period === q && (_af.year||year) === _curY;
            %>
            <a href="/finanzas?year=<%= _curY %>&period=<%= q %>"
               class="px-2 py-1.5 rounded-lg border text-xs font-semibold text-center transition-colors
               <%= isActive ? 'bg-blue-600 text-white border-blue-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-600' %>">
              <%= qLabels[q] %>
            </a>
            <% }) %>
          </div>
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Ventana móvil</div>
          <div class="flex flex-wrap gap-1.5 mb-3" id="rollingPresets"></div>
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Rango personalizado</div>
          <form method="GET" action="/finanzas" class="flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <input type="date" name="from" id="pickerFrom" value="<%= _af.from || '' %>"
                class="flex-1 text-xs border border-slate-200 rounded-lg px-2 py-1.5 text-slate-700 focus:outline-none focus:border-blue-400">
              <span class="text-slate-400 text-xs">—</span>
              <input type="date" name="to" id="pickerTo" value="<%= _af.to || '' %>"
                class="flex-1 text-xs border border-slate-200 rounded-lg px-2 py-1.5 text-slate-700 focus:outline-none focus:border-blue-400">
            </div>
            <button type="submit" class="w-full py-1.5 rounded-lg bg-blue-600 text-white text-xs font-bold hover:bg-blue-700 transition-colors">
              Aplicar
            </button>
          </form>
        </div>
      </div>
      <!-- Currency toggle -->
      <div class="flex items-center gap-0.5 rounded-lg border border-slate-200 p-0.5 bg-slate-50">
        <button id="cur-btn-pyg" onclick="switchCurrency('pyg')"
                class="px-2.5 py-1 rounded-md text-[11px] font-bold transition-all bg-white text-slate-700 shadow-sm border border-slate-200">
          Gs.
        </button>
        <button id="cur-btn-usd" onclick="switchCurrency('usd')"
                class="px-2.5 py-1 rounded-md text-[11px] font-bold transition-all text-slate-400 hover:text-slate-600">
          USD
        </button>
      </div>
      <div class="flex items-center gap-1.5 text-xs text-slate-400 border-l border-slate-200 pl-3">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span><%= lastUpdate %></span>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="flex items-center gap-2 border-l border-slate-200 pl-3">
        <% if (user.picture) { %>
        <img src="<%= user.picture %>" class="w-7 h-7 rounded-full border border-slate-200" alt="">
        <% } else { %>
        <div class="w-7 h-7 bg-green-200 rounded-full flex items-center justify-center text-xs font-bold text-green-800">
          <%= (user.name||user.email).slice(0,1).toUpperCase() %>
        </div>
        <% } %>
        <span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span>
        <form action="/auth/logout" method="POST" class="inline">
          <button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Salir</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</nav>

<!-- ── KPI Cards (always visible) ────────────────────────────────────────── -->
<div class="bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-9 gap-3">

      <!-- Ingresos YTD -->
      <div class="xl:col-span-1 bg-slate-50 rounded-xl border border-slate-200 p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Ingresos <%= year %></div>
        <div class="text-xl font-black text-slate-900"><%- amt(fin.totalRevenue) %></div>
        <% if (yoyRevDelta !== null) { %>
        <div class="text-[11px] mt-1 font-bold <%= yoyRevDelta >= 0 ? 'kpi-delta-up' : 'kpi-delta-down' %>">
          <%= yoyRevDelta >= 0 ? '▲' : '▼' %> <%= Math.abs(yoyRevDelta) %>% vs <%= year-1 %>
        </div>
        <% } else if (fin.curMonth.revDelta !== null) { %>
        <div class="text-[11px] mt-1 font-semibold <%= fin.curMonth.revDelta >= 0 ? 'kpi-delta-up' : 'kpi-delta-down' %>">
          <%= fin.curMonth.revDelta >= 0 ? '▲' : '▼' %> <%= Math.abs(fin.curMonth.revDelta) %>% vs mes ant.
        </div>
        <% } %>
      </div>

      <!-- Costos directos -->
      <div class="bg-slate-50 rounded-xl border border-slate-200 p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Costos Directos</div>
        <div class="text-xl font-black text-slate-900"><%- amt(totalIngCost) %></div>
        <div class="text-[11px] text-slate-400 mt-1"><%= totalIngRev > 0 ? Math.round(totalIngCost/totalIngRev*100) : 0 %>% de ingresos</div>
      </div>

      <!-- Margen de contribución -->
      <div class="bg-slate-50 rounded-xl border border-slate-200 p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Margen Contrib.</div>
        <div class="text-xl font-black <%= totalIngMgn >= 0 ? 'text-emerald-600' : 'text-red-500' %>">
          <%= totalIngMgnPct %>%
        </div>
        <div class="text-[11px] mt-1 font-semibold text-slate-500"><%- amt(totalIngMgn) %></div>
      </div>

      <!-- Resultado EERR (ingresos - todos los costos registrados) -->
      <div class="bg-slate-50 rounded-xl border-2 <%= eerrResult >= 0 ? 'border-emerald-400' : 'border-red-400' %> p-4 cursor-pointer hover:opacity-90" onclick="switchTab('eerr')">
        <div class="text-[10px] font-bold <%= eerrResult >= 0 ? 'text-emerald-600' : 'text-red-600' %> uppercase tracking-wide mb-1">Resultado EERR</div>
        <div class="text-xl font-black <%= eerrResult >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
          <%= eerrResultPct >= 0 ? '+' : '' %><%= eerrResultPct %>%
        </div>
        <div class="text-[11px] mt-1 font-semibold <%= eerrResult >= 0 ? 'text-emerald-700' : 'text-red-600' %>"><%- amt(eerrResult) %></div>
      </div>

      <!-- Egresos indirectos -->
      <div class="bg-slate-50 rounded-xl border border-slate-200 p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Egresos Indirectos</div>
        <div class="text-xl font-black text-red-500"><%- amt(totalEgCost) %></div>
        <div class="text-[11px] text-slate-400 mt-1"><%= egRows.length %> cuentas</div>
      </div>

      <!-- Clientes activos -->
      <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 cursor-pointer hover:bg-slate-100 transition"
           onclick="switchTab('clientes')">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Clientes</div>
        <div class="text-xl font-black text-slate-900"><%= clients.clientCount %></div>
        <% if (yoyClientDelta !== null) { %>
        <div class="text-[11px] mt-1 font-bold <%= yoyClientDelta >= 0 ? 'kpi-delta-up' : 'kpi-delta-down' %>">
          <%= yoyClientDelta >= 0 ? '+' : '' %><%= yoyClientDelta %> vs <%= year-1 %>
        </div>
        <% } else { %>
        <div class="text-[11px] text-slate-400 mt-1">activos en <%= year %></div>
        <% } %>
      </div>

      <!-- CXC -->
      <div class="bg-slate-50 rounded-xl border-2 border-amber-200 p-4 cursor-pointer hover:bg-amber-50 transition"
           onclick="switchTab('cxc')">
        <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">CXC — Por Cobrar</div>
        <div class="text-xl font-black text-amber-700"><%- amt(cxc.total) %></div>
        <div class="text-[11px] text-red-500 font-semibold mt-1"><%- amt(overdue) %> vencido</div>
      </div>

      <!-- CXP -->
      <div class="bg-slate-50 rounded-xl border-2 border-orange-200 p-4 cursor-pointer hover:bg-orange-50 transition"
           onclick="switchTab('cashflow')">
        <% const cxpOverdue = (cxp.buckets.d1_30||0)+(cxp.buckets.d31_60||0)+(cxp.buckets.d61_90||0)+(cxp.buckets.d90plus||0); %>
        <div class="text-[10px] font-bold text-orange-600 uppercase tracking-wide mb-1">CXP — Por Pagar</div>
        <div class="text-xl font-black text-orange-700"><%- amt(cxp.total) %></div>
        <div class="text-[11px] text-orange-500 font-semibold mt-1"><%= cxp.count %> facturas prov.</div>
      </div>

      <!-- Cotizaciones Pipeline -->
      <div class="bg-slate-50 rounded-xl border-2 border-blue-200 p-4 cursor-pointer hover:bg-blue-50 transition"
           onclick="switchTab('pipeline')">
        <div class="text-[10px] font-bold text-blue-600 uppercase tracking-wide mb-1">Cotizaciones</div>
        <div class="text-xl font-black text-blue-700"><%- amt(pipeline.total) %></div>
        <div class="text-[11px] text-blue-500 font-semibold mt-1"><%= pipeline.count %> cotiz. · <%= closingRate.rate !== null ? closingRate.rate + '% cierre' : '' %></div>
      </div>

    </div>
  </div>
</div>

<!-- ── Tab navigation ─────────────────────────────────────────────────────── -->
<div class="bg-white border-b border-slate-200 sticky top-[57px] z-40">
  <div class="max-w-7xl mx-auto px-4 overflow-x-auto">
    <div class="flex items-center gap-0 min-w-max">
      <button class="tab-btn active text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap" data-tab="resumen"   onclick="switchTab('resumen')">Resumen</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="clientes"  onclick="switchTab('clientes')">Clientes</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="productos" onclick="switchTab('productos')">Productos</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="eerr"      onclick="switchTab('eerr')">EERR</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="margenes"  onclick="switchTab('margenes')">Márgenes</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="cxc"       onclick="switchTab('cxc')">CXC</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="cashflow"  onclick="switchTab('cashflow')">Cash Flow</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap"        data-tab="pipeline"  onclick="switchTab('pipeline')">Pipeline</button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap flex items-center gap-1.5" data-tab="alertas" onclick="switchTab('alertas')">
        Alertas
        <% if (dqAlerts && dqAlerts.count > 0) { %>
        <span class="<%= dqAlerts.highCount > 0 ? 'bg-red-500' : 'bg-amber-400' %> text-white text-[10px] font-extrabold rounded-full px-1.5 py-0.5 leading-none"><%= dqAlerts.count %></span>
        <% } %>
      </button>
      <button class="tab-btn text-sm text-slate-600 px-5 py-3.5 whitespace-nowrap" data-tab="proyeccion" onclick="switchTab('proyeccion')">Proyección</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: RESUMEN
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-resumen" class="max-w-7xl mx-auto px-4 py-6 space-y-6">

  <!-- Auto-insights -->
  <% if (insights.length > 0) { %>
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">Insights automáticos</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
      <% insights.forEach(function(ins) {
        const cfg = {
          good: { bg: 'bg-emerald-50 border-emerald-200', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', ic: 'text-emerald-500', tx: 'text-emerald-800' },
          bad:  { bg: 'bg-red-50 border-red-200',         icon: 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z', ic: 'text-red-500', tx: 'text-red-800' },
          warn: { bg: 'bg-amber-50 border-amber-200',     icon: 'M12 9v2m0 4h.01m-6.938 4h13.876c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', ic: 'text-amber-500', tx: 'text-amber-800' },
          info: { bg: 'bg-blue-50 border-blue-200',       icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', ic: 'text-blue-500', tx: 'text-blue-800' },
        }[ins.type] || { bg:'bg-slate-50 border-slate-200', ic:'text-slate-400', tx:'text-slate-700', icon:'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' };
      %>
      <div class="flex items-start gap-2 rounded-lg border px-3 py-2 <%= cfg.bg %>">
        <svg class="w-4 h-4 mt-0.5 shrink-0 <%= cfg.ic %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= cfg.icon %>"/>
        </svg>
        <span class="text-xs font-medium <%= cfg.tx %>"><%= ins.text %></span>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- ── P&L cascade — ¿Ganamos? ───────────────────────────────────────────── -->
  <div class="bg-white rounded-xl border-2 <%= eerrResult >= 0 ? 'border-emerald-200' : 'border-red-200' %> p-5">
    <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
      <div>
        <h2 class="text-base font-bold text-slate-800">Estado de Resultados simplificado — <%= year %></h2>
        <p class="text-xs text-slate-400 mt-0.5">Ingresos y costos registrados en Odoo · nómina estimada desde contratos vigentes</p>
      </div>
      <div class="flex items-center gap-2 px-4 py-2 rounded-xl <%= netEstimado >= 0 ? 'bg-emerald-50 border border-emerald-200' : 'bg-red-50 border border-red-200' %>">
        <span class="text-xl"><%= netEstimado >= 0 ? '✅' : '🔴' %></span>
        <div>
          <div class="text-[11px] font-bold <%= netEstimado >= 0 ? 'text-emerald-700' : 'text-red-700' %> uppercase tracking-wide"><%= netEstimado >= 0 ? 'Resultado positivo' : 'Resultado negativo' %></div>
          <div class="text-lg font-black <%= netEstimado >= 0 ? 'text-emerald-700' : 'text-red-600' %>"><%- amt(netEstimado) %></div>
        </div>
      </div>
    </div>

    <!-- Waterfall rows -->
    <div class="space-y-1 text-sm max-w-2xl">
      <!-- Ingresos -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-100">
        <span class="font-semibold text-slate-700 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-emerald-500 inline-block"></span> Ingresos facturados
        </span>
        <span class="font-black text-emerald-700"><%- amt(totalIngRev) %></span>
      </div>
      <!-- Costos directos -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-100 pl-4">
        <span class="text-slate-600 flex items-center gap-2">
          <span class="text-red-400">−</span> Costos directos (atribuidos a proyectos)
        </span>
        <span class="font-semibold text-red-600"><%- amt(-totalIngCost) %></span>
      </div>
      <!-- Margen de contribución -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-200 bg-slate-50 px-3 rounded-lg">
        <span class="font-bold text-slate-800">= Margen de contribución</span>
        <span class="font-black <%= totalIngMgn >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
          <%- amt(totalIngMgn) %> <span class="text-xs font-semibold ml-1">(<%= totalIngMgnPct %>%)</span>
        </span>
      </div>
      <!-- Egresos indirectos -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-100 pl-4">
        <span class="text-slate-600 flex items-center gap-2">
          <span class="text-red-400">−</span> Egresos indirectos (gastos generales, proveedores)
        </span>
        <span class="font-semibold text-red-600"><%- amt(-totalEgCost) %></span>
      </div>
      <!-- Resultado EERR -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-200 bg-slate-50 px-3 rounded-lg">
        <span class="font-bold text-slate-800">= Resultado EERR (Odoo)</span>
        <span class="font-black <%= eerrResult >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
          <%- amt(eerrResult) %> <span class="text-xs font-semibold ml-1">(<%= eerrResultPct %>%)</span>
        </span>
      </div>
      <!-- Nómina comprometida -->
      <div class="flex items-center justify-between py-2.5 border-b border-slate-100 pl-4">
        <span class="text-slate-600 flex items-center gap-2">
          <span class="text-orange-400">−</span>
          Nómina estimada (<%= payroll.contractCount %> contratos vigentes)
          <span class="text-[10px] bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded font-bold">no en Odoo</span>
        </span>
        <span class="font-semibold text-orange-600"><%- amt(-nominaYTD) %></span>
      </div>
      <!-- Resultado final estimado -->
      <div class="flex items-center justify-between py-3 px-3 rounded-xl mt-1 <%= netEstimado >= 0 ? 'bg-emerald-50 border-2 border-emerald-300' : 'bg-red-50 border-2 border-red-300' %>">
        <span class="font-extrabold text-slate-900 text-base">= Resultado estimado</span>
        <div class="text-right">
          <div class="font-black text-xl <%= netEstimado >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
            <%- amt(netEstimado) %>
          </div>
          <div class="text-[11px] font-bold <%= netEstimado >= 0 ? 'text-emerald-600' : 'text-red-500' %>">
            <%= netEstimadoPct %>% del ingreso
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Monthly chart + Revenue donut side by side -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Monthly Ingresos vs Costos (2/3 width) -->
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-base font-bold text-slate-800">Ingresos vs Costos — <%= year %></h2>
          <p class="text-xs text-slate-400 mt-0.5">Por mes · eje derecho = margen %</p>
        </div>
        <div class="flex items-center gap-4 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-500 inline-block"></span>Ingresos</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-400 inline-block"></span>Costos</span>
          <span class="flex items-center gap-1.5"><span class="w-6 h-0.5 bg-blue-500 inline-block"></span>Margen %</span>
        </div>
      </div>
      <div style="height:260px"><canvas id="chartMonthly"></canvas></div>
    </div>

    <!-- Revenue breakdown donut (1/3 width) -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="mb-4">
        <h2 class="text-base font-bold text-slate-800">Mix de Ingresos</h2>
        <p class="text-xs text-slate-400 mt-0.5">Por cuenta analítica · YTD <%= year %></p>
      </div>
      <div style="height:200px"><canvas id="chartDonut"></canvas></div>
      <div id="donutLegend" class="mt-3 space-y-1 text-xs"></div>
    </div>
  </div>

  <!-- Margin heatmap by month (summary) -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-bold text-slate-800">Margen % mensual por cuenta</h2>
        <p class="text-xs text-slate-400 mt-0.5">Top <%= Math.min(ingRows.length, 8) %> cuentas por ingreso · verde = buen margen</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-slate-100">
            <th class="text-left py-2 px-3 font-semibold text-slate-500 w-48">Cuenta</th>
            <th class="text-right py-2 px-2 font-semibold text-slate-500 w-20">YTD %</th>
            <% fin.months.forEach(m => { %><th class="text-center py-2 px-1.5 font-semibold text-slate-400 w-12"><%= m.label %></th><% }) %>
          </tr>
        </thead>
        <tbody>
          <% ingRows.slice(0, 8).forEach(row => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="py-2 px-3 font-medium text-slate-700 truncate max-w-[192px]" title="<%= row.name %>"><%= row.name %></td>
            <td class="py-2 px-2 text-right">
              <span class="font-bold <%= row.marginPct >= 50 ? 'text-emerald-600' : row.marginPct >= 25 ? 'text-blue-500' : row.marginPct >= 0 ? 'text-amber-600' : 'text-red-500' %>">
                <%= row.marginPct %>%
              </span>
            </td>
            <% row.months.forEach(m => {
              const mp = (m.revenue > 0) ? Math.round((m.revenue - m.cost) / m.revenue * 100) : null;
            %>
            <td class="py-2 px-1.5 text-center">
              <% if (mp !== null) { %>
              <span class="inline-block px-1 py-0.5 rounded text-[10px] font-bold
                <%= mp >= 50 ? 'bg-emerald-100 text-emerald-700' : mp >= 25 ? 'bg-blue-100 text-blue-700' : mp >= 0 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-600' %>">
                <%= mp %>%
              </span>
              <% } else { %><span class="text-slate-200">—</span><% } %>
            </td>
            <% }) %>
          </tr>
          <% }) %>
          <% if (ingRows.length === 0) { %>
          <tr><td colspan="14" class="py-8 text-center text-slate-400">Sin datos de ingresos para <%= year %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /tab-resumen -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: EERR
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-eerr" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-4">

  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-xl font-extrabold text-slate-900">Estado de Resultados — Torus · <%= year %></h2>
      <p class="text-xs text-slate-400 mt-0.5">Basado en cuentas analíticas de Odoo · facturas de clientes (ingresos) y proveedores (costos)</p>
    </div>
    <div class="flex items-center gap-2 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      Nómina y estructura no incluidos (no están en Odoo)
    </div>
  </div>

  <!-- Cost structure breakdown -->
  <% const _cb = fin.costBreakdown || {}; %>
  <% if (_cb.total > 0) { %>
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-extrabold text-slate-700 uppercase tracking-wide">Estructura de Costos</span>
      <span class="text-xs text-slate-400">Total registrado en Odoo: <%- amt(_cb.total) %></span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- COGS -->
      <div class="flex items-start gap-3">
        <div class="mt-0.5 w-3 h-3 rounded-sm bg-red-500 shrink-0"></div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <span class="text-xs font-bold text-slate-700">Costo de Ventas <span class="font-normal text-slate-400">(COGS)</span></span>
            <span class="text-xs font-bold text-red-600 shrink-0"><%- amt(_cb.cogs) %></span>
          </div>
          <div class="w-full bg-slate-100 rounded-full h-2">
            <div class="bg-red-500 h-2 rounded-full" style="width:<%= _cb.cogsPct %>%"></div>
          </div>
          <p class="text-[10px] text-slate-400 mt-1"><%= _cb.cogsPct %>% del total · cuenta tipo <code>expense_direct_cost</code> · costos directos del servicio (subcontratos, licencias de proyecto, etc.)</p>
        </div>
      </div>
      <!-- Opex -->
      <div class="flex items-start gap-3">
        <div class="mt-0.5 w-3 h-3 rounded-sm bg-orange-400 shrink-0"></div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <span class="text-xs font-bold text-slate-700">Gastos Operativos <span class="font-normal text-slate-400">(Opex)</span></span>
            <span class="text-xs font-bold text-orange-600 shrink-0"><%- amt(_cb.opex) %></span>
          </div>
          <div class="w-full bg-slate-100 rounded-full h-2">
            <div class="bg-orange-400 h-2 rounded-full" style="width:<%= _cb.opexPct %>%"></div>
          </div>
          <p class="text-[10px] text-slate-400 mt-1"><%= _cb.opexPct %>% del total · cuenta tipo <code>expense</code> · gastos generales, admin, marketing, software, etc.</p>
        </div>
      </div>
    </div>
    <p class="text-[10px] text-slate-400 mt-3 pt-3 border-t border-slate-100">⚠ No incluye nómina del equipo ni gastos de estructura fija (alquiler, servicios) — no están registrados como facturas en Odoo.</p>
  </div>
  <% } %>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="bg-slate-50 border-b-2 border-slate-200">
            <th class="text-left px-5 py-3 font-bold text-slate-600 min-w-56 sticky left-0 bg-slate-50 z-10">Cuenta Analítica</th>
            <th class="text-right px-3 py-3 font-bold text-emerald-700 min-w-24">Ingresos</th>
            <th class="text-right px-3 py-3 font-bold text-red-600 min-w-24">Costo Directo</th>
            <th class="text-right px-3 py-3 font-bold text-slate-700 min-w-24">Margen</th>
            <th class="text-right px-3 py-3 font-bold text-slate-500 min-w-14">%</th>
            <% fin.months.forEach(m => { %><th class="text-center px-2 py-3 font-semibold text-slate-400 min-w-16"><%= m.label %></th><% }) %>
          </tr>
        </thead>
        <tbody>

          <%# ── INGRESOS — collapsible groups ── %>
          <tr class="bg-emerald-50 border-b border-emerald-100">
            <td colspan="<%= 5 + fin.months.length %>" class="px-5 py-2 text-xs font-extrabold text-emerald-800 uppercase tracking-wide">
              INGRESOS — <%= ingRows.length %> cuentas
              <span class="ml-2 text-emerald-600 font-normal normal-case">· clic en grupo para expandir</span>
            </td>
          </tr>
          <% Object.entries(_ingGroups).forEach(function([groupName, rows]) {
            const gRev  = rows.reduce((s,r) => s + r.totalRevenue, 0);
            const gCost = rows.reduce((s,r) => s + r.totalCost, 0);
            const gMgn  = gRev - gCost;
            const gPct  = gRev > 0 ? Math.round(gMgn / gRev * 100) : 0;
            const gId   = 'ing_' + groupName.replace(/[^a-z0-9]/gi, '_').toLowerCase();
          %>
          <%# Group header row (clickable) %>
          <tr class="bg-emerald-50/70 border-b border-emerald-100 cursor-pointer hover:bg-emerald-100/60 transition select-none"
              onclick="eerrToggle('<%= gId %>')">
            <td class="px-4 py-2 font-bold text-emerald-900 sticky left-0 bg-emerald-50/70 z-10 text-xs">
              <div class="flex items-center gap-2">
                <svg id="<%= gId %>-icon" class="w-3 h-3 text-emerald-600 transition-transform duration-150 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
                <%= groupName %>
                <span class="text-[10px] font-normal text-emerald-600 bg-emerald-100 px-1.5 py-0.5 rounded"><%= rows.length %></span>
              </div>
            </td>
            <td class="text-right px-3 py-2 text-emerald-700 font-bold text-xs"><%-  amtC(gRev) %></td>
            <td class="text-right px-3 py-2 text-red-600 text-xs"><%-  gCost > 0 ? amtC(gCost) : '—' %></td>
            <td class="text-right px-3 py-2 text-xs font-bold <%= gMgn >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%-  amtC(gMgn) %></td>
            <td class="text-right px-3 py-2 text-xs font-bold <%= gPct >= 0 ? 'text-emerald-500' : 'text-red-500' %>"><%= gPct %>%</td>
            <% fin.months.forEach(function(m) {
              const monthRev  = rows.reduce((s,r) => s + (r.months.find(x=>x.month===m.month)||{}).revenue||0, 0);
              const monthCost = rows.reduce((s,r) => s + (r.months.find(x=>x.month===m.month)||{}).cost||0, 0);
            %><td class="text-right px-2 py-2 text-xs <%= monthRev > 0 ? 'text-emerald-600' : 'text-slate-300' %>"><%-  monthRev > 0 ? amtC(monthRev) : '' %></td><% }) %>
          </tr>
          <%# Individual account rows (hidden by default) %>
          <% rows.forEach(function(row) {
            const mClass = row.margin >= 0 ? 'text-emerald-600 font-bold' : 'text-red-500 font-bold';
            const pClass = row.marginPct >= 0 ? 'text-emerald-500' : 'text-red-500';
            const costBadge = row.totalCost > 0
              ? (row.dominantCostType === 'cogs'
                  ? '<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-red-100 text-red-600">COGS</span>'
                  : '<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-orange-100 text-orange-600">Opex</span>')
              : '';
          %>
          <tr class="<%= gId %>-row hidden border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="pl-9 pr-3 py-2 text-slate-700 sticky left-0 bg-white z-10 text-xs"><%= row.name %><%- costBadge %></td>
            <td class="text-right px-3 py-2 text-emerald-700 text-xs"><%-  amtC(row.totalRevenue) %></td>
            <td class="text-right px-3 py-2 text-red-600 text-xs"><%-  row.totalCost > 0 ? amtC(row.totalCost) : '—' %></td>
            <td class="text-right px-3 py-2 text-xs <%= mClass %>"><%-  amtC(row.margin) %></td>
            <td class="text-right px-3 py-2 text-xs <%= pClass %>"><%= row.marginPct %>%</td>
            <% row.months.forEach(function(m) {
              const hasRev = m.revenue > 0; const hasCost = m.cost > 0;
              const cellVal = hasRev ? gsM(m.revenue) : hasCost ? '('+gsM(m.cost)+')' : '';
              const cellCls = hasRev ? 'text-emerald-600' : hasCost ? 'text-red-500' : 'text-slate-200';
            %><td class="text-right px-2 py-2 text-xs <%= cellCls %>" title="<%= m.label %>: Ing <%-  amtG(m.revenue) %> | Costo <%-  amtG(m.cost) %>"><%= cellVal %></td><% }) %>
          </tr>
          <% }) %>
          <% }) %>

          <!-- Subtotal Ingresos -->
          <tr class="bg-emerald-50 border-y-2 border-emerald-300 font-bold text-xs">
            <td class="px-5 py-2.5 font-extrabold text-emerald-900 sticky left-0 bg-emerald-50 z-10">SUBTOTAL INGRESOS</td>
            <td class="text-right px-3 py-2.5 text-emerald-700 font-extrabold"><%-  amtC(totalIngRev) %></td>
            <td class="text-right px-3 py-2.5 text-red-600 font-extrabold"><%-  amtC(totalIngCost) %></td>
            <td class="text-right px-3 py-2.5 <%= totalIngMgn >= 0 ? 'text-emerald-700' : 'text-red-600' %> font-extrabold"><%-  amtC(totalIngMgn) %></td>
            <td class="text-right px-3 py-2.5 <%= totalIngMgn >= 0 ? 'text-emerald-600' : 'text-red-500' %> font-extrabold"><%= totalIngMgnPct %>%</td>
            <% fin.months.forEach(function(m) { %><td class="text-right px-2 py-2.5 <%= m.revenue > 0 ? 'text-emerald-600' : 'text-slate-300' %>"><%-  m.revenue > 0 ? amtC(m.revenue) : '—' %></td><% }) %>
          </tr>

          <% if (egRows.length > 0) { %>
          <%# ── EGRESOS INDIRECTOS — collapsible groups ── %>
          <tr><td colspan="<%= 5 + fin.months.length %>" class="px-5 pt-3 pb-0"></td></tr>
          <tr class="bg-red-50 border-b border-red-100">
            <td colspan="<%= 5 + fin.months.length %>" class="px-5 py-2 text-xs font-extrabold text-red-800 uppercase tracking-wide">
              EGRESOS SIN CONTRAPARTIDA — <%= egRows.length %> cuentas
            </td>
          </tr>
          <% Object.entries(_egGroups).forEach(function([groupName, rows]) {
            const gCost = rows.reduce((s,r) => s + r.totalCost, 0);
            const gId   = 'eg_' + groupName.replace(/[^a-z0-9]/gi, '_').toLowerCase();
          %>
          <tr class="bg-red-50/60 border-b border-red-100 cursor-pointer hover:bg-red-100/50 transition select-none"
              onclick="eerrToggle('<%= gId %>')">
            <td class="px-4 py-2 font-bold text-red-900 sticky left-0 bg-red-50/60 z-10 text-xs">
              <div class="flex items-center gap-2">
                <svg id="<%= gId %>-icon" class="w-3 h-3 text-red-500 transition-transform duration-150 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
                <%= groupName %>
                <span class="text-[10px] font-normal text-red-600 bg-red-100 px-1.5 py-0.5 rounded"><%= rows.length %></span>
              </div>
            </td>
            <td class="text-right px-3 py-2 text-slate-300 text-xs">—</td>
            <td class="text-right px-3 py-2 text-red-600 font-bold text-xs"><%-  amtC(gCost) %></td>
            <td class="text-right px-3 py-2 text-red-500 font-bold text-xs">(<%-  amtC(gCost) %>)</td>
            <td class="text-right px-3 py-2 text-red-400 text-xs">—</td>
            <% fin.months.forEach(function(m) {
              const mCost = rows.reduce((s,r) => s + (r.months.find(x=>x.month===m.month)||{}).cost||0, 0);
            %><td class="text-right px-2 py-2 text-xs <%= mCost > 0 ? 'text-red-500' : 'text-slate-200' %>"><%-  mCost > 0 ? '('+amtC(mCost)+')' : '' %></td><% }) %>
          </tr>
          <% rows.forEach(function(row) {
            const egCostBadge = row.dominantCostType === 'cogs'
              ? '<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-red-100 text-red-600">COGS</span>'
              : '<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-orange-100 text-orange-600">Opex</span>';
          %>
          <tr class="<%= gId %>-row hidden border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="pl-9 pr-3 py-2 text-slate-700 sticky left-0 bg-white z-10 text-xs"><%= row.name %><%- egCostBadge %></td>
            <td class="text-right px-3 py-2 text-slate-300 text-xs">—</td>
            <td class="text-right px-3 py-2 text-red-600 text-xs"><%-  amtC(row.totalCost) %></td>
            <td class="text-right px-3 py-2 text-red-500 font-bold text-xs">(<%-  amtC(row.totalCost) %>)</td>
            <td class="text-right px-3 py-2 text-red-400 text-xs">—</td>
            <% row.months.forEach(function(m) { %><td class="text-right px-2 py-2 text-xs <%= m.cost > 0 ? 'text-red-500' : 'text-slate-200' %>"><%-  m.cost > 0 ? '('+amtC(m.cost)+')' : '' %></td><% }) %>
          </tr>
          <% }) %>
          <% }) %>

          <!-- Subtotal Egresos -->
          <tr class="bg-red-50 border-y-2 border-red-300 font-bold text-xs">
            <td class="px-5 py-2.5 font-extrabold text-red-900 sticky left-0 bg-red-50 z-10">SUBTOTAL EGRESOS INDIRECTOS</td>
            <td class="text-right px-3 py-2.5 text-slate-300">—</td>
            <td class="text-right px-3 py-2.5 text-red-700 font-extrabold"><%-  amtC(totalEgCost) %></td>
            <td class="text-right px-3 py-2.5 text-red-700 font-extrabold">(<%-  amtC(totalEgCost) %>)</td>
            <td colspan="<%= 1 + fin.months.length %>"></td>
          </tr>
          <% } %>

          <!-- Grand total -->
          <tr class="bg-slate-900 text-white font-bold text-xs">
            <td class="px-5 py-3 font-extrabold sticky left-0 bg-slate-900 z-10">RESULTADO NETO PARCIAL</td>
            <td class="text-right px-3 py-3 text-emerald-400 font-extrabold"><%-  amtC(totalIngRev) %></td>
            <td class="text-right px-3 py-3 text-red-400 font-extrabold"><%-  amtC(totalIngCost + totalEgCost) %></td>
            <td class="text-right px-3 py-3 <%= totalIngMgn - totalEgCost >= 0 ? 'text-emerald-400' : 'text-red-400' %> font-extrabold">
              <%-  amtC(totalIngMgn - totalEgCost) %>
            </td>
            <td class="text-right px-3 py-3 <%= totalIngMgn - totalEgCost >= 0 ? 'text-emerald-300' : 'text-red-300' %> font-extrabold">
              <%= totalIngRev > 0 ? Math.round((totalIngMgn - totalEgCost) / totalIngRev * 100) : 0 %>%
            </td>
            <% fin.months.forEach(function(m) { %>
            <td class="text-right px-2 py-3 <%= m.revenue > 0 ? 'text-emerald-300' : 'text-slate-500' %>">
              <%-  m.revenue > 0 ? amtC(m.revenue - m.cost) : '' %>
            </td>
            <% }) %>
          </tr>

          <% if (fin.eerrRows.length === 0) { %>
          <tr><td colspan="17" class="py-12 text-center text-slate-400">Sin datos contables para <%= year %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="px-5 py-3 bg-amber-50 border-t border-amber-100 text-xs text-amber-700">
      ⚠ El "Resultado Neto Parcial" NO incluye nómina del equipo ni gastos de estructura (alquiler, servicios, etc.) ya que no están registrados en Odoo.
      Los costos directos representan facturas de proveedores taggeadas con cuentas analíticas.
    </div>
  </div>

</div><!-- /tab-eerr -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: MÁRGENES
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-margenes" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- Horizontal bar: Revenue vs Direct Cost per account -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="mb-4">
        <h2 class="text-base font-bold text-slate-800">Ingresos vs Costos por Cuenta</h2>
        <p class="text-xs text-slate-400 mt-0.5">YTD <%= year %> · ordenado por ingreso</p>
      </div>
      <div style="height:<%= Math.max(280, ingRows.length * 32) %>px"><canvas id="chartHBar"></canvas></div>
    </div>

    <!-- Margin % ranking -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="mb-4">
        <h2 class="text-base font-bold text-slate-800">Ranking de Margen</h2>
        <p class="text-xs text-slate-400 mt-0.5">Contribución por cuenta analítica</p>
      </div>
      <div class="space-y-2">
        <% ingRows.forEach(row => {
          const barW = Math.max(0, Math.min(100, row.marginPct));
          const barColor = row.marginPct >= 50 ? 'bg-emerald-500' : row.marginPct >= 25 ? 'bg-blue-500' : row.marginPct >= 0 ? 'bg-amber-400' : 'bg-red-500';
        %>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-slate-700 truncate max-w-[200px]" title="<%= row.name %>"><%= row.name %></span>
            <div class="flex items-center gap-3 shrink-0 ml-2">
              <span class="text-xs text-slate-400"><%-  amtC(row.totalRevenue) %></span>
              <span class="text-xs font-bold <%= row.marginPct >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%= row.marginPct %>%</span>
            </div>
          </div>
          <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
            <div class="h-2 rounded-full <%= barColor %> transition-all" style="width:<%= barW %>%"></div>
          </div>
        </div>
        <% }) %>
        <% if (ingRows.length === 0) { %>
        <div class="py-8 text-center text-slate-400 text-sm">Sin datos para <%= year %></div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Stacked revenue by account over months -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-bold text-slate-800">Evolución de Ingresos por Cuenta</h2>
        <p class="text-xs text-slate-400 mt-0.5">Top <%= Math.min(ingRows.length, 6) %> cuentas · barras apiladas por mes</p>
      </div>
    </div>
    <div style="height:280px"><canvas id="chartStacked"></canvas></div>
  </div>

</div><!-- /tab-margenes -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: CXC
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-cxc" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

<%
  const dso = totalIngRev > 0 ? Math.round(cxc.total / (totalIngRev / 365)) : null;
%>
  <div class="flex items-center gap-3 flex-wrap">
    <h2 class="text-xl font-extrabold text-slate-900">Cuentas por Cobrar</h2>
    <span class="bg-amber-100 text-amber-800 text-xs font-bold px-2.5 py-1 rounded-full">
      <%= cxc.count %> facturas · <%- amt(cxc.total) %>
    </span>
    <% if (overdue > 0) { %>
    <span class="bg-red-100 text-red-700 text-xs font-bold px-2.5 py-1 rounded-full">
      <%- amt(overdue) %> vencido
    </span>
    <% } %>
    <% if (dso !== null) { %>
    <span class="bg-blue-50 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-full border border-blue-200">
      DSO: <%= dso %> días prom. de cobro
    </span>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- CXC Aging donut -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-4">Distribución de Saldo</h3>
      <div style="height:200px"><canvas id="chartCxcDonut"></canvas></div>
      <div id="cxcDonutLegend" class="mt-3 space-y-1.5"></div>
    </div>

    <!-- Aging buckets (2/3 width) -->
    <div class="lg:col-span-2 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 content-start">
      <%
        const agingCfg = [
          { key: 'current', label: 'Al día',      color: 'emerald', textColor: 'text-emerald-700' },
          { key: 'd1_30',   label: '1–30 días',   color: 'amber',   textColor: 'text-amber-700' },
          { key: 'd31_60',  label: '31–60 días',  color: 'orange',  textColor: 'text-orange-700' },
          { key: 'd61_90',  label: '61–90 días',  color: 'red',     textColor: 'text-red-700' },
          { key: 'd90plus', label: '+90 días',     color: 'rose',    textColor: 'text-rose-700' },
        ];
        agingCfg.forEach(cfg => {
          const amount     = cxc.buckets[cfg.key] || 0;
          const pctOfTotal = cxc.total > 0 ? Math.round(amount / cxc.total * 100) : 0;
          const count      = cxc.items.filter(i => i.bucket === cfg.key).length;
      %>
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-2"><%= cfg.label %></div>
        <div class="text-xl font-black <%= cfg.textColor %>"><%- amt(amount) %></div>
        <div class="w-full bg-slate-100 rounded-full h-1.5 mt-2">
          <div class="aging-bar bg-<%= cfg.color %>-400 h-1.5 rounded-full" style="width:<%= pctOfTotal %>%"></div>
        </div>
        <div class="flex items-center justify-between mt-1.5">
          <span class="text-[10px] text-slate-400"><%= count %> fact.</span>
          <span class="text-[10px] font-semibold text-slate-500"><%= pctOfTotal %>%</span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Top overdue clients -->
  <% const topOverdue = cxc.items.filter(i => i.daysOverdue > 0).sort((a,b) => b.residual - a.residual).slice(0, 5); %>
  <% if (topOverdue.length > 0) { %>
  <div class="bg-white rounded-xl border border-red-200 p-5">
    <h3 class="text-sm font-bold text-red-700 mb-3">Top <%= topOverdue.length %> — Mayores saldos vencidos</h3>
    <div class="space-y-2">
      <% topOverdue.forEach((inv, i) => { %>
      <div class="flex items-center justify-between py-2 border-b border-slate-50 last:border-0">
        <div class="flex items-center gap-3">
          <span class="text-lg font-black text-slate-300">#<%= i+1 %></span>
          <div>
            <div class="text-sm font-semibold text-slate-800"><%= inv.partner %></div>
            <div class="text-xs text-slate-400"><%= inv.name %> · Vence: <%= inv.dueDate || '—' %></div>
          </div>
        </div>
        <div class="text-right shrink-0">
          <div class="text-sm font-black text-red-600"><%- amt(inv.residual) %></div>
          <div class="text-xs font-bold
            <%= inv.bucket === 'd90plus' ? 'text-rose-600' : inv.bucket === 'd61_90' ? 'text-red-600' : inv.bucket === 'd31_60' ? 'text-orange-600' : 'text-amber-600' %>">
            <%= inv.daysOverdue %>d vencida
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- CXC Detail Table -->
  <div>
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-bold text-slate-700">Detalle completo de facturas</span>
      <button onclick="exportCXCcsv()"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-xs font-semibold text-slate-600 hover:border-blue-300 hover:bg-blue-50 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Exportar CSV
      </button>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto" style="max-height:320px;overflow-y:auto">
        <table class="w-full text-sm">
          <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
            <tr class="text-xs">
              <th class="text-left px-4 py-2.5 font-semibold text-slate-600">Factura</th>
              <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Cliente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Vencimiento</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Días vencida</th>
              <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Total</th>
              <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Pendiente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Bucket</th>
            </tr>
          </thead>
          <tbody>
            <% cxc.items.forEach(inv => {
              const rowBg = inv.bucket === 'd90plus' ? 'bg-red-50/60' : inv.bucket === 'd61_90' ? 'bg-orange-50/40' : '';
            %>
            <tr class="border-b border-slate-50 hover:bg-slate-50 transition <%= rowBg %>">
              <td class="px-4 py-2 text-xs font-mono text-slate-700"><%= inv.name %></td>
              <td class="px-3 py-2 text-xs font-medium text-slate-800 max-w-xs truncate"><%= inv.partner %></td>
              <td class="px-3 py-2 text-xs text-center <%= inv.daysOverdue > 0 ? 'text-red-600 font-semibold' : 'text-slate-500' %>"><%= inv.dueDate || '—' %></td>
              <td class="px-3 py-2 text-center">
                <% if (inv.daysOverdue > 0) { %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-bold
                  <%= inv.bucket === 'd90plus' ? 'bg-rose-100 text-rose-700' : inv.bucket === 'd61_90' ? 'bg-red-100 text-red-700' : inv.bucket === 'd31_60' ? 'bg-orange-100 text-orange-700' : 'bg-amber-100 text-amber-700' %>">
                  <%= inv.daysOverdue %>d
                </span>
                <% } else { %><span class="text-xs text-emerald-500 font-semibold">Al día</span><% } %>
              </td>
              <td class="px-4 py-2 text-right text-xs text-slate-500"><%-  amtG(inv.total) %></td>
              <td class="px-4 py-2 text-right text-xs font-bold text-slate-900"><%-  amtG(inv.residual) %></td>
              <td class="px-3 py-2 text-center">
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-semibold bg-slate-100 text-slate-500">
                  <%= inv.bucket === 'current' ? 'Al día' : inv.bucket.replace('d','').replace('_','-') + 'd' %>
                </span>
              </td>
            </tr>
            <% }) %>
            <% if (cxc.items.length === 0) { %>
            <tr><td colspan="7" class="py-10 text-center text-slate-400">✅ Sin facturas pendientes</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div><!-- /tab-cxc -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: PIPELINE
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-pipeline" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-4">

  <div class="flex items-center gap-3">
    <h2 class="text-xl font-extrabold text-slate-900">Pipeline Comercial</h2>
    <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= pipeline.count %> cotizaciones · <%- amt(pipeline.total) %></span>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Total Pipeline</div>
      <div class="text-2xl font-black text-blue-700"><%- amt(pipeline.total) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= pipeline.count %> cotizaciones</div>
    </div>
    <div class="bg-white rounded-xl border border-blue-200 p-4">
      <div class="text-[10px] font-bold text-blue-600 uppercase tracking-wide mb-1">Enviadas</div>
      <div class="text-2xl font-black text-blue-700"><%- amt(pipeline.totalSent) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= pipeline.countSent %> cotiz. · esperando respuesta</div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Borradores</div>
      <div class="text-2xl font-black text-slate-700"><%- amt(pipeline.totalDraft) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= pipeline.countDraft %> cotiz. · sin enviar</div>
    </div>
    <div class="bg-white rounded-xl border border-emerald-200 p-4">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Tasa de Cierre</div>
      <% if (closingRate.rate !== null) { %>
      <div class="text-2xl font-black text-emerald-700"><%= closingRate.rate %>%</div>
      <div class="text-xs text-slate-400 mt-1"><%= closingRate.wonCount %> ganadas / <%= closingRate.totalCount %> elegibles</div>
      <% } else { %>
      <div class="text-2xl font-black text-slate-400">—</div>
      <% } %>
      <div class="text-xs text-slate-400 mt-0.5">Últimos <%= closingRate.period %></div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto" style="max-height:400px;overflow-y:auto">
      <table class="w-full text-sm">
        <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
          <tr class="text-xs">
            <th class="text-left px-4 py-2.5 font-semibold text-slate-600">Cotización</th>
            <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Cliente</th>
            <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Estado</th>
            <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Monto</th>
            <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Responsable</th>
            <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Fecha</th>
            <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Vence</th>
          </tr>
        </thead>
        <tbody>
          <% pipeline.items.forEach(o => { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="px-4 py-2 text-xs font-mono text-slate-700"><%= o.name %></td>
            <td class="px-3 py-2 text-xs font-medium text-slate-800 max-w-xs truncate"><%= o.partner %></td>
            <td class="px-3 py-2 text-center">
              <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-bold
                <%= o.state === 'sent' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
                <%= o.state === 'sent' ? 'Enviada' : 'Borrador' %>
              </span>
            </td>
            <td class="px-4 py-2 text-right text-xs font-bold text-slate-900"><%-  amtG(o.amount) %></td>
            <td class="px-3 py-2 text-xs text-slate-500 truncate max-w-xs"><%= o.user %></td>
            <td class="px-3 py-2 text-xs text-center text-slate-500"><%= o.date || '—' %></td>
            <td class="px-3 py-2 text-xs text-center <%= o.validUntil && o.validUntil < new Date().toISOString().slice(0,10) ? 'text-red-500 font-semibold' : 'text-slate-500' %>">
              <%= o.validUntil || '—' %>
            </td>
          </tr>
          <% }) %>
          <% if (pipeline.items.length === 0) { %>
          <tr><td colspan="7" class="py-8 text-center text-slate-400">Sin cotizaciones abiertas</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /tab-pipeline -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: ALERTAS DE CALIDAD DE DATOS
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-alertas" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-xl font-extrabold text-slate-900">Alertas de Calidad de Datos</h2>
      <p class="text-xs text-slate-400 mt-0.5">Problemas detectados en Odoo que afectan la precisión del dashboard · hacé click para corregir</p>
    </div>
    <% if (dqAlerts && dqAlerts.count > 0) { %>
    <div class="flex items-center gap-3">
      <% if (dqAlerts.highCount > 0) { %>
      <span class="flex items-center gap-1.5 bg-red-50 border border-red-200 text-red-700 text-xs font-bold px-3 py-1.5 rounded-full">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        <%= dqAlerts.highCount %> alerta<%= dqAlerts.highCount !== 1 ? 's' : '' %> crítica<%= dqAlerts.highCount !== 1 ? 's' : '' %>
      </span>
      <% } %>
      <span class="text-xs text-slate-500"><%= dqAlerts.count %> total</span>
    </div>
    <% } %>
  </div>

  <% if (!dqAlerts || dqAlerts.count === 0) { %>
  <div class="bg-white rounded-xl border border-emerald-200 p-10 text-center">
    <svg class="w-10 h-10 text-emerald-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <p class="text-sm font-bold text-emerald-700">Todo limpio</p>
    <p class="text-xs text-slate-400 mt-1">No se detectaron problemas de calidad de datos para el período seleccionado.</p>
  </div>
  <% } else { %>

  <%
    // Group alerts by type for section headers
    const _alertGroups = {};
    for (const al of dqAlerts.alerts) {
      if (!_alertGroups[al.type]) _alertGroups[al.type] = [];
      _alertGroups[al.type].push(al);
    }
    const _alertGroupMeta = {
      missing_analytic:      { label: 'Facturas de cliente sin distribución analítica', icon: 'receipt', color: 'red', desc: 'Estas facturas no están taggeadas a ninguna cuenta analítica. El dashboard no las incluye en el análisis de márgenes ni por cliente.' },
      missing_analytic_cost: { label: 'Facturas de proveedor sin distribución analítica', icon: 'receipt', color: 'amber', desc: 'Costos de proveedor no asignados a ningún proyecto o cuenta. Impactan el análisis de COGS y márgenes.' },
    };
  %>

  <% Object.entries(_alertGroups).forEach(function([type, items]) {
    const meta   = _alertGroupMeta[type] || { label: type, color: 'slate', desc: '' };
    const isHigh = meta.color === 'red';
    const totalAmt = items.reduce((s, a) => s + a.amount, 0);
  %>
  <div class="bg-white rounded-xl border <%= isHigh ? 'border-red-200' : 'border-amber-200' %> overflow-hidden">
    <!-- Group header -->
    <div class="<%= isHigh ? 'bg-red-50 border-red-200' : 'bg-amber-50 border-amber-200' %> border-b px-5 py-3 flex items-start justify-between gap-4">
      <div>
        <div class="flex items-center gap-2 mb-0.5">
          <span class="<%= isHigh ? 'bg-red-500' : 'bg-amber-400' %> text-white text-[10px] font-extrabold rounded-full w-5 h-5 flex items-center justify-center shrink-0"><%= items.length %></span>
          <span class="text-sm font-extrabold <%= isHigh ? 'text-red-800' : 'text-amber-800' %>"><%= meta.label %></span>
        </div>
        <p class="text-xs <%= isHigh ? 'text-red-600' : 'text-amber-700' %> ml-7"><%= meta.desc %></p>
      </div>
      <div class="text-right shrink-0">
        <div class="text-xs font-bold <%= isHigh ? 'text-red-700' : 'text-amber-700' %>"><%- amt(totalAmt) %> afectado</div>
        <div class="text-[10px] text-slate-400 mt-0.5">suma de líneas sin analítica</div>
      </div>
    </div>

    <!-- Alert rows -->
    <div class="divide-y divide-slate-50">
      <% items.forEach(function(al) { %>
      <div class="flex items-center justify-between gap-4 px-5 py-3 hover:bg-slate-50 transition group">
        <div class="flex items-start gap-3 min-w-0">
          <div class="mt-0.5 shrink-0">
            <div class="w-2 h-2 rounded-full <%= isHigh ? 'bg-red-400' : 'bg-amber-400' %> mt-1"></div>
          </div>
          <div class="min-w-0">
            <div class="text-xs font-bold text-slate-800 truncate"><%= al.partner %></div>
            <div class="text-[11px] text-slate-400 mt-0.5 flex items-center gap-2">
              <span class="font-mono"><%= al.moveName %></span>
              <span>·</span>
              <span><%= al.date %></span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <div class="text-right">
            <div class="text-xs font-bold text-slate-700"><%- amt(al.amount) %></div>
            <div class="text-[10px] text-slate-400">sin analítica</div>
          </div>
          <a href="<%= al.odooUrl %>" target="_blank" rel="noopener"
             class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-blue-200 bg-blue-50 text-blue-700 text-xs font-semibold hover:bg-blue-100 hover:border-blue-300 transition whitespace-nowrap">
            Corregir en Odoo
            <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>

  <!-- Summary callout -->
  <div class="bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-xs text-slate-600">
    <strong>Impacto en el dashboard:</strong> Las facturas sin distribución analítica no aparecen en el análisis por cuenta, por cliente ni en el EERR. Corregirlas en Odoo (agregar la distribución analítica en cada línea de producto) actualizará el dashboard automáticamente en la próxima carga (caché 1h).
  </div>
  <% } %>

</div><!-- /tab-alertas -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: CLIENTES
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-clientes" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-xl font-extrabold text-slate-900">Rentabilidad por Cliente</h2>
      <p class="text-xs text-slate-400 mt-0.5">Ingresos facturados a cada cliente · <%= year %></p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <div class="relative">
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="clientSearch" type="text" placeholder="Buscar cliente…"
          oninput="filterClients(this.value)"
          class="pl-8 pr-3 py-1.5 text-xs border border-slate-200 rounded-lg bg-white text-slate-700 placeholder-slate-400 focus:outline-none focus:border-blue-400 w-44">
      </div>
      <span class="bg-slate-100 text-slate-700 text-xs font-bold px-3 py-1.5 rounded-full" id="clientCount"><%= clients.clientCount %> clientes activos</span>
      <% if (clients.top3Pct > 0) { %>
      <span class="<%= clients.top3Pct > 70 ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %> text-xs font-bold px-3 py-1.5 rounded-full">
        Top 3 = <%= clients.top3Pct %>% del revenue
      </span>
      <% } %>
    </div>
  </div>

  <!-- Client charts row -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Revenue donut by client -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-1">Concentración de Ingresos</h3>
      <p class="text-xs text-slate-400 mb-4">Top clientes por revenue · <%= year %></p>
      <div style="height:200px"><canvas id="chartClientDonut"></canvas></div>
      <div id="clientDonutLegend" class="mt-3 space-y-1 text-xs"></div>
    </div>

    <!-- Revenue bar ranking (top 10) -->
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-1">Ranking de Clientes por Revenue</h3>
      <p class="text-xs text-slate-400 mb-4">Top 10 · barras horizontales</p>
      <div style="height:<%= Math.max(220, Math.min(clients.clients.length, 10) * 36) %>px">
        <canvas id="chartClientBar"></canvas>
      </div>
    </div>
  </div>

  <!-- Client CXC heatmap — DSO + outstanding -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="bg-white rounded-xl border border-red-200 p-4">
      <h3 class="text-sm font-bold text-red-700 mb-3">Top deudores</h3>
      <div class="space-y-2">
        <% const topDebtors = clients.clients.filter(c => c.unpaid > 0).sort((a,b) => b.unpaid - a.unpaid).slice(0,5); %>
        <% topDebtors.forEach(function(c, i) { %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-xs font-black text-slate-300">#<%= i+1 %></span>
            <span class="text-xs font-semibold text-slate-700 truncate"><%= c.name %></span>
          </div>
          <div class="text-right shrink-0 ml-2">
            <div class="text-xs font-bold text-red-600"><%- amt(c.unpaid) %></div>
            <div class="text-[10px] text-slate-400">DSO <%= c.dso %>d</div>
          </div>
        </div>
        <% }) %>
        <% if (topDebtors.length === 0) { %><p class="text-xs text-slate-400">Sin saldo pendiente</p><% } %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-emerald-200 p-4">
      <h3 class="text-sm font-bold text-emerald-700 mb-3">Top clientes por revenue</h3>
      <div class="space-y-2">
        <% clients.clients.slice(0,5).forEach(function(c, i) { %>
        <div class="flex items-center justify-between gap-2">
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-xs font-black text-slate-300">#<%= i+1 %></span>
            <span class="text-xs font-semibold text-slate-700 truncate"><%= c.name %></span>
          </div>
          <div class="text-right shrink-0">
            <div class="text-xs font-bold text-emerald-700"><%- amt(c.revenue) %></div>
            <div class="text-[10px] text-slate-400"><%= c.revPct %>%</div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <h3 class="text-sm font-bold text-slate-700 mb-3">Frecuencia de facturación</h3>
      <div class="space-y-2">
        <% clients.clients.slice(0,5).forEach(function(c) { %>
        <div class="flex items-center justify-between gap-2">
          <span class="text-xs font-semibold text-slate-700 truncate"><%= c.name %></span>
          <div class="text-right shrink-0">
            <span class="text-xs font-bold text-slate-700"><%= c.invoiceCount %></span>
            <span class="text-[10px] text-slate-400"> fact.</span>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Full client table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-5 py-3 font-bold text-slate-600">#</th>
            <th class="text-left px-4 py-3 font-bold text-slate-600">Cliente</th>
            <th class="text-right px-4 py-3 font-bold text-emerald-700">Revenue</th>
            <th class="text-right px-4 py-3 font-bold text-slate-500">% Total</th>
            <th class="text-right px-4 py-3 font-bold text-slate-500">Facturas</th>
            <th class="text-right px-4 py-3 font-bold text-amber-600">Pendiente</th>
            <th class="text-right px-4 py-3 font-bold text-blue-600">DSO (días)</th>
            <th class="text-left px-4 py-3 font-bold text-slate-500">Rev. mensual</th>
          </tr>
        </thead>
        <tbody id="clientTableBody">
          <% clients.clients.forEach(function(c, i) { %>
          <tr class="client-row border-b border-slate-50 hover:bg-slate-50 transition" data-name="<%= c.name.toLowerCase() %>">
            <td class="px-5 py-2.5 text-slate-400 font-bold"><%= i+1 %></td>
            <td class="px-4 py-2.5 font-semibold text-slate-800"><%= c.name %></td>
            <td class="px-4 py-2.5 text-right font-bold text-emerald-700"><%- amt(c.revenue) %></td>
            <td class="px-4 py-2.5 text-right">
              <div class="flex items-center justify-end gap-2">
                <div class="w-12 bg-slate-100 rounded-full h-1.5">
                  <div class="h-1.5 rounded-full bg-emerald-400" style="width:<%= c.revPct %>%"></div>
                </div>
                <span class="font-semibold text-slate-600"><%= c.revPct %>%</span>
              </div>
            </td>
            <td class="px-4 py-2.5 text-right text-slate-600"><%= c.invoiceCount %></td>
            <td class="px-4 py-2.5 text-right font-semibold <%= c.unpaid > 0 ? 'text-amber-600' : 'text-slate-300' %>">
              <%- c.unpaid > 0 ? amt(c.unpaid) : '—' %>
            </td>
            <td class="px-4 py-2.5 text-right">
              <% if (c.dso > 0) { %>
              <span class="font-bold <%= c.dso > 60 ? 'text-red-600' : c.dso > 30 ? 'text-amber-600' : 'text-emerald-600' %>"><%= c.dso %>d</span>
              <% } else { %><span class="text-slate-300">—</span><% } %>
            </td>
            <td class="px-4 py-2.5">
              <%
                const mKeys = Object.keys(c.monthlyRev||{}).sort().slice(-6);
                const mMax  = Math.max(...mKeys.map(k => c.monthlyRev[k]), 1);
              %>
              <div class="flex items-end gap-0.5 h-5">
                <% mKeys.forEach(function(k) { const h = Math.round((c.monthlyRev[k]/mMax)*16); %>
                <div class="w-2 rounded-sm bg-emerald-400 opacity-70" style="height:<%= h %>px" title="<%= k %>: Gs. <%= gsM(c.monthlyRev[k] || 0) %>"></div>
                <% }) %>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (clients.clients.length === 0) { %>
          <tr><td colspan="8" class="py-10 text-center text-slate-400">Sin datos de clientes para <%= year %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /tab-clientes -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: PRODUCTOS (Líneas de Servicio)
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-productos" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div>
    <h2 class="text-xl font-extrabold text-slate-900">Rentabilidad por Línea de Servicio</h2>
    <p class="text-xs text-slate-400 mt-0.5">Agrupado por categoría de producto (2° nivel) · Cuentas analíticas · <%= year %></p>
  </div>

  <!-- ── Categorías de Producto ─────────────────────────────────────────── -->
  <% if (fin.catRows && fin.catRows.length > 0) { %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="bg-slate-50 border-b border-slate-200 px-5 py-2.5 flex items-center justify-between">
      <span class="text-xs font-extrabold text-slate-700 uppercase tracking-wide">Por Categoría de Producto</span>
      <span class="text-xs text-slate-400"><%= fin.catRows.length %> categorías</span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-3 font-bold text-slate-600">Categoría</th>
            <th class="text-right px-4 py-3 font-bold text-emerald-700">Ingresos</th>
            <th class="text-right px-4 py-3 font-bold text-red-600">Costo</th>
            <th class="text-right px-4 py-3 font-bold text-slate-700">Margen</th>
            <th class="text-right px-4 py-3 font-bold text-slate-500">Margen %</th>
            <th class="text-right px-4 py-3 font-bold text-slate-400">% Ingresos</th>
            <th class="text-left px-4 py-3 font-bold text-slate-400">Evolución</th>
          </tr>
        </thead>
        <tbody>
          <% const totalCatRev = fin.catRows.reduce((s,r) => s + r.totalRevenue, 0); %>
          <% fin.catRows.forEach(function(row) { %>
          <%
            const cPct = totalCatRev > 0 ? Math.round(row.totalRevenue / totalCatRev * 100) : 0;
            const cMx  = Math.max(...row.months.map(m => m.revenue), 1);
          %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="px-5 py-2.5 font-semibold text-slate-800"><%= row.name %></td>
            <td class="px-4 py-2.5 text-right text-emerald-700 font-bold"><%- amt(row.totalRevenue) %></td>
            <td class="px-4 py-2.5 text-right text-red-600"><%- row.totalCost > 0 ? amt(row.totalCost) : '<span class="text-slate-300">—</span>' %></td>
            <td class="px-4 py-2.5 text-right font-bold <%= row.margin >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%- amt(row.margin) %></td>
            <td class="px-4 py-2.5 text-right">
              <span class="inline-block px-2 py-0.5 rounded font-bold text-[11px]
                <%= row.marginPct >= 50 ? 'bg-emerald-100 text-emerald-700' : row.marginPct >= 25 ? 'bg-blue-100 text-blue-700' : row.marginPct >= 0 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-600' %>">
                <%= row.marginPct %>%
              </span>
            </td>
            <td class="px-4 py-2.5 text-right">
              <div class="flex items-center justify-end gap-2">
                <div class="w-16 bg-slate-100 rounded-full h-1.5">
                  <div class="bg-emerald-500 h-1.5 rounded-full" style="width:<%= cPct %>%"></div>
                </div>
                <span class="text-slate-500 font-semibold w-7 text-right"><%= cPct %>%</span>
              </div>
            </td>
            <td class="px-4 py-2.5">
              <div class="flex items-end gap-0.5 h-5">
                <% row.months.forEach(function(m) { const bh = m.revenue > 0 ? Math.round(m.revenue/cMx*16) : 1; %>
                <div class="w-2 rounded-sm <%= m.revenue > 0 ? 'bg-blue-400' : 'bg-slate-100' %> opacity-80"
                     style="height:<%= bh %>px"
                     title="<%= m.label %>: Gs. <%= gsM(m.revenue) %>"></div>
                <% }) %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- KPI row productos -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Líneas de Servicio</div>
      <div class="text-2xl font-black text-slate-900"><%= svcLines.length %></div>
      <div class="text-xs text-slate-400 mt-1"><%- amt(totalSvcRev) %></div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Proyectos</div>
      <div class="text-2xl font-black text-slate-900"><%= projRows.length %></div>
      <div class="text-xs text-slate-400 mt-1"><%- amt(totalProjRev) %></div>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1">Mejor producto</div>
      <% const bestSvc = svcLines[0]; %>
      <div class="text-base font-black text-slate-900 truncate"><%= bestSvc ? bestSvc.name.replace(/[\[\]]/g,'') : '—' %></div>
      <div class="text-xs text-emerald-600 font-bold mt-1"><%- bestSvc ? amt(bestSvc.totalRevenue) : '' %></div>
    </div>
    <div class="bg-white rounded-xl border border-emerald-200 p-4">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Mejor margen</div>
      <% const bestMgn = [...svcLines].sort((a,b) => b.marginPct - a.marginPct)[0]; %>
      <div class="text-base font-black text-emerald-700 truncate"><%= bestMgn ? bestMgn.name.replace(/[\[\]]/g,'') : '—' %></div>
      <div class="text-xs text-emerald-600 font-bold mt-1"><%= bestMgn ? bestMgn.marginPct + '%' : '' %></div>
    </div>
  </div>

  <!-- Charts row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Donut mix de productos -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-1">Mix de Ingresos por Producto</h3>
      <p class="text-xs text-slate-400 mb-4">Participación de cada línea de servicio</p>
      <div style="height:220px"><canvas id="chartProductDonut"></canvas></div>
      <div id="productDonutLegend" class="mt-3 space-y-1 text-xs"></div>
    </div>
    <!-- Bar revenue vs margin per product -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-1">Revenue vs Margen por Producto</h3>
      <p class="text-xs text-slate-400 mb-4">Ingresos y porcentaje de margen</p>
      <div style="height:220px"><canvas id="chartProductBar"></canvas></div>
    </div>
  </div>

  <!-- Tabla servicios -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="bg-slate-50 border-b border-slate-200 px-5 py-2.5 flex items-center justify-between gap-3">
      <span class="text-xs font-extrabold text-slate-700 uppercase tracking-wide">Líneas de Servicio — Detalle</span>
      <div class="relative">
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="svcSearch" type="text" placeholder="Filtrar…"
          oninput="filterSvcLines(this.value)"
          class="pl-8 pr-3 py-1 text-xs border border-slate-200 rounded-lg bg-white text-slate-700 placeholder-slate-400 focus:outline-none focus:border-blue-400 w-36">
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-3 font-bold text-slate-600">Producto / Servicio</th>
            <th class="text-right px-4 py-3 font-bold text-emerald-700">Ingresos</th>
            <th class="text-right px-4 py-3 font-bold text-red-600">Costo</th>
            <th class="text-right px-4 py-3 font-bold text-slate-700">Margen</th>
            <th class="text-right px-4 py-3 font-bold text-slate-500">Margen %</th>
            <th class="text-left px-4 py-3 font-bold text-slate-400">Evolución mensual</th>
          </tr>
        </thead>
        <tbody>
          <% (svcLines.length > 0 ? svcLines : ingRows).forEach(function(row) { %>
          <tr class="svc-row border-b border-slate-50 hover:bg-slate-50 transition" data-name="<%= row.name.toLowerCase() %>">
            <td class="px-5 py-2.5 font-semibold text-slate-800"><%= row.name %></td>
            <td class="px-4 py-2.5 text-right text-emerald-700 font-bold"><%- amt(row.totalRevenue) %></td>
            <td class="px-4 py-2.5 text-right text-red-600"><%- row.totalCost > 0 ? amt(row.totalCost) : '—' %></td>
            <td class="px-4 py-2.5 text-right font-bold <%= row.margin >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%- amt(row.margin) %></td>
            <td class="px-4 py-2.5 text-right">
              <span class="inline-block px-2 py-0.5 rounded font-bold text-[11px]
                <%= row.marginPct >= 50 ? 'bg-emerald-100 text-emerald-700' : row.marginPct >= 25 ? 'bg-blue-100 text-blue-700' : row.marginPct >= 0 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-600' %>">
                <%= row.marginPct %>%
              </span>
            </td>
            <td class="px-4 py-2.5">
              <%
                const rMx = Math.max(...row.months.map(m => m.revenue), 1);
              %>
              <div class="flex items-end gap-0.5 h-5">
                <% row.months.forEach(function(m) { const bh = m.revenue > 0 ? Math.round(m.revenue/rMx*16) : 1; %>
                <div class="w-2 rounded-sm <%= m.revenue > 0 ? 'bg-emerald-400' : 'bg-slate-100' %> opacity-80" style="height:<%= bh %>px" title="<%= m.label %>: Gs. <%= gsM(m.revenue) %>"></div>
                <% }) %>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (ingRows.length === 0) { %>
          <tr><td colspan="6" class="py-10 text-center text-slate-400">Sin datos de productos para <%= year %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (projRows.length > 0) { %>
  <!-- Tabla proyectos -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="bg-slate-50 border-b border-slate-200 px-5 py-2.5 text-xs font-extrabold text-slate-700 uppercase tracking-wide">
      Proyectos por Cuenta Analítica (<%= projRows.length %>)
    </div>
    <div class="overflow-x-auto" style="max-height:320px;overflow-y:auto">
      <table class="w-full text-xs">
        <thead class="sticky top-0 bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-2.5 font-bold text-slate-600">Proyecto</th>
            <th class="text-right px-4 py-2.5 font-bold text-emerald-700">Revenue</th>
            <th class="text-right px-4 py-2.5 font-bold text-red-600">Costo</th>
            <th class="text-right px-4 py-2.5 font-bold text-slate-500">Margen %</th>
          </tr>
        </thead>
        <tbody>
          <% projRows.forEach(function(row) { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="px-5 py-2 font-medium text-slate-700 max-w-xs truncate" title="<%= row.name %>"><%= row.name %></td>
            <td class="px-4 py-2 text-right text-emerald-700 font-semibold"><%- amt(row.totalRevenue) %></td>
            <td class="px-4 py-2 text-right text-red-600"><%- row.totalCost > 0 ? amt(row.totalCost) : '—' %></td>
            <td class="px-4 py-2 text-right">
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold
                <%= row.marginPct >= 50 ? 'bg-emerald-100 text-emerald-700' : row.marginPct >= 25 ? 'bg-blue-100 text-blue-700' : row.marginPct >= 0 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-600' %>">
                <%= row.marginPct %>%
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

</div><!-- /tab-productos -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: CASH FLOW
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-cashflow" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div class="flex items-center gap-3 flex-wrap">
    <h2 class="text-xl font-extrabold text-slate-900">Cash Flow</h2>
    <span class="bg-slate-100 text-slate-700 text-xs font-bold px-2.5 py-1 rounded-full">
      Net en 90d: <span class="<%= cashInflow.d90 - cashOutflow.d90 >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
        <%- amt(cashInflow.d90 - cashOutflow.d90) %>
      </span>
    </span>
  </div>

  <!-- Cash flow KPIs -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
    <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Entradas esperadas 30d</div>
      <div class="text-xl font-black text-emerald-700"><%- amt(cashInflow.d30) %></div>
      <div class="text-[11px] text-emerald-600 mt-1">CXC al día + 1–30d</div>
    </div>
    <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Entradas esperadas 60d</div>
      <div class="text-xl font-black text-emerald-700"><%- amt(cashInflow.d60) %></div>
    </div>
    <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Total CXC</div>
      <div class="text-xl font-black text-emerald-700"><%- amt(cashInflow.total) %></div>
      <div class="text-[11px] text-slate-400 mt-1"><%= cxc.count %> facturas</div>
    </div>
    <div class="bg-orange-50 rounded-xl border border-orange-200 p-4">
      <div class="text-[10px] font-bold text-orange-600 uppercase tracking-wide mb-1">Salidas esperadas 30d</div>
      <div class="text-xl font-black text-orange-700"><%- amt(cashOutflow.d30) %></div>
      <div class="text-[11px] text-orange-600 mt-1">CXP al día + 1–30d</div>
    </div>
    <div class="bg-orange-50 rounded-xl border border-orange-200 p-4">
      <div class="text-[10px] font-bold text-orange-600 uppercase tracking-wide mb-1">Salidas esperadas 60d</div>
      <div class="text-xl font-black text-orange-700"><%- amt(cashOutflow.d60) %></div>
    </div>
    <div class="bg-orange-50 rounded-xl border border-orange-200 p-4">
      <div class="text-[10px] font-bold text-orange-600 uppercase tracking-wide mb-1">Total CXP</div>
      <div class="text-xl font-black text-orange-700"><%- amt(cashOutflow.total) %></div>
      <div class="text-[11px] text-slate-400 mt-1"><%= cxp.count %> facturas prov.</div>
    </div>
  </div>

  <!-- Net projection bars -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="text-sm font-bold text-slate-800 mb-4">Proyección Neta de Caja — 30 · 60 · 90 días</h3>
    <div class="grid grid-cols-3 gap-4">
      <% [[30, cashInflow.d30, cashOutflow.d30], [60, cashInflow.d60, cashOutflow.d60], [90, cashInflow.d90, cashOutflow.d90]].forEach(function(row) {
        const days = row[0], inf = row[1], out = row[2], net = inf - out;
      %>
      <div class="bg-slate-50 rounded-xl p-4 text-center">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-2">En <%= days %> días</div>
        <div class="text-2xl font-black <%= net >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
          <%- amt(net) %>
        </div>
        <div class="mt-3 space-y-1 text-xs">
          <div class="flex justify-between text-emerald-600"><span>Entradas</span><span class="font-semibold"><%- amt(inf) %></span></div>
          <div class="flex justify-between text-orange-600"><span>Salidas</span><span class="font-semibold"><%- amt(out) %></span></div>
          <div class="border-t border-slate-200 pt-1 flex justify-between font-bold <%= net >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
            <span>Neto</span><span><%- amt(net) %></span>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Pipeline — Ingresos esperados (cotizaciones) -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <h3 class="text-sm font-bold text-slate-800">Ingresos Esperados — Cotizaciones en Curso</h3>
      <span class="text-xs text-slate-500 bg-slate-100 px-2 py-1 rounded-full"><%= pipeline.count %> cotizaciones activas</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
        <div class="text-[10px] font-bold text-blue-600 uppercase tracking-wide mb-1">Enviadas (confirmadas)</div>
        <div class="text-xl font-black text-blue-700"><%- amt(pipelineSent) %></div>
        <div class="text-[11px] text-blue-500 mt-1"><%= pipeline.countSent %> cotizaciones · alta probabilidad</div>
      </div>
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">En Borrador</div>
        <div class="text-xl font-black text-slate-700"><%- amt(pipelineDraft) %></div>
        <div class="text-[11px] text-slate-400 mt-1"><%= pipeline.countDraft %> cotizaciones · pendiente de envío</div>
      </div>
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4">
        <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Total Pipeline</div>
        <div class="text-xl font-black text-emerald-700"><%- amt(pipeline.total) %></div>
        <div class="text-[11px] text-emerald-600 mt-1">Si se confirman y facturan</div>
      </div>
    </div>
    <!-- Top pipeline items -->
    <% if (pipeline.items.length > 0) { %>
    <div class="overflow-x-auto" style="max-height:200px;overflow-y:auto">
      <table class="w-full text-xs">
        <thead class="sticky top-0 bg-white border-b border-slate-100">
          <tr>
            <th class="text-left py-2 px-3 font-semibold text-slate-500">Cliente</th>
            <th class="text-left py-2 px-3 font-semibold text-slate-500">Cotización</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-500">Estado</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-500">Monto</th>
          </tr>
        </thead>
        <tbody>
          <% pipeline.items.slice(0,10).forEach(function(o) { %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="px-3 py-2 font-medium text-slate-700 truncate max-w-[150px]"><%= o.partner %></td>
            <td class="px-3 py-2 text-slate-500"><%= o.name %></td>
            <td class="px-3 py-2 text-center">
              <span class="inline-flex px-2 py-0.5 rounded text-[10px] font-bold <%= o.state === 'sent' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-500' %>">
                <%= o.state === 'sent' ? 'Enviada' : 'Borrador' %>
              </span>
            </td>
            <td class="px-3 py-2 text-right font-bold text-slate-900"><%- amt(o.amount) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Nómina comprometida — próximos 3 meses -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <h3 class="text-sm font-bold text-slate-800">Salidas Comprometidas — Nómina Próximos 3 Meses</h3>
      <span class="text-xs font-semibold bg-orange-100 text-orange-700 px-2 py-1 rounded-full"><%= payroll.contractCount %> contratos vigentes</span>
    </div>
    <div class="grid grid-cols-3 gap-4 mb-5">
      <% nextMonthsPayroll.forEach(function(m, idx) { %>
      <div class="<%= idx === 0 ? 'bg-orange-50 border-2 border-orange-300' : 'bg-slate-50 border border-slate-200' %> rounded-xl p-4 text-center">
        <div class="text-[10px] font-bold <%= idx === 0 ? 'text-orange-600' : 'text-slate-500' %> uppercase tracking-wide mb-1">
          <%= m.label %><%= idx === 0 ? ' (este mes)' : '' %>
        </div>
        <div class="text-xl font-black <%= idx === 0 ? 'text-orange-700' : 'text-slate-700' %>"><%- amt(m.salary) %></div>
        <div class="text-[11px] <%= idx === 0 ? 'text-orange-500' : 'text-slate-400' %> mt-1"><%= m.count %> empleados</div>
      </div>
      <% }) %>
    </div>

    <!-- Employee breakdown -->
    <% if (payroll.byEmployee && payroll.byEmployee.length > 0) { %>
    <div class="overflow-x-auto" style="max-height:200px;overflow-y:auto">
      <table class="w-full text-xs">
        <thead class="sticky top-0 bg-white border-b border-slate-100">
          <tr>
            <th class="text-left py-2 px-3 font-semibold text-slate-500">Empleado</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-500">Estado</th>
            <th class="text-center py-2 px-3 font-semibold text-slate-500">Inicio</th>
            <th class="text-right py-2 px-3 font-semibold text-slate-500">Salario/mes</th>
          </tr>
        </thead>
        <tbody>
          <% payroll.byEmployee.forEach(function(e) { %>
          <tr class="border-b border-slate-50 hover:bg-orange-50/30">
            <td class="px-3 py-2 font-medium text-slate-700"><%= e.name %></td>
            <td class="px-3 py-2 text-center">
              <span class="inline-flex px-2 py-0.5 rounded text-[10px] font-bold <%= e.state === 'open' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                <%= e.state === 'open' ? 'Vigente' : 'Borrador' %>
              </span>
            </td>
            <td class="px-3 py-2 text-center text-slate-400"><%= e.dateStart || '—' %></td>
            <td class="px-3 py-2 text-right font-black text-slate-900"><%- amt(e.wage) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Posición de caja estimada mes a mes -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="text-sm font-bold text-slate-800 mb-4">Posición de Caja Estimada — Próximos 3 Meses</h3>
    <p class="text-xs text-slate-400 mb-4">CXC cobrable + cotizaciones enviadas vs CXP a pagar + nómina comprometida</p>
    <div class="grid grid-cols-3 gap-4">
      <% nextMonthsPayroll.forEach(function(m, idx) {
        const inflow  = idx === 0 ? cashInflow.d30  : idx === 1 ? cashInflow.d60  : cashInflow.d90;
        const cxpOut  = idx === 0 ? cashOutflow.d30 : idx === 1 ? cashOutflow.d60 : cashOutflow.d90;
        const payOut  = m.salary;
        const totalOut = cxpOut + payOut;
        const net = inflow - totalOut;
      %>
      <div class="rounded-xl border-2 <%= net >= 0 ? 'border-emerald-300 bg-emerald-50' : 'border-red-300 bg-red-50' %> p-4">
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-2"><%= m.label %></div>
        <div class="text-2xl font-black mb-3 <%= net >= 0 ? 'text-emerald-700' : 'text-red-600' %>"><%- amt(net) %></div>
        <div class="space-y-1 text-xs">
          <div class="flex justify-between text-emerald-700"><span>+ CXC a cobrar</span><span class="font-semibold"><%- amt(inflow) %></span></div>
          <div class="flex justify-between text-slate-500"><span>− CXP a pagar</span><span class="font-semibold"><%- amt(-cxpOut) %></span></div>
          <div class="flex justify-between text-orange-600"><span>− Nómina</span><span class="font-semibold"><%- amt(-payOut) %></span></div>
          <div class="border-t border-slate-200 pt-1 flex justify-between font-bold <%= net >= 0 ? 'text-emerald-700' : 'text-red-600' %>">
            <span>Neto</span><span><%- amt(net) %></span>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- CXP detail table -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <div class="bg-white rounded-xl border border-orange-200 overflow-hidden">
      <div class="bg-orange-50 border-b border-orange-200 px-5 py-2.5">
        <h3 class="text-sm font-bold text-orange-800">Cuentas por Pagar — Detalle</h3>
        <p class="text-xs text-orange-600 mt-0.5"><%= cxp.count %> facturas · <%- amt(cxp.total) %></p>
      </div>
      <div class="overflow-x-auto" style="max-height:300px;overflow-y:auto">
        <table class="w-full text-xs">
          <thead class="sticky top-0 bg-orange-50 border-b border-orange-100">
            <tr>
              <th class="text-left px-4 py-2.5 font-semibold text-slate-600">Proveedor</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Vcto.</th>
              <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Pendiente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% cxp.items.slice(0, 50).forEach(function(inv) { %>
            <tr class="border-b border-slate-50 hover:bg-orange-50/30 transition">
              <td class="px-4 py-2 font-medium text-slate-700 truncate max-w-[140px]" title="<%= inv.partner %>"><%= inv.partner %></td>
              <td class="px-3 py-2 text-center text-slate-500"><%= inv.dueDate || '—' %></td>
              <td class="px-4 py-2 text-right font-bold <%= inv.daysOverdue > 0 ? 'text-red-600' : 'text-orange-600' %>"><%- amt(inv.residual) %></td>
              <td class="px-3 py-2 text-center">
                <% if (inv.daysOverdue > 0) { %>
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-100 text-red-700"><%= inv.daysOverdue %>d</span>
                <% } else { %>
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-semibold bg-emerald-100 text-emerald-700">Al día</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% if (cxp.items.length === 0) { %>
            <tr><td colspan="4" class="py-8 text-center text-slate-400">Sin facturas de proveedores pendientes</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CXP aging buckets -->
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h3 class="text-sm font-bold text-slate-800 mb-4">Aging Proveedores</h3>
      <div style="height:200px"><canvas id="chartCxpDonut"></canvas></div>
      <div id="cxpDonutLegend" class="mt-3 space-y-1.5 text-xs"></div>
    </div>
  </div>

</div><!-- /tab-cashflow -->


<!-- ══════════════════════════════════════════════════════════════════════════
     TAB: PROYECCIÓN DE CIERRE
═══════════════════════════════════════════════════════════════════════════ -->
<div id="tab-proyeccion" class="hidden max-w-7xl mx-auto px-4 py-6 space-y-6">

  <div>
    <h2 class="text-xl font-extrabold text-slate-900">Proyección de Cierre — Proyectos Activos</h2>
    <p class="text-xs text-slate-400 mt-0.5">Estimado basado en horas restantes × USD 35/h × tipo de cambio. Solo proyectos no completados con presupuesto de horas.</p>
  </div>

  <% if (projectForecast && projectForecast.items && projectForecast.items.length > 0) { %>

  <!-- Summary KPIs -->
  <div class="grid grid-cols-2 gap-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mb-1">Horas Pendientes</div>
      <div class="text-3xl font-black text-slate-900"><%= projectForecast.totalRemainingHours %>h</div>
      <div class="text-xs text-slate-400 mt-1"><%= projectForecast.items.length %> proyectos activos</div>
    </div>
    <div class="bg-white rounded-xl border border-emerald-200 p-5">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Ingreso Estimado</div>
      <div class="text-3xl font-black text-emerald-700"><%- amt(projectForecast.totalForecastPyg) %></div>
      <div class="text-xs text-slate-400 mt-1">USD 35/h × <%= (usdRate || 7500).toLocaleString('es-PY') %> PYG/USD</div>
    </div>
  </div>

  <!-- Projects table -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="bg-slate-50 border-b border-slate-200 px-5 py-2.5 flex items-center justify-between">
      <span class="text-xs font-extrabold text-slate-700 uppercase tracking-wide">Detalle por Proyecto</span>
      <span class="text-xs text-slate-400"><%= projectForecast.items.length %> proyectos</span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="border-b border-slate-100 bg-slate-50 sticky top-0">
          <tr>
            <th class="text-left px-5 py-2.5 font-bold text-slate-600">Proyecto</th>
            <th class="text-left px-4 py-2.5 font-bold text-slate-500">Cliente</th>
            <th class="text-right px-4 py-2.5 font-bold text-slate-500">Horas Usadas</th>
            <th class="text-right px-4 py-2.5 font-bold text-slate-500">Horas Restantes</th>
            <th class="text-right px-4 py-2.5 font-bold text-emerald-700">Ingreso Estimado</th>
          </tr>
        </thead>
        <tbody>
          <% projectForecast.items.forEach(function(p) {
               const barPct = Math.min(100, p.hoursPct || 0);
               const barColor = p.rag === 'red' ? 'bg-red-500' : p.rag === 'amber' ? 'bg-amber-400' : 'bg-emerald-500';
               const pctColor = p.rag === 'red' ? 'text-red-600 font-bold' : p.rag === 'amber' ? 'text-amber-600 font-semibold' : 'text-emerald-600';
             %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="px-5 py-3 font-semibold text-slate-800 max-w-xs truncate"><%= p.name %></td>
            <td class="px-4 py-3 text-slate-500 max-w-[160px] truncate"><%= p.client || '—' %></td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <div class="w-20 bg-slate-100 rounded-full h-2 flex-none">
                  <div class="<%= barColor %> h-2 rounded-full" style="width:<%= barPct %>%"></div>
                </div>
                <span class="<%= pctColor %> w-10 text-right"><%= p.hoursPct !== null ? p.hoursPct + '%' : '—' %></span>
              </div>
              <div class="text-slate-400 text-right mt-0.5"><%= p.totalLog %>/<%= p.totalAlloc %>h</div>
            </td>
            <td class="px-4 py-3 text-right font-bold text-slate-700"><%= p.remaining %>h</td>
            <td class="px-4 py-3 text-right font-bold text-emerald-700"><%- amt(p.estimatedRevenuePyg) %></td>
          </tr>
          <% }); %>
        </tbody>
        <tfoot class="border-t-2 border-slate-200 bg-slate-50">
          <tr>
            <td class="px-5 py-3 font-extrabold text-slate-700" colspan="3">Total</td>
            <td class="px-4 py-3 text-right font-extrabold text-slate-800"><%= projectForecast.totalRemainingHours %>h</td>
            <td class="px-4 py-3 text-right font-extrabold text-emerald-700"><%- amt(projectForecast.totalForecastPyg) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <% } else { %>
  <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
    <div class="text-slate-500 font-medium">No hay proyectos activos con horas pendientes</div>
    <div class="text-xs text-slate-400 mt-1">Los proyectos completos o sin presupuesto de horas no aparecen aquí</div>
  </div>
  <% } %>

</div><!-- /tab-proyeccion -->


<div class="text-center text-xs text-slate-400 py-6 flex items-center justify-center gap-3">
  <span>Torus Finanzas · Datos al <%= lastUpdate %> · Cache: 1h financiero · 15min CXC</span>
  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-slate-100 font-mono text-slate-500"
        title="Deploy: <%= appDeployAt %>">
    v<%= appVersion %>
  </span>
</div>

<!-- ── Scripts ──────────────────────────────────────────────────────────── -->
<script>
<%
  const _finData = JSON.stringify({
    labels:   fin.months.map(m => m.label),
    revenue:  fin.months.map(m => m.revenue),
    cost:     fin.months.map(m => m.cost),
    margin:   fin.months.map(m => m.marginPct),
    ingRows: fin.eerrRows.filter(r => r.totalRevenue > 0)
      .sort((a,b) => b.totalRevenue - a.totalRevenue)
      .map(r => ({ name: r.name, totalRevenue: r.totalRevenue, totalCost: r.totalCost, marginPct: r.marginPct,
                   months: r.months.map(m => ({ revenue: m.revenue, cost: m.cost })) })),
  });
  const _cxcData  = JSON.stringify({ buckets: cxc.buckets, total: cxc.total, items: cxc.items });
  const _cxpData  = JSON.stringify({ buckets: cxp.buckets, total: cxp.total });
  const _clientData = JSON.stringify(clients.clients.slice(0, 20).map(c => ({
    name: c.name.length > 28 ? c.name.slice(0,28)+'…' : c.name,
    revenue: c.revenue, revPct: c.revPct, unpaid: c.unpaid, dso: c.dso,
  })));
  const _svcData = JSON.stringify(
    fin.eerrRows.filter(r => r.totalRevenue > 0 && /^\[/.test(r.name))
      .map(r => ({ name: r.name.replace(/[\[\]]/g,''), revenue: r.totalRevenue, marginPct: r.marginPct }))
  );
  const _yoyData = JSON.stringify({
    labels: yoy.prevMonths.map(m => m.label),
    revenue: yoy.prevMonths.map(m => m.revenue),
  });
%>

(function() {
  const fin     = <%- _finData %>;
  const cxc     = <%- _cxcData %>;
  const cxpData = <%- _cxpData %>;
  const clientData = <%- _clientData %>;
  const svcData = <%- _svcData %>;
  const yoyData = <%- _yoyData %>;
  // ── Currency switch ──────────────────────────────────────────────────────
  const _USD_RATE = <%- usdRate || 7500 %>;
  let _currency = localStorage.getItem('fin_currency') || 'pyg';

  function _fmtCur(pyg, compact) {
    if (_currency === 'usd') {
      const usd = Math.abs(pyg || 0) / _USD_RATE;
      if (compact) {
        if (usd >= 1e6) return '$\u00A0' + (usd/1e6).toFixed(1) + 'M';
        if (usd >= 1e3) return '$\u00A0' + Math.round(usd/1e3) + 'K';
        return '$\u00A0' + usd.toFixed(0);
      }
      return '$\u00A0' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(usd);
    } else {
      const abs = Math.abs(pyg || 0);
      if (compact) {
        if (abs >= 1e9) return 'Gs.\u00A0' + (abs/1e9).toFixed(1) + 'B';
        if (abs >= 1e6) return 'Gs.\u00A0' + (abs/1e6).toFixed(1) + 'M';
        if (abs >= 1e3) return 'Gs.\u00A0' + Math.round(abs/1e3) + 'K';
        return 'Gs.\u00A0' + Math.round(abs);
      }
      return 'Gs.\u00A0' + new Intl.NumberFormat('es-PY', { maximumFractionDigits: 0 }).format(abs);
    }
  }

  window.switchCurrency = function(cur) {
    _currency = cur;
    localStorage.setItem('fin_currency', cur);
    // Update all tagged amount spans
    document.querySelectorAll('.c-amt').forEach(el => {
      const pyg     = parseFloat(el.dataset.pyg || 0);
      const compact = el.classList.contains('c-amt-compact');
      el.textContent = _fmtCur(pyg, compact || el.textContent.includes('M') || el.textContent.includes('K'));
    });
    // Update toggle button styles
    const btnPyg = document.getElementById('cur-btn-pyg');
    const btnUsd = document.getElementById('cur-btn-usd');
    [btnPyg, btnUsd].forEach(btn => {
      if (!btn) return;
      const active = btn.id === 'cur-btn-' + cur;
      btn.className = active
        ? 'px-2.5 py-1 rounded-md text-[11px] font-bold transition-all bg-white text-slate-700 shadow-sm border border-slate-200'
        : 'px-2.5 py-1 rounded-md text-[11px] font-bold transition-all text-slate-400 hover:text-slate-600';
    });
    // Re-render visible charts with new currency
    _reinitVisibleCharts();
  };

  function _reinitVisibleCharts() {
    // Destroy and re-init charts that are currently visible
    Object.keys(chartsInited).forEach(name => {
      chartsInited[name] = false; // mark as stale
    });
    // Re-init the currently active tab's charts
    const activeTab = document.querySelector('[id^="tab-"]:not(.hidden)');
    if (activeTab) {
      const tabName = activeTab.id.replace('tab-', '');
      chartsInited[tabName] = false;
      Chart.helpers.each(Chart.instances, c => c.destroy()); // destroy all chart instances
      initTabCharts(tabName);
      chartsInited[tabName] = true;
    }
  }

  // Proxy: fmt/fmtM now respect current currency
  const fmt  = n => _fmtCur(n, false);
  const fmtM = n => {
    const abs = Math.abs(n||0);
    if (_currency === 'usd') {
      const usd = abs / _USD_RATE;
      if (usd >= 1e6) return (usd/1e6).toFixed(1) + 'M';
      if (usd >= 1e3) return Math.round(usd/1e3) + 'K';
      return usd.toFixed(0);
    }
    if (abs >= 1e9) return (abs/1e9).toFixed(1) + ' B';
    if (abs >= 1e6) return (abs/1e6).toFixed(1) + ' M';
    if (abs >= 1e3) return Math.round(abs/1e3) + ' K';
    return String(Math.round(abs));
  };

  const PALETTE = [
    '#3B82F6','#10B981','#8B5CF6','#F59E0B','#EF4444',
    '#06B6D4','#F97316','#EC4899','#84CC16','#6B7280'
  ];

  const chartsInited = {};

  // ── Date picker toggle ────────────────────────────────────────────────────
  window.toggleFinPicker = function() {
    const panel = document.getElementById('finPickerPanel');
    if (panel) panel.classList.toggle('hidden');
  };
  document.addEventListener('click', function(e) {
    const picker = document.getElementById('finDatePicker');
    if (picker && !picker.contains(e.target)) {
      document.getElementById('finPickerPanel')?.classList.add('hidden');
    }
  });

  // ── Filter loader ─────────────────────────────────────────────────────────
  function _showLoader() {
    const el = document.getElementById('finLoadingOverlay');
    if (el) el.classList.remove('hidden');
  }
  // Show loader on any filter link click (year, quarter, rolling presets, tab picker)
  document.getElementById('finPickerPanel')?.addEventListener('click', function(e) {
    const a = e.target.closest('a');
    if (a && a.href && !a.href.startsWith('javascript')) _showLoader();
  });
  // Show loader on custom range form submit
  document.querySelector('#finPickerPanel form')?.addEventListener('submit', _showLoader);
  // Hide loader if user hits back/popstate (browser nav)
  window.addEventListener('pageshow', function() {
    document.getElementById('finLoadingOverlay')?.classList.add('hidden');
  });

  // ── Rolling date presets ──────────────────────────────────────────────────
  (function() {
    const presets = [
      { label: 'Este mes',   months: 0 },
      { label: 'Últ. 3M',   months: 3 },
      { label: 'Últ. 6M',   months: 6 },
      { label: 'Últ. 12M',  months: 12 },
    ];
    const container = document.getElementById('rollingPresets');
    if (!container) return;
    const today = new Date();
    const curFrom = document.getElementById('pickerFrom')?.value;
    const curTo   = document.getElementById('pickerTo')?.value;
    presets.forEach(p => {
      const toDate   = new Date(today);
      toDate.setDate(today.getDate()); // today
      let fromDate;
      if (p.months === 0) {
        fromDate = new Date(today.getFullYear(), today.getMonth(), 1);
      } else {
        fromDate = new Date(today);
        fromDate.setMonth(today.getMonth() - p.months);
        fromDate.setDate(1);
      }
      const fromStr = fromDate.toISOString().slice(0, 10);
      const toStr   = toDate.toISOString().slice(0, 10);
      const isActive = curFrom === fromStr && curTo === toStr;
      const a = document.createElement('a');
      a.href = `/finanzas?from=${fromStr}&to=${toStr}`;
      a.textContent = p.label;
      a.className = 'px-2.5 py-1 rounded-lg border text-xs font-semibold transition-colors ' +
        (isActive ? 'bg-blue-600 text-white border-blue-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-600');
      a.addEventListener('click', _showLoader);
      container.appendChild(a);
    });
  })();

  // ── Client search filter ─────────────────────────────────────────────────
  window.filterClients = function(q) {
    const term = (q || '').toLowerCase().trim();
    const rows = document.querySelectorAll('.client-row');
    let visible = 0;
    rows.forEach(tr => {
      const name = tr.dataset.name || '';
      const show = !term || name.includes(term);
      tr.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    const counter = document.getElementById('clientCount');
    if (counter) counter.textContent = visible + (visible === 1 ? ' cliente' : ' clientes') + (term ? ' encontrado' + (visible === 1 ? '' : 's') : ' activos');
  };

  // ── Service line filter ───────────────────────────────────────────────────
  window.filterSvcLines = function(q) {
    const term = (q || '').toLowerCase().trim();
    document.querySelectorAll('.svc-row').forEach(tr => {
      const name = tr.dataset.name || '';
      tr.classList.toggle('hidden', !!(term && !name.includes(term)));
    });
  };

  // ── EERR group toggle ─────────────────────────────────────────────────────
  window.eerrToggle = function(gId) {
    const rows = document.querySelectorAll('.' + gId + '-row');
    const icon = document.getElementById(gId + '-icon');
    const open = rows[0] && !rows[0].classList.contains('hidden');
    rows.forEach(r => r.classList.toggle('hidden', open));
    if (icon) icon.style.transform = open ? '' : 'rotate(0deg)';
  };

  // ── Tab switching ──────────────────────────────────────────────────────────
  window.switchTab = function(name) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    const tabEl = document.getElementById('tab-' + name);
    if (tabEl) tabEl.classList.remove('hidden');
    const btn = document.querySelector(`.tab-btn[data-tab="${name}"]`);
    if (btn) btn.classList.add('active');
    if (!chartsInited[name]) { chartsInited[name] = true; initTabCharts(name); }
  };

  function initTabCharts(name) {
    if (name === 'resumen')   { initMonthlyChart(); initDonutChart(); }
    if (name === 'margenes')  { initHBarChart(); initStackedChart(); }
    if (name === 'cxc')       { initCxcDonut(); }
    if (name === 'clientes')  { initClientDonut(); initClientBar(); }
    if (name === 'productos') { initProductDonut(); initProductBar(); }
    if (name === 'cashflow')  { initCxpDonut(); }
  }

  // ── Client charts ──────────────────────────────────────────────────────────
  function initClientDonut() {
    const ctx = document.getElementById('chartClientDonut');
    if (!ctx || !clientData.length) return;
    const top = clientData.slice(0, 8);
    const otherRev = clientData.slice(8).reduce((s, c) => s + c.revenue, 0);
    const labels = [...top.map(c => c.name)];
    const data   = [...top.map(c => c.revenue)];
    if (otherRev > 0) { labels.push('Otros'); data.push(otherRev); }
    const colors = [...PALETTE, '#94a3b8'];
    new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors.slice(0,data.length), borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
      options: {
        responsive:true, maintainAspectRatio:false, cutout:'60%',
        plugins: {
          legend: { display:false },
          tooltip: { callbacks: { label: c => ` ${c.label}: ${fmtM(c.raw)} (${c.dataset.data.reduce((a,b)=>a+b,0)>0?Math.round(c.raw/c.dataset.data.reduce((a,b)=>a+b,0)*100):0}%)` } },
        },
      },
    });
    const legendEl = document.getElementById('clientDonutLegend');
    if (legendEl) legendEl.innerHTML = labels.map((lbl,i) =>
      `<div class="flex items-center justify-between gap-2">
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm shrink-0 inline-block" style="background:${colors[i]}"></span><span class="text-[11px] text-slate-600 truncate">${lbl}</span></span>
        <span class="text-[11px] font-semibold text-slate-700 shrink-0">${fmtM(data[i])}</span>
      </div>`
    ).join('');
  }

  function initClientBar() {
    const ctx = document.getElementById('chartClientBar');
    if (!ctx || !clientData.length) return;
    const top = clientData.slice(0, 10);
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: top.map(c => c.name),
        datasets: [
          { label: 'Revenue', data: top.map(c => c.revenue), backgroundColor: 'rgba(16,185,129,0.75)', borderRadius:4 },
          { label: 'Pendiente', data: top.map(c => c.unpaid), backgroundColor: 'rgba(245,158,11,0.6)', borderRadius:4 },
        ],
      },
      options: {
        indexAxis: 'y', responsive:true, maintainAspectRatio:false,
        interaction: { mode:'index', intersect:false },
        plugins: { legend:{ position:'top', labels:{ font:{size:11}, padding:10 } }, tooltip:{ callbacks:{ label: c => ` ${c.dataset.label}: ${fmt(c.raw)}` } } },
        scales: { x:{ ticks:{ font:{size:10}, callback: v => fmtM(v) } }, y:{ ticks:{ font:{size:11} }, grid:{ display:false } } },
      },
    });
  }

  // ── Product charts ─────────────────────────────────────────────────────────
  function initProductDonut() {
    const ctx = document.getElementById('chartProductDonut');
    if (!ctx || !svcData.length) return;
    const labels = svcData.map(s => s.name);
    const data   = svcData.map(s => s.revenue);
    const colors = PALETTE.slice(0, data.length);
    new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
      options: {
        responsive:true, maintainAspectRatio:false, cutout:'55%',
        plugins: { legend:{ display:false }, tooltip:{ callbacks:{ label: c => ` ${c.label}: ${fmtM(c.raw)}` } } },
      },
    });
    const legendEl = document.getElementById('productDonutLegend');
    if (legendEl) legendEl.innerHTML = labels.map((lbl,i) =>
      `<div class="flex items-center justify-between gap-2">
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm shrink-0 inline-block" style="background:${colors[i]}"></span><span class="text-[11px] text-slate-600 truncate">${lbl}</span></span>
        <span class="text-[11px] font-semibold text-slate-700 shrink-0">${fmtM(data[i])}</span>
      </div>`
    ).join('');
  }

  function initProductBar() {
    const ctx = document.getElementById('chartProductBar');
    if (!ctx || !svcData.length) return;
    new Chart(ctx, {
      data: {
        labels: svcData.map(s => s.name),
        datasets: [
          { type:'bar',  label:'Revenue',  data: svcData.map(s => s.revenue),    backgroundColor: PALETTE.map((c,i) => PALETTE[i]+'BB'), borderRadius:4, yAxisID:'y', order:2 },
          { type:'line', label:'Margen %', data: svcData.map(s => s.marginPct),  borderColor:'#1e293b', backgroundColor:'transparent', borderWidth:2.5, pointRadius:5, yAxisID:'yPct', order:1 },
        ],
      },
      options: {
        responsive:true, maintainAspectRatio:false,
        plugins: { legend:{ position:'top', labels:{ font:{size:11} } }, tooltip:{ callbacks:{ label: c => c.dataset.yAxisID==='yPct' ? ` Margen: ${c.raw}%` : ` Revenue: ${fmt(c.raw)}` } } },
        scales: {
          y:    { beginAtZero:true, ticks:{ callback: v => fmtM(v), font:{size:10} } },
          yPct: { position:'right', beginAtZero:false, grid:{ drawOnChartArea:false }, ticks:{ callback: v => v+'%', font:{size:10} } },
          x:    { ticks:{ font:{size:10} }, grid:{ display:false } },
        },
      },
    });
  }

  // ── CXP aging donut ────────────────────────────────────────────────────────
  function initCxpDonut() {
    const ctx = document.getElementById('chartCxpDonut');
    if (!ctx) return;
    const labels = ['Al día', '1–30 días', '31–60 días', '61–90 días', '+90 días'];
    const data   = [cxpData.buckets.current||0, cxpData.buckets.d1_30||0, cxpData.buckets.d31_60||0, cxpData.buckets.d61_90||0, cxpData.buckets.d90plus||0];
    const colors = ['#10B981','#F59E0B','#F97316','#EF4444','#F43F5E'];
    const total  = data.reduce((a,b) => a+b, 0);
    new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
      options: {
        responsive:true, maintainAspectRatio:false, cutout:'60%',
        plugins: { legend:{ display:false }, tooltip:{ callbacks:{ label: c => ` ${c.label}: ${fmtM(c.raw)} (${total>0?Math.round(c.raw/total*100):0}%)` } } },
      },
    });
    const legendEl = document.getElementById('cxpDonutLegend');
    if (legendEl) legendEl.innerHTML = labels.map((lbl,i) => data[i]>0 ? `
      <div class="flex items-center justify-between gap-2">
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm shrink-0 inline-block" style="background:${colors[i]}"></span><span class="text-[11px] text-slate-600">${lbl}</span></span>
        <span class="text-[11px] font-semibold text-slate-700">${fmtM(data[i])}</span>
      </div>` : '').join('');
  }

  // ── Monthly chart ──────────────────────────────────────────────────────────
  function initMonthlyChart() {
    const ctx = document.getElementById('chartMonthly');
    if (!ctx || !fin.labels.length) return;
    new Chart(ctx, {
      data: {
        labels: fin.labels,
        datasets: [
          { type:'bar',  label:'Ingresos',  data: fin.revenue, backgroundColor:'rgba(16,185,129,0.75)', borderColor:'rgb(16,185,129)', borderWidth:1, borderRadius:4, order:2 },
          { type:'bar',  label:'Costos',    data: fin.cost,    backgroundColor:'rgba(239,68,68,0.65)',  borderColor:'rgb(239,68,68)',  borderWidth:1, borderRadius:4, order:2 },
          { type:'line', label:'Margen %',  data: fin.margin,  borderColor:'rgb(59,130,246)', backgroundColor:'rgba(59,130,246,0.08)', borderWidth:2.5, pointRadius:4, tension:0.3, yAxisID:'yPct', order:1 },
        ],
      },
      options: {
        responsive:true, maintainAspectRatio:false,
        interaction:{ mode:'index', intersect:false },
        plugins:{
          legend:{ position:'top', labels:{ font:{size:11}, padding:12 } },
          tooltip:{ callbacks:{
            label: ctx => ctx.dataset.label === 'Margen %'
              ? ` Margen: ${ctx.raw !== null ? ctx.raw + '%' : '—'}`
              : ` ${ctx.dataset.label}: ${fmt(ctx.raw)}`,
          }},
        },
        scales:{
          x:{ grid:{ display:false }, ticks:{ font:{size:11} } },
          y:{ beginAtZero:true, ticks:{ font:{size:10}, callback: v => _fmtCur(v, true) } },
          yPct:{ position:'right', beginAtZero:false, grid:{ drawOnChartArea:false }, ticks:{ font:{size:10}, callback: v => v+'%' } },
        },
      },
    });
  }

  // ── Revenue donut ──────────────────────────────────────────────────────────
  function initDonutChart() {
    const ctx = document.getElementById('chartDonut');
    if (!ctx || !fin.ingRows.length) return;
    const top = fin.ingRows.slice(0, 8);
    const otherRev = fin.ingRows.slice(8).reduce((s,r) => s + r.totalRevenue, 0);
    const labels = [...top.map(r => r.name.length > 28 ? r.name.slice(0,28)+'…' : r.name)];
    const data   = [...top.map(r => r.totalRevenue)];
    if (otherRev > 0) { labels.push('Otros'); data.push(otherRev); }
    const colors = [...PALETTE, '#94a3b8'];

    new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors.slice(0, data.length), borderWidth: 2, borderColor: '#fff', hoverOffset: 6 }] },
      options: {
        responsive:true, maintainAspectRatio:false, cutout:'60%',
        plugins: {
          legend: { display:false },
          tooltip: { callbacks: { label: c => ` ${c.label}: ${fmtM(c.raw)} (${Math.round(c.raw / data.reduce((a,b) => a+b,0)*100)}%)` } },
        },
      },
    });

    // Custom legend
    const legendEl = document.getElementById('donutLegend');
    if (legendEl) {
      legendEl.innerHTML = labels.map((lbl, i) =>
        `<div class="flex items-center justify-between gap-2">
          <span class="flex items-center gap-1.5 truncate">
            <span class="w-2.5 h-2.5 rounded-sm shrink-0 inline-block" style="background:${colors[i]}"></span>
            <span class="text-[11px] text-slate-600 truncate">${lbl}</span>
          </span>
          <span class="text-[11px] font-semibold text-slate-700 shrink-0">${fmtM(data[i])}</span>
        </div>`
      ).join('');
    }
  }

  // ── Horizontal bar (revenue vs cost per account) ───────────────────────────
  function initHBarChart() {
    const ctx = document.getElementById('chartHBar');
    if (!ctx || !fin.ingRows.length) return;
    const rows = fin.ingRows;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: rows.map(r => r.name.length > 30 ? r.name.slice(0,30)+'…' : r.name),
        datasets: [
          { label:'Ingresos',      data: rows.map(r => r.totalRevenue), backgroundColor:'rgba(16,185,129,0.75)', borderRadius:3 },
          { label:'Costo Directo', data: rows.map(r => r.totalCost),    backgroundColor:'rgba(239,68,68,0.65)',  borderRadius:3 },
        ],
      },
      options: {
        indexAxis:'y', responsive:true, maintainAspectRatio:false,
        interaction:{ mode:'index', intersect:false },
        plugins:{ legend:{ position:'top', labels:{ font:{size:11}, padding:12 } }, tooltip:{ callbacks:{ label: c => ` ${c.dataset.label}: ${fmt(c.raw)}` } } },
        scales:{
          x:{ ticks:{ font:{size:10}, callback: v => v >= 1e6 ? (v/1e6).toFixed(0)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v } },
          y:{ ticks:{ font:{size:11} }, grid:{ display:false } },
        },
      },
    });
  }

  // ── Stacked revenue by account by month ───────────────────────────────────
  function initStackedChart() {
    const ctx = document.getElementById('chartStacked');
    if (!ctx || !fin.ingRows.length) return;
    const top6 = fin.ingRows.slice(0, 6);
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: fin.labels,
        datasets: top6.map((r, i) => ({
          label: r.name.length > 25 ? r.name.slice(0,25)+'…' : r.name,
          data:  r.months.map(m => m.revenue || null),
          backgroundColor: PALETTE[i],
          borderRadius: 2,
          stack: 'revenue',
        })),
      },
      options: {
        responsive:true, maintainAspectRatio:false,
        interaction:{ mode:'index', intersect:false },
        plugins:{ legend:{ position:'top', labels:{ font:{size:10}, padding:10 } }, tooltip:{ callbacks:{ label: c => ` ${c.dataset.label}: ${fmt(c.raw)}` } } },
        scales:{
          x:{ stacked:true, grid:{ display:false }, ticks:{ font:{size:11} } },
          y:{ stacked:true, beginAtZero:true, ticks:{ font:{size:10}, callback: v => v >= 1e6 ? (v/1e6).toFixed(0)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v } },
        },
      },
    });
  }

  // ── CXC aging donut ────────────────────────────────────────────────────────
  function initCxcDonut() {
    const ctx = document.getElementById('chartCxcDonut');
    if (!ctx) return;
    const labels = ['Al día', '1–30 días', '31–60 días', '61–90 días', '+90 días'];
    const data   = [cxc.buckets.current||0, cxc.buckets.d1_30||0, cxc.buckets.d31_60||0, cxc.buckets.d61_90||0, cxc.buckets.d90plus||0];
    const colors = ['#10B981','#F59E0B','#F97316','#EF4444','#F43F5E'];
    const total  = data.reduce((a,b) => a+b, 0);

    new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth:2, borderColor:'#fff', hoverOffset:6 }] },
      options: {
        responsive:true, maintainAspectRatio:false, cutout:'60%',
        plugins: {
          legend: { display:false },
          tooltip: { callbacks: { label: c => ` ${c.label}: ${fmtM(c.raw)} (${total > 0 ? Math.round(c.raw/total*100) : 0}%)` } },
        },
      },
    });

    const legendEl = document.getElementById('cxcDonutLegend');
    if (legendEl) {
      legendEl.innerHTML = labels.map((lbl, i) => data[i] > 0 ? `
        <div class="flex items-center justify-between gap-2">
          <span class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-sm shrink-0 inline-block" style="background:${colors[i]}"></span>
            <span class="text-[11px] text-slate-600">${lbl}</span>
          </span>
          <span class="text-[11px] font-semibold text-slate-700">${fmtM(data[i])}</span>
        </div>` : ''
      ).join('');
    }
  }

  // ── CSV export ─────────────────────────────────────────────────────────────
  window.exportCXCcsv = function() {
    const items = <%- cxcItemsJson %>;
    if (!items.length) { alert('Sin datos para exportar.'); return; }
    const headers = ['Factura','Cliente','Fecha Factura','Vencimiento','Días Vencida','Total','Pendiente','Bucket'];
    const rows = items.map(i => [i.name, i.partner, i.invoiceDate||'', i.dueDate||'', i.daysOverdue, i.total, i.residual, i.bucket]);
    const csv = [headers, ...rows].map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\r\n');
    const blob = new Blob(['\uFEFF' + csv], { type:'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a'); a.href = url;
    a.download = `CXC_Torus_${new Date().toISOString().slice(0,10)}.csv`;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
  };

  // Init first tab on load
  chartsInited['resumen'] = true;
  initMonthlyChart();
  initDonutChart();

  // Restore currency preference from localStorage
  if (_currency === 'usd') switchCurrency('usd');
  else switchCurrency('pyg');

})();
</script>
</body>
</html>
