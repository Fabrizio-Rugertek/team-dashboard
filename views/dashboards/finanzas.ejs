<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .kpi-delta-up   { color: #10b981; }
    .kpi-delta-down { color: #ef4444; }
    .aging-bar { transition: width .4s ease; }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

<%
  // ── Helpers ────────────────────────────────────────────────────────────
  const gs = n => '₲\u00A0' + new Intl.NumberFormat('es-PY', { maximumFractionDigits: 0 }).format(n || 0);
  const gsM = n => {
    const abs = Math.abs(n || 0);
    if (abs >= 1e9) return (n/1e9).toFixed(1) + ' B';
    if (abs >= 1e6) return (n/1e6).toFixed(1) + ' M';
    if (abs >= 1e3) return Math.round(n/1e3) + ' K';
    return String(Math.round(n || 0));
  };
  const pct = n => (n >= 0 ? '+' : '') + n + '%';
  const bucketLabel = { current: 'Al día', d1_30: '1–30 días', d31_60: '31–60 días', d61_90: '61–90 días', d90plus: '+90 días' };
  const bucketColor = { current: 'emerald', d1_30: 'amber', d31_60: 'orange', d61_90: 'red', d90plus: 'rose' };
  const stateLabel  = { draft: 'Borrador', sent: 'Enviada' };
  const stateColor  = { draft: 'slate', sent: 'blue' };
%>

<!-- ── Navbar ──────────────────────────────────────────────────────────── -->
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <img src="/img/torus-icon-green.png" alt="Torus" class="h-8 w-auto">

      <span class="text-slate-400 text-sm font-medium">/ Finanzas</span>
      <span class="text-slate-300">·</span>
      <a href="/"       class="text-sm font-medium text-blue-600 hover:text-blue-800">Inicio</a>
      <span class="text-slate-300">·</span>
      <a href="/equipo" class="text-sm font-medium text-blue-600 hover:text-blue-800">Equipo</a>
      <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <span class="text-slate-300">·</span>
      <a href="/admin/users" class="text-sm font-medium text-slate-500 hover:text-slate-700">Usuarios</a>
      <% } %>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1">
        <% for (let y = 2024; y <= new Date().getFullYear(); y++) { %>
        <a href="/finanzas?year=<%= y %>"
           class="px-3 py-1.5 rounded-lg border text-xs font-semibold transition-colors <%= y === year ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-slate-600 border-slate-200 hover:border-blue-300 hover:bg-blue-50' %>">
          <%= y %>
        </a>
        <% } %>
      </div>
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span><%= lastUpdate %></span>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="flex items-center gap-2 border-l border-slate-200 pl-3">
        <% if (user.picture) { %>
        <img src="<%= user.picture %>" class="w-7 h-7 rounded-full border border-slate-200" alt="">
        <% } else { %>
        <div class="w-7 h-7 bg-green-200 rounded-full flex items-center justify-center text-xs font-bold text-green-800">
          <%= (user.name||user.email).slice(0,1).toUpperCase() %>
        </div>
        <% } %>
        <span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span>
        <form action="/auth/logout" method="POST" class="inline">
          <button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">Salir</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">

  <!-- ── KPI Cards ───────────────────────────────────────────────────── -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4">

    <!-- Ingresos YTD -->
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Ingresos <%= year %></div>
      <div class="text-2xl font-black text-slate-900">₲ <%= gsM(fin.totalRevenue) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= gs(fin.totalRevenue) %></div>
      <% if (fin.curMonth.revDelta !== null) { %>
        <div class="text-xs mt-1 font-semibold <%= fin.curMonth.revDelta >= 0 ? 'kpi-delta-up' : 'kpi-delta-down' %>">
          <%= fin.curMonth.revDelta >= 0 ? '▲' : '▼' %> <%= Math.abs(fin.curMonth.revDelta) %>% vs mes ant.
        </div>
      <% } %>
    </div>

    <!-- Costos YTD -->
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Costos <%= year %></div>
      <div class="text-2xl font-black text-slate-900">₲ <%= gsM(fin.totalCost) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= gs(fin.totalCost) %></div>
      <div class="text-xs text-slate-400 mt-1">Facturas de proveedores</div>
    </div>

    <!-- Margen Bruto -->
    <div class="bg-white rounded-xl border-2 <%= fin.totalMargin >= 0 ? 'border-emerald-200' : 'border-red-200' %> p-4">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Margen Bruto</div>
      <div class="text-2xl font-black <%= fin.totalMargin >= 0 ? 'text-emerald-600' : 'text-red-500' %>">
        ₲ <%= gsM(fin.totalMargin) %>
      </div>
      <div class="text-xs mt-1 font-bold <%= fin.totalMargin >= 0 ? 'text-emerald-500' : 'text-red-500' %>">
        <%= fin.totalMargin >= 0 ? '+' : '' %><%= fin.marginPct %>% margen
      </div>
      <div class="text-xs text-amber-600 mt-1">⚠ Sin nómina</div>
    </div>

    <!-- CXC -->
    <div class="bg-white rounded-xl border-2 border-amber-200 p-4 cursor-pointer hover:bg-amber-50 transition" onclick="document.getElementById('secCXC').scrollIntoView({behavior:'smooth'})">
      <div class="text-xs font-semibold text-amber-600 uppercase tracking-wide mb-1">CXC Pendiente</div>
      <div class="text-2xl font-black text-amber-700">₲ <%= gsM(cxc.total) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= cxc.count %> facturas sin cobrar</div>
      <% const overdue = cxc.buckets.d1_30 + cxc.buckets.d31_60 + cxc.buckets.d61_90 + cxc.buckets.d90plus; %>
      <div class="text-xs text-red-500 font-semibold mt-1">₲ <%= gsM(overdue) %> vencido</div>
    </div>

    <!-- Pipeline -->
    <div class="bg-white rounded-xl border-2 border-blue-200 p-4 cursor-pointer hover:bg-blue-50 transition" onclick="document.getElementById('secPipeline').scrollIntoView({behavior:'smooth'})">
      <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-1">Pipeline</div>
      <div class="text-2xl font-black text-blue-700">₲ <%= gsM(pipeline.total) %></div>
      <div class="text-xs text-slate-400 mt-1"><%= pipeline.count %> cotizaciones abiertas</div>
      <div class="text-xs text-blue-500 font-semibold mt-1">₲ <%= gsM(pipeline.totalSent) %> enviadas</div>
    </div>

  </div>

  <!-- ── Gráfico mensual ─────────────────────────────────────────────── -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-slate-800">Ingresos vs Costos — <%= year %></h2>
      <div class="flex items-center gap-4 text-xs text-slate-500">
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-500 inline-block"></span>Ingresos</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-400 inline-block"></span>Costos</span>
        <span class="flex items-center gap-1.5"><span class="w-6 h-0.5 bg-blue-500 inline-block"></span>Margen %</span>
      </div>
    </div>
    <div style="height:260px">
      <canvas id="chartMonthly"></canvas>
    </div>
  </div>

  <!-- ── EERR Table ──────────────────────────────────────────────────── -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-bold text-slate-800">Estado de Resultados por Cuenta Analítica</h2>
        <p class="text-xs text-slate-400 mt-0.5">Ingresos (facturas emitidas) y Costos (facturas de proveedores) taggeados por cuenta analítica</p>
      </div>
      <span class="text-xs text-slate-400"><%= fin.eerrRows.length %> líneas</span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200 text-xs">
            <th class="text-left px-5 py-3 font-semibold text-slate-600 min-w-48">Cuenta Analítica</th>
            <th class="text-right px-3 py-3 font-semibold text-emerald-700">Ingresos</th>
            <th class="text-right px-3 py-3 font-semibold text-red-600">Costos</th>
            <th class="text-right px-3 py-3 font-semibold text-slate-700">Margen</th>
            <th class="text-right px-3 py-3 font-semibold text-slate-500">%</th>
            <% fin.months.forEach(m => { %><th class="text-right px-2 py-3 font-semibold text-slate-400"><%= m.label %></th><% }) %>
          </tr>
        </thead>
        <tbody>
          <% fin.eerrRows.forEach(row => {
            const mClass = row.margin >= 0 ? 'text-emerald-600 font-bold' : 'text-red-500 font-bold';
            const pClass = row.marginPct >= 0 ? 'text-emerald-500' : 'text-red-500';
          %>
          <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
            <td class="px-5 py-2.5 font-medium text-slate-800 text-xs"><%= row.name %></td>
            <td class="text-right px-3 py-2.5 text-emerald-700 text-xs"><%= gsM(row.totalRevenue) %></td>
            <td class="text-right px-3 py-2.5 text-red-600 text-xs"><%= gsM(row.totalCost) %></td>
            <td class="text-right px-3 py-2.5 text-xs <%= mClass %>"><%= gsM(row.margin) %></td>
            <td class="text-right px-3 py-2.5 text-xs <%= pClass %>"><%= row.marginPct %>%</td>
            <% row.months.forEach(m => {
              const hasRev = m.revenue > 0;
              const hasCost = m.cost > 0;
              const cellClass = hasRev ? 'text-emerald-600' : hasCost ? 'text-red-500' : 'text-slate-200';
              const val = hasRev ? gsM(m.revenue) : hasCost ? gsM(m.cost) : '';
            %>
            <td class="text-right px-2 py-2.5 text-xs <%= cellClass %>" title="<%= m.label %>: Rev ₲<%= m.revenue.toLocaleString() %> | Cost ₲<%= m.cost.toLocaleString() %>">
              <%= val %>
            </td>
            <% }) %>
          </tr>
          <% }) %>

          <!-- Totals row -->
          <tr class="bg-slate-50 border-t-2 border-slate-300 font-bold text-xs">
            <td class="px-5 py-3 font-extrabold text-slate-900">TOTAL</td>
            <td class="text-right px-3 py-3 text-emerald-700"><%= gsM(fin.totalRevenue) %></td>
            <td class="text-right px-3 py-3 text-red-600"><%= gsM(fin.totalCost) %></td>
            <td class="text-right px-3 py-3 <%= fin.totalMargin >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%= gsM(fin.totalMargin) %></td>
            <td class="text-right px-3 py-3 <%= fin.totalMargin >= 0 ? 'text-emerald-500' : 'text-red-500' %>"><%= fin.marginPct %>%</td>
            <% fin.months.forEach(m => { %>
            <td class="text-right px-2 py-3 <%= m.revenue > 0 ? 'text-emerald-600' : 'text-slate-300' %>">
              <%= m.revenue > 0 ? gsM(m.revenue) : '' %>
            </td>
            <% }) %>
          </tr>

          <% if (fin.eerrRows.length === 0) { %>
          <tr><td colspan="17" class="py-12 text-center text-slate-400">Sin datos para <%= year %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% if (fin.note) { %>
    <div class="px-5 py-3 bg-amber-50 border-t border-amber-100 text-xs text-amber-700">⚠ <%= fin.note %></div>
    <% } %>
  </div>

  <!-- ── CXC ─────────────────────────────────────────────────────────── -->
  <div id="secCXC">
    <div class="flex items-center gap-3 mb-4">
      <h2 class="text-xl font-extrabold text-slate-900">Cuentas por Cobrar</h2>
      <span class="bg-amber-100 text-amber-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= cxc.count %> facturas · ₲ <%= gsM(cxc.total) %></span>
    </div>

    <!-- Aging buckets -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-4">
      <%
        const agingCfg = [
          { key: 'current', label: 'Al día',      color: 'emerald', icon: '✅' },
          { key: 'd1_30',   label: '1–30 días',   color: 'amber',   icon: '🟡' },
          { key: 'd31_60',  label: '31–60 días',  color: 'orange',  icon: '🟠' },
          { key: 'd61_90',  label: '61–90 días',  color: 'red',     icon: '🔴' },
          { key: 'd90plus', label: '+90 días',     color: 'rose',    icon: '💀' },
        ];
        agingCfg.forEach(cfg => {
          const amount = cxc.buckets[cfg.key] || 0;
          const pctOfTotal = cxc.total > 0 ? Math.round(amount / cxc.total * 100) : 0;
      %>
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-xl mb-1"><%= cfg.icon %></div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1"><%= cfg.label %></div>
        <div class="text-xl font-black text-slate-900">₲ <%= gsM(amount) %></div>
        <div class="w-full bg-slate-100 rounded-full h-1.5 mt-2">
          <div class="aging-bar bg-<%= cfg.color %>-400 h-1.5 rounded-full" style="width:<%= pctOfTotal %>%"></div>
        </div>
        <div class="text-xs text-slate-400 mt-1"><%= pctOfTotal %>% del total</div>
      </div>
      <% }) %>
    </div>

    <!-- CXC Table -->
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-semibold text-slate-700">Detalle de facturas</span>
      <button onclick="exportCXCcsv()"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-xs font-semibold text-slate-600 hover:border-blue-300 hover:bg-blue-50 transition-colors">
        ↓ Exportar CSV
      </button>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto max-h-72 overflow-y-auto">
        <table class="w-full text-sm">
          <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
            <tr class="text-xs">
              <th class="text-left px-4 py-2.5 font-semibold text-slate-600">Factura</th>
              <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Cliente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Vencimiento</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Días vencida</th>
              <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Pendiente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% cxc.items.forEach(inv => {
              const isOverdue = inv.daysOverdue > 0;
              const rowBg = inv.bucket === 'd90plus' ? 'bg-red-50' : inv.bucket === 'd61_90' ? 'bg-orange-50' : '';
            %>
            <tr class="border-b border-slate-50 hover:bg-slate-50 transition <%= rowBg %>">
              <td class="px-4 py-2 text-xs font-mono text-slate-700"><%= inv.name %></td>
              <td class="px-3 py-2 text-xs font-medium text-slate-800 max-w-xs truncate"><%= inv.partner %></td>
              <td class="px-3 py-2 text-xs text-center <%= isOverdue ? 'text-red-600 font-semibold' : 'text-slate-500' %>"><%= inv.dueDate || '—' %></td>
              <td class="px-3 py-2 text-center">
                <% if (inv.daysOverdue > 0) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold
                    <%= inv.bucket === 'd90plus' ? 'bg-rose-100 text-rose-700' : inv.bucket === 'd61_90' ? 'bg-red-100 text-red-700' : inv.bucket === 'd31_60' ? 'bg-orange-100 text-orange-700' : 'bg-amber-100 text-amber-700' %>">
                    <%= inv.daysOverdue %>d
                  </span>
                <% } else { %>
                  <span class="text-xs text-emerald-500">Al día</span>
                <% } %>
              </td>
              <td class="px-4 py-2 text-right text-xs font-bold text-slate-900"><%= gs(inv.residual) %></td>
              <td class="px-3 py-2 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                  <%= inv.bucket === 'current' ? 'Vigente' : 'Vencida' %>
                </span>
              </td>
            </tr>
            <% }) %>
            <% if (cxc.items.length === 0) { %>
            <tr><td colspan="6" class="py-8 text-center text-slate-400">Sin facturas pendientes ✅</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── Pipeline ────────────────────────────────────────────────────── -->
  <div id="secPipeline">
    <div class="flex items-center gap-3 mb-4">
      <h2 class="text-xl font-extrabold text-slate-900">Pipeline Comercial</h2>
      <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= pipeline.count %> cotizaciones · ₲ <%= gsM(pipeline.total) %></span>
    </div>

    <!-- Pipeline summary -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Total Pipeline</div>
        <div class="text-2xl font-black text-blue-700">₲ <%= gsM(pipeline.total) %></div>
        <div class="text-xs text-slate-400 mt-1"><%= pipeline.count %> cotizaciones</div>
      </div>
      <div class="bg-white rounded-xl border border-blue-200 p-4">
        <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-1">Enviadas</div>
        <div class="text-2xl font-black text-blue-700">₲ <%= gsM(pipeline.totalSent) %></div>
        <div class="text-xs text-slate-400 mt-1"><%= pipeline.countSent %> cotiz. · esperando respuesta</div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Borradores</div>
        <div class="text-2xl font-black text-slate-700">₲ <%= gsM(pipeline.totalDraft) %></div>
        <div class="text-xs text-slate-400 mt-1"><%= pipeline.countDraft %> cotiz. · sin enviar</div>
      </div>
      <div class="bg-white rounded-xl border border-emerald-200 p-4">
        <div class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">Tasa de Cierre</div>
        <% if (closingRate.rate !== null) { %>
        <div class="text-2xl font-black text-emerald-700"><%= closingRate.rate %>%</div>
        <div class="text-xs text-slate-400 mt-1"><%= closingRate.wonCount %> ganadas / <%= closingRate.totalCount %> elegibles</div>
        <% } else { %>
        <div class="text-2xl font-black text-slate-400">—</div>
        <div class="text-xs text-slate-400 mt-1">Sin datos suficientes</div>
        <% } %>
        <div class="text-xs text-slate-400 mt-0.5">Últimos <%= closingRate.period %></div>
      </div>
    </div>

    <!-- Pipeline Table -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto max-h-72 overflow-y-auto">
        <table class="w-full text-sm">
          <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
            <tr class="text-xs">
              <th class="text-left px-4 py-2.5 font-semibold text-slate-600">Cotización</th>
              <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Cliente</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Estado</th>
              <th class="text-right px-4 py-2.5 font-semibold text-slate-600">Monto</th>
              <th class="text-left px-3 py-2.5 font-semibold text-slate-600">Responsable</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Fecha</th>
              <th class="text-center px-3 py-2.5 font-semibold text-slate-600">Vence</th>
            </tr>
          </thead>
          <tbody>
            <% pipeline.items.forEach(o => { %>
            <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
              <td class="px-4 py-2 text-xs font-mono text-slate-700"><%= o.name %></td>
              <td class="px-3 py-2 text-xs font-medium text-slate-800 max-w-xs truncate"><%= o.partner %></td>
              <td class="px-3 py-2 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold
                  <%= o.state === 'sent' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
                  <%= o.state === 'sent' ? 'Enviada' : 'Borrador' %>
                </span>
              </td>
              <td class="px-4 py-2 text-right text-xs font-bold text-slate-900"><%= gs(o.amount) %></td>
              <td class="px-3 py-2 text-xs text-slate-500 max-w-xs truncate"><%= o.user %></td>
              <td class="px-3 py-2 text-xs text-center text-slate-500"><%= o.date || '—' %></td>
              <td class="px-3 py-2 text-xs text-center <%= o.validUntil && o.validUntil < new Date().toISOString().slice(0,10) ? 'text-red-500 font-semibold' : 'text-slate-500' %>">
                <%= o.validUntil || '—' %>
              </td>
            </tr>
            <% }) %>
            <% if (pipeline.items.length === 0) { %>
            <tr><td colspan="7" class="py-8 text-center text-slate-400">Sin cotizaciones abiertas</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="text-center text-xs text-slate-400 pb-6">
    Datos al <%= lastUpdate %> · Cache financiero: 1 hora · CXC: 15 min
  </div>

</div><!-- end max-w-7xl -->

<script>
<%
  const chartData = JSON.stringify({
    labels:   fin.months.map(m => m.label),
    revenue:  fin.months.map(m => m.revenue),
    cost:     fin.months.map(m => m.cost),
    margin:   fin.months.map(m => m.marginPct),
  });
%>
(function() {
  const d = <%- chartData %>;
  const fmt = n => '₲\u00A0' + new Intl.NumberFormat('es-PY', {maximumFractionDigits:0}).format(n||0);

  const ctx = document.getElementById('chartMonthly').getContext('2d');
  new Chart(ctx, {
    data: {
      labels: d.labels,
      datasets: [
        {
          type: 'bar',
          label: 'Ingresos',
          data: d.revenue,
          backgroundColor: 'rgba(16,185,129,0.75)',
          borderColor: 'rgb(16,185,129)',
          borderWidth: 1,
          borderRadius: 4,
          order: 2,
        },
        {
          type: 'bar',
          label: 'Costos',
          data: d.cost,
          backgroundColor: 'rgba(239,68,68,0.65)',
          borderColor: 'rgb(239,68,68)',
          borderWidth: 1,
          borderRadius: 4,
          order: 2,
        },
        {
          type: 'line',
          label: 'Margen %',
          data: d.margin,
          borderColor: 'rgb(59,130,246)',
          backgroundColor: 'rgba(59,130,246,0.1)',
          borderWidth: 2,
          pointRadius: 3,
          tension: 0.3,
          yAxisID: 'yPct',
          order: 1,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { position: 'top', labels: { font: { size: 11 }, padding: 12 } },
        tooltip: {
          callbacks: {
            label: ctx => {
              if (ctx.dataset.label === 'Margen %') {
                return ctx.raw !== null ? ` Margen: ${ctx.raw}%` : ' Margen: —';
              }
              return ` ${ctx.dataset.label}: ${fmt(ctx.raw)}`;
            },
          },
        },
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 } } },
        y: {
          beginAtZero: true,
          ticks: {
            font: { size: 10 },
            callback: v => {
              if (v >= 1e6) return '₲ ' + (v/1e6).toFixed(0) + 'M';
              if (v >= 1e3) return '₲ ' + (v/1e3).toFixed(0) + 'K';
              return '₲ ' + v;
            },
          },
        },
        yPct: {
          position: 'right',
          beginAtZero: false,
          grid: { drawOnChartArea: false },
          ticks: { font: { size: 10 }, callback: v => v + '%' },
        },
      },
    },
  });
})();

// ── CSV Export for CXC ─────────────────────────────────────────────────────────
function exportCXCcsv() {
  const items = <%- cxcItemsJson %>;
  if (!items.length) { alert('Sin datos para exportar.'); return; }
  const headers = ['Factura','Cliente','Fecha Factura','Vencimiento','Días Vencida','Total','Pendiente','Bucket'];
  const rows = items.map(i => [
    i.name, i.partner, i.invoiceDate || '', i.dueDate || '',
    i.daysOverdue, i.total, i.residual, i.bucket,
  ]);
  const csv = [headers, ...rows]
    .map(r => r.map(v => `"${String(v).replace(/"/g, '""')}"`).join(','))
    .join('\r\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = `CXC_${new Date().toISOString().slice(0,10)}.csv`;
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
}
</script>
</body>
</html>
