<!-- ── Hidden chart data ──────────────────────────────────────────────────── -->
<script id="crmChartData" type="application/json"><%- crmJSON %></script>

<script>
// ── Data ──────────────────────────────────────────────────────────────────────
const CRM = JSON.parse(document.getElementById('crmChartData').textContent);
const COLORS = ['#3b82f6','#6366f1','#14b8a6','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316','#10b981','#ef4444'];

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(name) {
  document.querySelectorAll('[id^="tab-"]:not([id^="tab-btn-"])')
    .forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('[id^="tab-btn-"]')
    .forEach(el => el.classList.remove('active'));
  const panel = document.getElementById('tab-' + name);
  const btn   = document.getElementById('tab-btn-' + name);
  if (panel) panel.classList.remove('hidden');
  if (btn)   btn.classList.add('active');
  // Keep hidden form input in sync so filters preserve tab
  const inp = document.getElementById('hiddenTab');
  if (inp) inp.value = name;
}

// ── Chart helpers ─────────────────────────────────────────────────────────────
function fmtGsJS(n) {
  if (!n || n === 0) return '₲ 0';
  if (n >= 1e9) return '₲ ' + (n / 1e9).toFixed(1) + 'B';
  if (n >= 1e6) return '₲ ' + Math.round(n / 1e6) + 'M';
  return '₲ ' + Math.round(n).toLocaleString('es-PY');
}

const CHART_DEFAULTS = {
  responsive: true,
  maintainAspectRatio: true,
  plugins: { legend: { labels: { font: { family: 'Inter', size: 11 }, boxWidth: 12, padding: 12 } } },
};

// ── Hunters bar chart ─────────────────────────────────────────────────────────
function initHunterCharts() {
  const hunters = (CRM.byHunter || []).filter(h => h.name !== 'Sin Hunter').slice(0, 10);
  if (!hunters.length) return;

  const labels = hunters.map(h => h.name.split(' ')[0]);

  new Chart(document.getElementById('huntersBarChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Leads', data: hunters.map(h => h.leads), backgroundColor: '#93c5fd', borderRadius: 4 },
        { label: 'Won',   data: hunters.map(h => h.won),   backgroundColor: '#34d399', borderRadius: 4 },
      ],
    },
    options: {
      ...CHART_DEFAULTS,
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
    },
  });

  new Chart(document.getElementById('huntersRevenueChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Revenue Won',
        data: hunters.map(h => h.revenue || 0),
        backgroundColor: hunters.map((_, i) => COLORS[i % COLORS.length] + 'cc'),
        borderRadius: 4,
      }],
    },
    options: {
      ...CHART_DEFAULTS,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => fmtGsJS(ctx.raw) } } },
      scales: { y: { beginAtZero: true, ticks: { callback: v => v >= 1e6 ? Math.round(v/1e6)+'M' : v } } },
    },
  });
}

// ── Trend charts ──────────────────────────────────────────────────────────────
function initTrendCharts() {
  const trend = CRM.trendData || [];
  if (!trend.length) return;

  const labels  = trend.map(m => m.label);
  const created = trend.map(m => m.created);
  const won     = trend.map(m => m.won);
  const lost    = trend.map(m => m.lost);
  const revenue = trend.map(m => m.revenue || 0);

  new Chart(document.getElementById('trendVolumeChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Creados', data: created, backgroundColor: '#93c5fd', borderRadius: 3 },
        { label: 'Won',     data: won,     backgroundColor: '#34d399', borderRadius: 3 },
        { label: 'Lost',    data: lost,    backgroundColor: '#fca5a5', borderRadius: 3 },
      ],
    },
    options: {
      ...CHART_DEFAULTS,
      scales: { x: { stacked: false }, y: { beginAtZero: true, ticks: { stepSize: 1 } } },
    },
  });

  new Chart(document.getElementById('trendRevenueChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Revenue Won',
        data: revenue,
        backgroundColor: '#fbbf24',
        borderRadius: 4,
        type: 'bar',
      }],
    },
    options: {
      ...CHART_DEFAULTS,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => fmtGsJS(ctx.raw) } } },
      scales: { y: { beginAtZero: true, ticks: { callback: v => v >= 1e6 ? Math.round(v/1e6)+'M' : v } } },
    },
  });
}

// ── Sources doughnut ──────────────────────────────────────────────────────────
function initSourceChart() {
  const sources = (CRM.bySource || []).slice(0, 8);
  if (!sources.length) return;

  new Chart(document.getElementById('sourceDoughnut'), {
    type: 'doughnut',
    data: {
      labels: sources.map(s => s.name),
      datasets: [{
        data:            sources.map(s => s.count),
        backgroundColor: sources.map((_, i) => COLORS[i % COLORS.length]),
        borderWidth:     2,
        borderColor:     '#fff',
      }],
    },
    options: {
      ...CHART_DEFAULTS,
      cutout: '62%',
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 10, padding: 8 } },
        tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw} leads` } },
      },
    },
  });
}

// ── Init all on load ──────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  switchTab('<%= activeTab %>');
  initHunterCharts();
  initTrendCharts();
  initSourceChart();
});
</script>

</body>
</html>
