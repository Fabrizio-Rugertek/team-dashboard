<!-- ── Hidden chart data ──────────────────────────────────────────────────── -->
<script id="crmChartData" type="application/json"><%- crmJSON %></script>

<script>
// ── Current filter state ───────────────────────────────────────────────────────
const CRM    = JSON.parse(document.getElementById('crmChartData').textContent);
const COLORS = ['#3b82f6','#6366f1','#14b8a6','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316','#10b981','#ef4444'];

let currentRange  = '<%= af.range    || "all"      %>';
let currentFrom   = '<%= af.from     || ""         %>';
let currentTo     = '<%= af.to       || ""         %>';
let currentHunter = '<%= af.hunterId || ""         %>';
let currentCloser = '<%= af.closerId || ""         %>';
let currentSource = '<%= af.sourceId || ""         %>';
let currentStage  = '<%= af.stageId  || ""         %>';
let currentDType  = '<%= af.dateType || "created"  %>';
let currentTab    = '<%= activeTab %>';

// ── URL builder ───────────────────────────────────────────────────────────────
function buildFilterUrl(overrides) {
  overrides = overrides || {};
  const r   = overrides.range    !== undefined ? overrides.range    : currentRange;
  const f   = overrides.from     !== undefined ? overrides.from     : currentFrom;
  const t   = overrides.to       !== undefined ? overrides.to       : currentTo;
  const h   = overrides.hunter   !== undefined ? overrides.hunter   : currentHunter;
  const c   = overrides.closer   !== undefined ? overrides.closer   : currentCloser;
  const s   = overrides.source   !== undefined ? overrides.source   : currentSource;
  const st  = overrides.stage    !== undefined ? overrides.stage    : currentStage;
  const dt  = overrides.dateType !== undefined ? overrides.dateType : currentDType;
  const tab = overrides.tab      !== undefined ? overrides.tab      : currentTab;

  const p = new URLSearchParams();
  p.set('range', r || 'all');
  if (r === 'custom') {
    if (f) p.set('from', f);
    if (t) p.set('to',   t);
  }
  if (h)  p.set('hunter',   h);
  if (c)  p.set('closer',   c);
  if (s)  p.set('source',   s);
  if (st) p.set('stage',    st);
  if (dt && dt !== 'created') p.set('dateType', dt);
  if (tab) p.set('tab', tab);
  return '/crm?' + p.toString();
}

function applyFilter(key, value) {
  const o = {};
  o[key] = value;
  window.location.href = buildFilterUrl(o);
}

// Filter to a specific month (YYYY-MM) — used by Tendencia rows
function applyMonthFilter(month) {
  var from = month + '-01';
  var d    = new Date(month + '-01T00:00:00');
  d.setMonth(d.getMonth() + 1);
  d.setDate(0); // last day of the month
  var to = d.toISOString().slice(0, 10);
  window.location.href = buildFilterUrl({ range: 'custom', from: from, to: to });
}

// ── Date picker ───────────────────────────────────────────────────────────────
function toggleDatePicker() {
  document.getElementById('datePicker').classList.toggle('hidden');
}
function selectPreset(value) {
  document.querySelectorAll('.preset-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelectorAll('.preset-btn[data-range="' + value + '"]').forEach(function(b) { b.classList.add('active'); });
  if (value === 'custom') {
    document.getElementById('presetInfoPanel').classList.add('hidden');
    document.getElementById('customPanel').classList.remove('hidden');
  } else {
    document.getElementById('customPanel').classList.add('hidden');
    document.getElementById('presetInfoPanel').classList.remove('hidden');
    document.getElementById('datePicker').classList.add('hidden');
    window.location.href = buildFilterUrl({ range: value, from: null, to: null });
  }
}
function applyCustomDate() {
  var from = document.getElementById('customFrom').value;
  var to   = document.getElementById('customTo').value;
  if (!from || !to) return;
  window.location.href = buildFilterUrl({ range: 'custom', from: from, to: to });
}
document.addEventListener('click', function(e) {
  var wrap = document.getElementById('datePickerWrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('datePicker').classList.add('hidden');
  }
});

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(name) {
  document.querySelectorAll('[id^="tab-"]:not([id^="tab-btn-"])')
    .forEach(function(el) { el.classList.add('hidden'); });
  document.querySelectorAll('[id^="tab-btn-"]')
    .forEach(function(el) { el.classList.remove('active'); });
  var panel = document.getElementById('tab-' + name);
  var btn   = document.getElementById('tab-btn-' + name);
  if (panel) panel.classList.remove('hidden');
  if (btn)   btn.classList.add('active');
  currentTab = name;
}

// ── Chart helpers ─────────────────────────────────────────────────────────────
function fmtGsJS(n) {
  if (!n || n === 0) return '\u20b2 0';
  if (n >= 1e9) return '\u20b2 ' + (n / 1e9).toFixed(1) + 'B';
  if (n >= 1e6) return '\u20b2 ' + Math.round(n / 1e6) + 'M';
  return '\u20b2 ' + Math.round(n).toLocaleString('es-PY');
}
const CHART_DEFAULTS = {
  responsive: true,
  maintainAspectRatio: true,
  plugins: { legend: { labels: { font: { family: 'Inter', size: 11 }, boxWidth: 12, padding: 12 } } },
};

// ── Hunters charts — clicking a bar applies hunter filter ─────────────────────
function initHunterCharts() {
  var hunters = (CRM.byHunter || []).filter(function(h) { return h.name !== 'Sin Hunter'; }).slice(0, 10);
  if (!hunters.length) return;
  var labels = hunters.map(function(h) { return h.name.split(' ')[0]; });

  var barChart = new Chart(document.getElementById('huntersBarChart'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Leads', data: hunters.map(function(h) { return h.leads; }), backgroundColor: '#93c5fd', borderRadius: 4 },
        { label: 'Won',   data: hunters.map(function(h) { return h.won;   }), backgroundColor: '#34d399', borderRadius: 4 },
      ],
    },
    options: {
      ...CHART_DEFAULTS,
      onClick: function(evt, elements) {
        if (elements.length > 0) {
          var idx = elements[0].index;
          if (hunters[idx]) applyFilter('hunter', hunters[idx].id);
        }
      },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
    },
  });
  document.getElementById('huntersBarChart').style.cursor = 'pointer';

  var revChart = new Chart(document.getElementById('huntersRevenueChart'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Revenue Won',
        data: hunters.map(function(h) { return h.revenue || 0; }),
        backgroundColor: hunters.map(function(_, i) { return COLORS[i % COLORS.length] + 'cc'; }),
        borderRadius: 4,
      }],
    },
    options: {
      ...CHART_DEFAULTS,
      onClick: function(evt, elements) {
        if (elements.length > 0) {
          var idx = elements[0].index;
          if (hunters[idx]) applyFilter('hunter', hunters[idx].id);
        }
      },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return fmtGsJS(ctx.raw); } } } },
      scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return v >= 1e6 ? Math.round(v/1e6)+'M' : v; } } } },
    },
  });
  document.getElementById('huntersRevenueChart').style.cursor = 'pointer';
}

// ── Trend charts — clicking a bar applies month filter ────────────────────────
function initTrendCharts() {
  var trend = CRM.trendData || [];
  if (!trend.length) return;
  var labels  = trend.map(function(m) { return m.label; });
  var created = trend.map(function(m) { return m.created; });
  var won     = trend.map(function(m) { return m.won; });
  var lost    = trend.map(function(m) { return m.lost; });
  var revenue = trend.map(function(m) { return m.revenue || 0; });

  var volumeChart = new Chart(document.getElementById('trendVolumeChart'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Creados', data: created, backgroundColor: '#93c5fd', borderRadius: 3 },
        { label: 'Won',     data: won,     backgroundColor: '#34d399', borderRadius: 3 },
        { label: 'Lost',    data: lost,    backgroundColor: '#fca5a5', borderRadius: 3 },
      ],
    },
    options: {
      ...CHART_DEFAULTS,
      onClick: function(evt, elements) {
        if (elements.length > 0) {
          var idx = elements[0].index;
          if (trend[idx]) applyMonthFilter(trend[idx].month);
        }
      },
      scales: { x: { stacked: false }, y: { beginAtZero: true, ticks: { stepSize: 1 } } },
    },
  });
  document.getElementById('trendVolumeChart').style.cursor = 'pointer';

  var revenueChart = new Chart(document.getElementById('trendRevenueChart'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{ label: 'Revenue Won', data: revenue, backgroundColor: '#fbbf24', borderRadius: 4 }],
    },
    options: {
      ...CHART_DEFAULTS,
      onClick: function(evt, elements) {
        if (elements.length > 0) {
          var idx = elements[0].index;
          if (trend[idx]) applyMonthFilter(trend[idx].month);
        }
      },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return fmtGsJS(ctx.raw); } } } },
      scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return v >= 1e6 ? Math.round(v/1e6)+'M' : v; } } } },
    },
  });
  document.getElementById('trendRevenueChart').style.cursor = 'pointer';
}

// ── Sources doughnut — clicking a slice filters by source ─────────────────────
function initSourceChart() {
  var sources = (CRM.bySource || []).slice(0, 8);
  if (!sources.length) return;
  var chart = new Chart(document.getElementById('sourceDoughnut'), {
    type: 'doughnut',
    data: {
      labels: sources.map(function(s) { return s.name; }),
      datasets: [{
        data:            sources.map(function(s) { return s.count; }),
        backgroundColor: sources.map(function(_, i) { return COLORS[i % COLORS.length]; }),
        borderWidth:     2,
        borderColor:     '#fff',
      }],
    },
    options: {
      ...CHART_DEFAULTS,
      cutout: '62%',
      onClick: function(evt, elements) {
        if (elements.length > 0) {
          var idx = elements[0].index;
          if (sources[idx] && sources[idx].id) applyFilter('source', sources[idx].id);
        }
      },
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 10, padding: 8 } },
        tooltip: { callbacks: { label: function(ctx) { return ctx.label + ': ' + ctx.raw + ' leads'; } } },
      },
    },
  });
  document.getElementById('sourceDoughnut').style.cursor = 'pointer';
}

// ── Init on load ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  switchTab('<%= activeTab %>');
  initHunterCharts();
  initTrendCharts();
  initSourceChart();
});

// ── Opportunity detail panel ───────────────────────────────────────────────────
const TOP_ACTIVE = <%- JSON.stringify(crm.topActive || []) %>;

function openOppPanel(row) {
  const idx = parseInt(row.getAttribute('data-idx'), 10);
  const o   = TOP_ACTIVE[idx];
  if (!o) return;

  document.getElementById('oppName').textContent    = o.name;
  document.getElementById('oppOdooLink').href       = '<%= ODOO %>/odoo/crm/' + o.id;
  document.getElementById('oppRevenue').textContent = o.revenueFmt || '₲ 0';
  document.getElementById('oppHunter').textContent  = o.hunter || '—';
  document.getElementById('oppCloser').textContent  = o.closer || '—';
  document.getElementById('oppSource').textContent  = o.source || '—';

  const stageEl = document.getElementById('oppStage');
  stageEl.textContent = o.stage || '—';

  const daysEl = document.getElementById('oppDays');
  daysEl.textContent = o.daysOpen + ' días abierta';
  daysEl.className   = 'text-sm font-bold ' + (o.daysOpen > 90 ? 'text-amber-600' : o.daysOpen > 30 ? 'text-slate-600' : 'text-green-600');

  // Build quick-filter pills
  const qf = document.getElementById('oppQuickFilters');
  qf.innerHTML = '';
  const pills = [
    o.stageId   && { label: 'Etapa: '  + (o.stage  || ''),            key: 'stage',  val: o.stageId,  color: 'bg-blue-50 border-blue-200 text-blue-700 hover:bg-blue-100' },
    o.hunterId  && { label: 'Hunter: ' + (o.hunter || '').split(' ')[0], key: 'hunter', val: o.hunterId, color: 'bg-amber-50 border-amber-200 text-amber-700 hover:bg-amber-100' },
    o.closerId  && { label: 'Closer: ' + (o.closer || '').split(' ')[0], key: 'closer', val: o.closerId, color: 'bg-slate-50 border-slate-200 text-slate-700 hover:bg-slate-100' },
    o.sourceId  && { label: 'Origen: ' + (o.source || '').slice(0, 18), key: 'source', val: o.sourceId, color: 'bg-indigo-50 border-indigo-200 text-indigo-700 hover:bg-indigo-100' },
  ].filter(Boolean);

  pills.forEach(function(p) {
    const btn = document.createElement('button');
    btn.className = 'px-3 py-1.5 rounded-lg border text-xs font-semibold transition-colors ' + p.color;
    btn.textContent = p.label;
    btn.addEventListener('click', function() { closeOppPanel(); applyFilter(p.key, p.val); });
    qf.appendChild(btn);
  });

  // Highlight row
  document.querySelectorAll('[data-idx]').forEach(function(tr) { tr.classList.remove('opp-row-active'); });
  row.classList.add('opp-row-active');

  // Show panel + backdrop + lock body scroll
  const backdrop = document.getElementById('oppBackdrop');
  backdrop.classList.remove('opacity-0', 'pointer-events-none');
  document.getElementById('oppPanel').classList.add('is-open');
  document.body.style.overflow = 'hidden';
}

function closeOppPanel() {
  document.getElementById('oppBackdrop').classList.add('opacity-0', 'pointer-events-none');
  document.getElementById('oppPanel').classList.remove('is-open');
  document.querySelectorAll('[data-idx]').forEach(function(tr) { tr.classList.remove('opp-row-active'); });
  document.body.style.overflow = '';
}

// Close on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeOppPanel();
});
</script>

</body>
</html>
