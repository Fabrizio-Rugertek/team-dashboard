                <% } else { %><span class="text-slate-300 text-xs">\u2014</span><% } %>
              </td>
              <td class="px-4 py-2.5 text-right text-xs font-bold text-slate-800"><%= s.revenue > 0 ? s.revenueFmt : '\u2014' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
