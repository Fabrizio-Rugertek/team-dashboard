          </thead>
          <tbody>
            <% allSources.slice(0, 12).forEach(function(s) { %>
            <tr class="drill-row border-b border-slate-50" onclick="applyFilter('source', '<%= s.id || '' %>')">
              <td class="px-4 py-2.5 font-medium text-slate-700 truncate max-w-xs">
                <%= s.name %>
                <span class="ml-1 text-[10px] text-amber-400 font-medium">filtrar &rarr;</span>
              </td>
              <td class="px-4 py-2.5 text-right text-slate-700 font-medium"><%= s.count %></td>
              <td class="px-4 py-2.5 text-right text-blue-600"><%= s.active %></td>
              <td class="px-4 py-2.5 text-right font-bold text-green-700"><%= s.won %></td>
              <td class="px-4 py-2.5 text-right">
                <% if ((s.won + s.lost) > 0) { %>
                <span class="px-2 py-0.5 rounded-full text-xs font-bold <%= s.winPct >= 50 ? 'bg-green-100 text-green-700' : s.winPct >= 30 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-700' %>">
                  <%= s.winPct %>%
