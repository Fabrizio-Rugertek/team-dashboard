    <% var maxSrcCount = allSources[0] ? allSources[0].count : 1; %>
    <div class="space-y-2">
    <% allSources.slice(0, 12).forEach(function(s) {
         var pct     = Math.max(2, Math.round(s.count / maxSrcCount * 100));
         var wonPct2 = s.count > 0 ? Math.round(s.won / s.count * 100) : 0;
       %>
      <div class="drill-bar -mx-2 px-2 py-1.5 rounded-lg" onclick="applyFilter('source', '<%= s.id || '' %>')">
        <div class="flex items-center justify-between mb-0.5">
          <span class="text-xs font-medium text-slate-700 truncate" style="max-width:55%"><%= s.name %></span>
          <div class="flex items-center gap-2 text-xs text-slate-400">
            <span><%= s.count %> leads</span>
            <% if (s.won > 0) { %><span class="text-green-600 font-semibold"><%= s.won %> won</span><% } %>
