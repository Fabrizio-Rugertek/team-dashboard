        <div class="w-full bg-slate-100 rounded-full h-2 relative">
          <div class="bg-indigo-400 h-2 rounded-full absolute top-0 left-0" style="width:<%= pct %>%"></div>
          <% if (wonPct2 > 0) { %>
          <div class="bg-green-500 h-2 rounded-full absolute top-0 left-0" style="width:<%= Math.max(1, Math.round(wonPct2 * pct / 100)) %>%"></div>
          <% } %>
        </div>
      </div>
    <% }); %>
    </div>
    <div class="mt-3 flex items-center gap-4 text-xs text-slate-400">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-indigo-400 inline-block"></span>Total leads</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>Won</span>
    </div>
  </div>

  <% } /* end if allSources.length > 0 */ %>

</div><!-- /tab-fuentes -->


