          <th class="px-5 py-2.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">Oportunidades</th>
          <th class="px-5 py-2.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">% del Total</th>
          <th class="px-5 py-2.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">Valor Pipeline</th>
        </tr>
      </thead>
      <tbody>
        <% (crm.byStage || []).forEach(function(s) {
             var pctTotal = totalFunnel > 0 ? Math.round(s.count / totalFunnel * 100) : 0;
             var valFmt = s.value >= 1e9 ? ('\u20b2' + (s.value/1e9).toFixed(1) + 'B') :
                          s.value >= 1e6 ? ('\u20b2' + Math.round(s.value/1e6) + 'M') :
                          ('\u20b2' + Math.round(s.value).toLocaleString('es-PY'));
           %>
        <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="px-5 py-2.5 font-medium text-slate-700"><%= s.name %></td>
          <td class="px-5 py-2.5 text-right font-bold text-slate-800"><%= s.count %></td>
