<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" type="image/png" href="/img/torus-icon-green.png">
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/marked@14/marked.min.js"></script>
<style>
  * { font-family: 'Inter', sans-serif; }
  textarea { font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.6; }
  .prose code { font-family: 'JetBrains Mono', monospace; font-size: 0.875em; background: #f1f5f9; padding: 0.125em 0.4em; border-radius: 4px; }
  .prose pre { background: #0f172a; color: #e2e8f0; padding: 1em; border-radius: 8px; overflow-x: auto; }
  .prose pre code { background: transparent; padding: 0; color: inherit; }
  .prose h1 { font-size: 1.6rem; font-weight: 800; margin: 0 0 0.5em; color: #0f172a; }
  .prose h2 { font-size: 1.3rem; font-weight: 700; margin: 1.2em 0 0.4em; color: #1e293b; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.2em; }
  .prose h3 { font-size: 1.1rem; font-weight: 700; margin: 1em 0 0.3em; color: #334155; }
  .prose p { margin: 0.6em 0; line-height: 1.6; color: #334155; }
  .prose ul, .prose ol { margin: 0.6em 0; padding-left: 1.5em; line-height: 1.6; color: #334155; }
  .prose table { border-collapse: collapse; margin: 0.8em 0; font-size: 0.85em; width: 100%; }
  .prose th, .prose td { padding: 0.4em 0.6em; border: 1px solid #e2e8f0; text-align: left; }
  .prose th { background: #f8fafc; font-weight: 700; }
  .prose a { color: #2563eb; text-decoration: underline; }
</style>
</head>
<body class="bg-slate-50 h-screen flex flex-col overflow-hidden">

<header class="bg-white border-b px-6 py-3 flex items-center justify-between flex-shrink-0">
  <div>
    <a href="/sop/md/<%= company %>/<%= slug %>" class="text-sm text-slate-500 hover:text-slate-700">← Volver al viewer</a>
    <h1 class="text-lg font-bold text-slate-900 mt-1">Editando: <code class="text-sm"><%= company %>/<%= slug %>.md</code></h1>
  </div>
  <div class="flex items-center gap-3">
    <span id="status" class="text-sm text-slate-500"></span>
    <button id="saveBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-semibold text-sm transition disabled:opacity-50">
      💾 Guardar (commit + push)
    </button>
  </div>
</header>

<main class="flex-1 grid grid-cols-2 gap-0 overflow-hidden">
  <div class="border-r flex flex-col bg-white">
    <div class="px-4 py-2 border-b bg-slate-50 text-xs font-semibold text-slate-600 uppercase">Markdown</div>
    <textarea id="editor" class="flex-1 p-4 outline-none resize-none border-0" spellcheck="false"><%= content %></textarea>
  </div>
  <div class="flex flex-col bg-white">
    <div class="px-4 py-2 border-b bg-slate-50 text-xs font-semibold text-slate-600 uppercase">Preview</div>
    <article id="preview" class="prose max-w-none flex-1 p-6 overflow-y-auto"></article>
  </div>
</main>

<script>
  const editor    = document.getElementById('editor');
  const preview   = document.getElementById('preview');
  const saveBtn   = document.getElementById('saveBtn');
  const status    = document.getElementById('status');
  const company   = <%- JSON.stringify(company) %>;
  const slug      = <%- JSON.stringify(slug) %>;

  function render() {
    preview.innerHTML = marked.parse(editor.value);
  }
  editor.addEventListener('input', render);
  render();

  let savedContent = editor.value;
  function setStatus(text, color) {
    status.textContent = text;
    status.className = 'text-sm ' + (color || 'text-slate-500');
  }
  setInterval(() => {
    if (editor.value !== savedContent) setStatus('● Cambios sin guardar', 'text-amber-600');
  }, 1000);

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    setStatus('⏳ Guardando + commit + push…', 'text-slate-600');
    try {
      const r = await fetch(`/sop/md/${company}/${slug}/save`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: editor.value }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'save failed');
      savedContent = editor.value;
      if (j.committed) {
        setStatus('✓ Guardado y pusheado a GitHub. Reindex MCP en background.', 'text-emerald-600');
      } else {
        setStatus('✓ Sin cambios para commitear (idéntico al actual).', 'text-emerald-600');
      }
    } catch (e) {
      setStatus('✗ Error: ' + e.message, 'text-red-600');
    } finally {
      saveBtn.disabled = false;
    }
  });

  window.addEventListener('beforeunload', e => {
    if (editor.value !== savedContent) e.returnValue = 'Tenés cambios sin guardar';
  });
</script>
</body>
</html>
