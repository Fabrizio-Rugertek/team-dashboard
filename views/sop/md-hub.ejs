<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" type="image/png" href="/img/torus-icon-green.png">
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>* { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen">
<nav class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm"><div class="max-w-7xl mx-auto px-5 py-3 flex items-center justify-between"><div class="flex items-center gap-3"><img src="/img/torus-icon-green.png" alt="Torus" class="h-7 w-auto"><span class="text-slate-300">/</span><a href="/" class="text-slate-400 text-sm font-medium hover:text-slate-600">Dashboard</a><span class="text-slate-300">/</span><a href="/sop" class="text-slate-400 text-sm font-medium hover:text-slate-600">SOPs</a><span class="text-slate-300">/</span><span class="text-sm font-bold text-slate-800">Markdown</span></div><% if (typeof user !== "undefined" && user) { %><div class="flex items-center gap-3"><span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span><form action="/auth/logout" method="POST" class="inline"><button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50">Salir</button></form></div><% } %></div></nav>

<main class="max-w-6xl mx-auto px-6 py-10">
  <div class="mb-8">
    <a href="/sop" class="text-sm text-slate-500 hover:text-slate-700">← Volver a SOPs hub</a>
    <h1 class="mt-2 text-3xl font-extrabold text-slate-900">📚 SOPs Detallados</h1>
    <p class="mt-2 text-slate-600">
      Procedimientos operativos en formato narrativo. Editables — los cambios se commitean
      automáticamente al repo <code class="text-xs bg-slate-200 px-1 rounded">fabri-context</code>
      y el cerebro (MCP) se reindexa.
    </p>
  </div>

  <% if (!summary.length) { %>
    <div class="bg-white border rounded-xl p-8 text-center text-slate-500">
      No hay SOPs markdown todavía. Verificar que <code>FABRI_CONTEXT_PATH</code> esté configurado.
    </div>
  <% } %>

  <div class="grid md:grid-cols-2 gap-5">
    <% summary.forEach(({ company, sops }) => { %>
      <a href="/sop/md/<%= company %>" class="block bg-white border rounded-xl p-6 hover:border-blue-400 hover:shadow transition">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-xl font-bold text-slate-900 capitalize"><%= company %></h2>
          <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded font-semibold"><%= sops.length %> SOPs</span>
        </div>
        <ul class="text-sm text-slate-600 space-y-1 mt-3">
          <% sops.slice(0, 5).forEach(s => { %>
            <li class="truncate">• <%= s.title %></li>
          <% }) %>
          <% if (sops.length > 5) { %>
            <li class="text-slate-400">y <%= sops.length - 5 %> más…</li>
          <% } %>
        </ul>
      </a>
    <% }) %>
  </div>
</main>
</body>
</html>
