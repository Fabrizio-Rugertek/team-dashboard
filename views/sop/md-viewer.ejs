<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" type="image/png" href="/img/torus-icon-green.png">
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  * { font-family: 'Inter', sans-serif; }
  .prose code { font-family: 'JetBrains Mono', monospace; font-size: 0.875em; background: #f1f5f9; padding: 0.125em 0.4em; border-radius: 4px; }
  .prose pre { background: #0f172a; color: #e2e8f0; padding: 1em; border-radius: 8px; overflow-x: auto; }
  .prose pre code { background: transparent; padding: 0; color: inherit; }
  .prose h1 { font-size: 2rem; font-weight: 800; margin-top: 0; margin-bottom: 0.5em; color: #0f172a; }
  .prose h2 { font-size: 1.5rem; font-weight: 700; margin-top: 1.5em; margin-bottom: 0.5em; color: #1e293b; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.25em; }
  .prose h3 { font-size: 1.2rem; font-weight: 700; margin-top: 1.25em; margin-bottom: 0.4em; color: #334155; }
  .prose h4 { font-size: 1.05rem; font-weight: 700; margin-top: 1em; margin-bottom: 0.3em; color: #475569; }
  .prose p { margin: 0.75em 0; line-height: 1.7; color: #334155; }
  .prose ul, .prose ol { margin: 0.75em 0; padding-left: 1.5em; line-height: 1.7; color: #334155; }
  .prose li { margin: 0.25em 0; }
  .prose table { border-collapse: collapse; margin: 1em 0; font-size: 0.9em; width: 100%; }
  .prose th { background: #f8fafc; font-weight: 700; text-align: left; padding: 0.5em 0.75em; border: 1px solid #e2e8f0; }
  .prose td { padding: 0.5em 0.75em; border: 1px solid #e2e8f0; }
  .prose blockquote { border-left: 4px solid #94a3b8; padding-left: 1em; color: #475569; font-style: italic; margin: 1em 0; }
  .prose hr { border: 0; border-top: 1px solid #e2e8f0; margin: 2em 0; }
  .prose a { color: #2563eb; text-decoration: underline; }
  .prose a:hover { color: #1d4ed8; }
</style>
</head>
<body class="bg-slate-50 min-h-screen">
<nav class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm"><div class="max-w-7xl mx-auto px-5 py-3 flex items-center justify-between"><div class="flex items-center gap-3"><img src="/img/torus-icon-green.png" alt="Torus" class="h-7 w-auto"><span class="text-slate-300">/</span><a href="/" class="text-slate-400 text-sm font-medium hover:text-slate-600">Dashboard</a><span class="text-slate-300">/</span><a href="/sop" class="text-slate-400 text-sm font-medium hover:text-slate-600">SOPs</a><span class="text-slate-300">/</span><span class="text-sm font-bold text-slate-800">Markdown</span></div><% if (typeof user !== "undefined" && user) { %><div class="flex items-center gap-3"><span class="text-xs font-medium text-slate-600 hidden sm:block"><%= user.name || user.email %></span><form action="/auth/logout" method="POST" class="inline"><button class="text-xs text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50">Salir</button></form></div><% } %></div></nav>

<main class="max-w-4xl mx-auto px-6 py-10">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <a href="/sop/md/<%= company %>" class="text-sm text-slate-500 hover:text-slate-700">← Volver a SOPs <%= company %></a>
      <div class="text-xs text-slate-400 mt-1">
        <code><%= slug %>.md</code> · Modificado <%= new Date(modifiedAt).toLocaleString('es-PY') %>
      </div>
    </div>
    <% if (canEdit) { %>
      <a href="/sop/md/<%= company %>/<%= slug %>/edit"
         class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-semibold text-sm transition">
        ✎ Editar
      </a>
    <% } %>
  </div>

  <article class="prose max-w-none bg-white border rounded-xl p-8">
    <%- html %>
  </article>
</main>
</body>
</html>
