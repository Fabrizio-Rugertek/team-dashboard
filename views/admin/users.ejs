<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>* { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-100 min-h-screen">

<%# Nav %>
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white text-sm">T</div>
      <span class="font-bold text-slate-900">Torus</span>
      <span class="text-slate-300">·</span>
      <span class="text-sm font-semibold text-slate-700">Gestión de Usuarios</span>
      <span class="text-slate-300">·</span>
      <a href="/equipo" class="text-sm text-blue-600 hover:text-blue-800 font-medium">← Equipo</a>
    </div>
    <div class="flex items-center gap-3 text-xs text-slate-500">
      <span><%= currentUser.email %></span>
      <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-bold uppercase"><%= currentUser.role %></span>
      <form action="/auth/logout" method="POST" class="inline">
        <button class="text-red-500 hover:text-red-700 font-semibold">Salir</button>
      </form>
    </div>
  </div>
</nav>

<div class="max-w-4xl mx-auto px-4 py-8 space-y-6">

  <%# Flash messages %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700 font-medium">⚠ <%= error %></div>
  <% } %>
  <% if (typeof success === 'string' && success || (typeof locals.query !== 'undefined')) { %>
  <% const q = typeof locals.query !== 'undefined' ? locals.query : {}; %>
  <% if (q.success) { %>
  <div class="p-4 rounded-xl bg-green-50 border border-green-200 text-sm text-green-700 font-medium">
    ✓ <%= q.success === 'added' ? 'Usuario agregado.' : q.success === 'deleted' ? 'Usuario eliminado.' : 'Cambios guardados.' %>
  </div>
  <% } %>
  <% if (q.error) { %>
  <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700 font-medium">⚠ <%= q.error %></div>
  <% } %>
  <% } %>

  <%# Role legend %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="font-bold text-slate-900 mb-3">Roles y permisos</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-sm">
      <div class="rounded-lg border border-blue-200 bg-blue-50 p-3">
        <div class="font-bold text-blue-700 mb-1">Admin</div>
        <div class="text-blue-600 text-xs space-y-0.5">
          <div>✓ Dashboard Equipo</div>
          <div>✓ Dashboard Finanzas</div>
          <div>✓ Gestión de usuarios</div>
          <div>✓ Todas las vistas</div>
        </div>
      </div>
      <div class="rounded-lg border border-purple-200 bg-purple-50 p-3">
        <div class="font-bold text-purple-700 mb-1">Director</div>
        <div class="text-purple-600 text-xs space-y-0.5">
          <div>✓ Dashboard Equipo</div>
          <div>✓ Dashboard Finanzas</div>
          <div>✗ Gestión de usuarios</div>
        </div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
        <div class="font-bold text-slate-700 mb-1">Consultant</div>
        <div class="text-slate-600 text-xs space-y-0.5">
          <div>✓ Dashboard Equipo</div>
          <div>✗ Dashboard Finanzas</div>
          <div>✗ Gestión de usuarios</div>
        </div>
      </div>
    </div>
  </div>

  <%# Add user form %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="font-bold text-slate-900 mb-4">Invitar usuario</h2>
    <form action="/admin/users" method="POST" class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-48">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1">Email de Google</label>
        <input type="email" name="email" required placeholder="usuario@empresa.com"
               class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
      </div>
      <div class="w-36">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1">Nombre (opc.)</label>
        <input type="text" name="name" placeholder="Nombre apellido"
               class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
      </div>
      <div class="w-36">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1">Rol</label>
        <select name="role" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
          <option value="consultant">Consultant</option>
          <option value="director">Director</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <button type="submit"
              class="bg-blue-600 text-white text-sm font-bold px-5 py-2 rounded-lg hover:bg-blue-700 transition-colors">
        Agregar
      </button>
    </form>
  </div>

  <%# Users table %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
      <h2 class="font-bold text-slate-900">Usuarios autorizados (<%= users.length %>)</h2>
    </div>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-100 text-xs">
          <th class="text-left py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Email</th>
          <th class="text-left py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Nombre</th>
          <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Rol</th>
          <th class="text-left py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Agregado</th>
          <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="border-b border-slate-50 hover:bg-slate-50 <%= u.email === currentUser.email ? 'bg-blue-50/50' : '' %>">
          <td class="py-3 px-4">
            <div class="font-medium text-slate-900"><%= u.email %></div>
            <% if (u.email === currentUser.email) { %><div class="text-xs text-blue-500 font-semibold">Vos</div><% } %>
          </td>
          <td class="py-3 px-4 text-slate-600"><%= u.name || '-' %></td>
          <td class="py-3 px-4 text-center">
            <% if (u.email !== currentUser.email) { %>
            <form action="/admin/users/<%= encodeURIComponent(u.email) %>/role" method="POST" class="inline-flex items-center gap-2">
              <select name="role" onchange="this.form.submit()"
                      class="text-xs border border-slate-200 rounded-lg px-2 py-1 focus:outline-none focus:ring-2 focus:ring-blue-300">
                <% roles.forEach(r => { %>
                <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= r %></option>
                <% }) %>
              </select>
            </form>
            <% } else { %>
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700"><%= u.role %></span>
            <% } %>
          </td>
          <td class="py-3 px-4 text-xs text-slate-400">
            <% if (u.addedAt) { %>
            <%= new Date(u.addedAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }) %>
            <% if (u.addedBy) { %><div class="text-slate-300">por <%= u.addedBy %></div><% } %>
            <% } else { %><span>—</span><% } %>
          </td>
          <td class="py-3 px-4 text-center">
            <% if (u.email !== currentUser.email) { %>
            <form action="/admin/users/<%= encodeURIComponent(u.email) %>/delete" method="POST"
                  onsubmit="return confirm('Eliminar acceso de <%= u.email %>?')">
              <button type="submit"
                      class="text-xs text-red-500 hover:text-red-700 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors">
                Eliminar
              </button>
            </form>
            <% } else { %>
            <span class="text-xs text-slate-300">—</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
        <% if (!users.length) { %>
        <tr><td colspan="5" class="py-10 text-center text-slate-400">No hay usuarios registrados.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<script>
// Auto-dismiss flash messages
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.has('success') || urlParams.has('error')) {
  const url = new URL(window.location);
  url.searchParams.delete('success');
  url.searchParams.delete('error');
  window.history.replaceState({}, '', url.toString());
}
</script>
</body>
</html>
