<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/torus-icon-green.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: #F8FAFC; }
    .view-chip { @apply inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold; }
    .toggle-row { transition: background 0.15s; }
    .toggle-row:hover { background: #F8FAFC; }
  </style>
</head>
<body class="min-h-screen">

<%
  // Flash messages from query params
  const qSuccess = (locals.query || {}).success || new URLSearchParams(
    typeof window !== 'undefined' ? window.location.search : ''
  );
  // Parse query manually from req — passed via template or read from rendered URL
  // Use a simple pattern: read ?success and ?error from the URL at client side
%>

<!-- ── Nav ──────────────────────────────────────────────────────────────── -->
<nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 py-0 flex items-center justify-between h-14">
    <div class="flex items-center gap-3">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-violet-600 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <span class="font-bold text-slate-900 text-sm">Torus</span>
      </a>
      <span class="text-slate-300">/</span>
      <span class="font-semibold text-slate-700 text-sm">Administración</span>
    </div>
    <div class="flex items-center gap-4">
      <a href="/equipo" class="text-xs font-semibold text-slate-500 hover:text-blue-600 transition-colors">← Equipo</a>
      <div class="flex items-center gap-2">
        <% if (currentUser.picture) { %>
        <img src="<%= currentUser.picture %>" class="w-7 h-7 rounded-full" alt="">
        <% } else { %>
        <div class="w-7 h-7 rounded-full bg-violet-100 flex items-center justify-center text-xs font-bold text-violet-600"><%= (currentUser.name || currentUser.email).charAt(0).toUpperCase() %></div>
        <% } %>
        <div class="hidden sm:block text-right">
          <div class="text-xs font-semibold text-slate-700"><%= currentUser.name || currentUser.email %></div>
          <div class="text-[10px] text-violet-500 font-bold uppercase"><%= currentUser.role %></div>
        </div>
      </div>
      <form action="/auth/logout" method="POST" class="inline">
        <button class="text-xs text-red-400 hover:text-red-600 font-semibold transition-colors">Salir</button>
      </form>
    </div>
  </div>
</nav>

<div class="max-w-6xl mx-auto px-4 py-8 space-y-6">

  <!-- ── Flash messages (rendered client-side from query params) ── -->
  <div id="flashMsg" class="hidden"></div>

  <!-- ── Header ───────────────────────────────────────────────────── -->
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-black text-slate-900">Gestión de Accesos</h1>
      <p class="text-sm text-slate-500 mt-1">Controlá quién puede acceder a cada sección de la plataforma.</p>
    </div>
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-slate-100 font-mono text-[11px] text-slate-500 shrink-0 mt-1"
          title="Deploy: <%= appDeployAt %>">v<%= appVersion %></span>
  </div>

  <!-- ── Stats bar ──────────────────────────────────────────────── -->
  <%
    const totalUsers = users.length;
    const byView = {
      equipo:   users.filter(u => u.effectiveViews.includes('equipo')).length,
      finanzas: users.filter(u => u.effectiveViews.includes('finanzas')).length,
      admin:    users.filter(u => u.effectiveViews.includes('admin')).length,
    };
  %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
      <div class="text-3xl font-black text-slate-800"><%= totalUsers %></div>
      <div class="text-xs text-slate-500 font-semibold mt-1">Usuarios totales</div>
    </div>
    <div class="bg-blue-50 rounded-xl border border-blue-200 p-4 text-center">
      <div class="text-3xl font-black text-blue-600"><%= byView.equipo %></div>
      <div class="text-xs text-blue-500 font-semibold mt-1">Acceso Equipo</div>
    </div>
    <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4 text-center">
      <div class="text-3xl font-black text-emerald-600"><%= byView.finanzas %></div>
      <div class="text-xs text-emerald-500 font-semibold mt-1">Acceso Finanzas</div>
    </div>
    <div class="bg-violet-50 rounded-xl border border-violet-200 p-4 text-center">
      <div class="text-3xl font-black text-violet-600"><%= byView.admin %></div>
      <div class="text-xs text-violet-500 font-semibold mt-1">Acceso Admin</div>
    </div>
  </div>

  <!-- ── Add user form ──────────────────────────────────────────── -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
      Invitar usuario
    </h2>
    <form action="/admin/users" method="POST">
      <div class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-52">
          <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Email de Google</label>
          <input type="email" name="email" required placeholder="usuario@rugertek.com"
                 class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400">
        </div>
        <div class="w-44">
          <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Nombre (opcional)</label>
          <input type="text" name="name" placeholder="Nombre Apellido"
                 class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-300 focus:border-violet-400">
        </div>
        <div>
          <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Acceso inicial</label>
          <div class="flex gap-3 pt-1">
            <% const viewConfig = [
              { id: 'equipo',   label: 'Equipo',   color: 'blue'   },
              { id: 'finanzas', label: 'Finanzas', color: 'emerald'},
              { id: 'admin',    label: 'Admin',    color: 'violet' },
            ]; %>
            <% viewConfig.forEach(v => { %>
            <label class="flex items-center gap-1.5 cursor-pointer select-none">
              <input type="checkbox" name="views" value="<%= v.id %>"
                     <%= v.id === 'equipo' ? 'checked' : '' %>
                     class="w-3.5 h-3.5 rounded accent-<%= v.color %>-600">
              <span class="text-sm text-slate-700 font-medium"><%= v.label %></span>
            </label>
            <% }) %>
          </div>
        </div>
        <button type="submit"
                class="bg-violet-600 text-white text-sm font-bold px-5 py-2 rounded-lg hover:bg-violet-700 transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Agregar
        </button>
      </div>
    </form>
  </div>

  <!-- ── Users table ────────────────────────────────────────────── -->
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
      <h2 class="font-bold text-slate-900">Usuarios autorizados <span class="text-slate-400 font-normal">(<%= users.length %>)</span></h2>
      <div class="hidden sm:flex items-center gap-4 text-xs text-slate-400">
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-blue-400 inline-block"></span>Equipo</span>
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-emerald-400 inline-block"></span>Finanzas</span>
        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-violet-400 inline-block"></span>Admin</span>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-100 text-xs">
            <th class="text-left py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Usuario</th>
            <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Equipo</th>
            <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Finanzas</th>
            <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Admin</th>
            <th class="text-left py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide hidden lg:table-cell">Agregado</th>
            <th class="text-center py-3 px-4 font-semibold text-slate-500 uppercase tracking-wide">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => {
            const isSelf = u.email === currentUser.email;
          %>
          <tr class="border-b border-slate-50 toggle-row <%= isSelf ? 'bg-violet-50/40' : '' %>">

            <!-- User info -->
            <td class="py-3 px-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0
                            <%= isSelf ? 'bg-violet-100 text-violet-700' : 'bg-slate-100 text-slate-500' %>">
                  <%= (u.name || u.email).charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="font-semibold text-slate-900 text-xs"><%= u.name || '—' %></div>
                  <div class="text-[11px] text-slate-400"><%= u.email %></div>
                  <% if (isSelf) { %><div class="text-[10px] text-violet-500 font-bold">Vos</div><% } %>
                </div>
              </div>
            </td>

            <!-- View toggles -->
            <% if (!isSelf) { %>
            <% ['equipo', 'finanzas', 'admin'].forEach(view => {
              const hasAccess = u.effectiveViews.includes(view);
              const viewColors = { equipo: 'blue', finanzas: 'emerald', admin: 'violet' };
              const col = viewColors[view];
            %>
            <td class="py-3 px-4 text-center">
              <form action="/admin/users/<%= encodeURIComponent(u.email) %>/views" method="POST" id="form-<%= u.email.replace('@','_').replace('.','_') %>-<%= view %>">
                <%# Send all current views except this one, toggling it %>
                <% u.effectiveViews.filter(v => v !== view).forEach(v => { %>
                <input type="hidden" name="views" value="<%= v %>">
                <% }) %>
                <% if (!hasAccess) { %>
                <input type="hidden" name="views" value="<%= view %>">
                <% } %>
                <button type="submit"
                        class="w-8 h-8 mx-auto rounded-lg border-2 flex items-center justify-center transition-all
                               <%= hasAccess
                                 ? 'bg-' + col + '-100 border-' + col + '-300 text-' + col + '-600 hover:bg-' + col + '-200'
                                 : 'bg-slate-50 border-slate-200 text-slate-300 hover:border-slate-300 hover:bg-slate-100' %>"
                        title="<%= hasAccess ? 'Quitar acceso a ' + view : 'Dar acceso a ' + view %>">
                  <% if (hasAccess) { %>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <% } else { %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% } %>
                </button>
              </form>
            </td>
            <% }) %>
            <% } else { %>
            <!-- Self: show read-only badges -->
            <% ['equipo', 'finanzas', 'admin'].forEach(view => {
              const hasAccess = u.effectiveViews.includes(view);
              const viewColors = { equipo: 'blue', finanzas: 'emerald', admin: 'violet' };
              const col = viewColors[view];
            %>
            <td class="py-3 px-4 text-center">
              <div class="w-8 h-8 mx-auto rounded-lg border-2 flex items-center justify-center
                          <%= hasAccess
                            ? 'bg-' + col + '-100 border-' + col + '-300 text-' + col + '-600'
                            : 'bg-slate-50 border-slate-200 text-slate-300' %>">
                <% if (hasAccess) { %>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <% } else { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                <% } %>
              </div>
            </td>
            <% }) %>
            <% } %>

            <!-- Added at -->
            <td class="py-3 px-4 hidden lg:table-cell">
              <% if (u.addedAt) { %>
              <div class="text-xs text-slate-500"><%= new Date(u.addedAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
              <% if (u.addedBy) { %><div class="text-[10px] text-slate-300">por <%= u.addedBy %></div><% } %>
              <% } else { %><span class="text-xs text-slate-300">—</span><% } %>
            </td>

            <!-- Delete -->
            <td class="py-3 px-4 text-center">
              <% if (!isSelf) { %>
              <form action="/admin/users/<%= encodeURIComponent(u.email) %>/delete" method="POST"
                    onsubmit="return confirm('¿Eliminar acceso de <%= u.email %>? Esta acción no se puede deshacer.')">
                <button type="submit"
                        class="w-7 h-7 mx-auto rounded-lg border border-red-200 bg-red-50 text-red-400 hover:bg-red-100 hover:text-red-600 flex items-center justify-center transition-colors"
                        title="Eliminar usuario">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </form>
              <% } else { %>
              <div class="w-7 h-7 mx-auto rounded-lg flex items-center justify-center text-slate-200" title="No podés eliminar tu propio acceso">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </div>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!users.length) { %>
          <tr>
            <td colspan="7" class="py-14 text-center text-slate-400">
              <div class="text-3xl mb-2">👤</div>
              <div class="font-semibold">Sin usuarios registrados</div>
              <div class="text-xs mt-1">Agregá el primer usuario usando el formulario de arriba.</div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Permission reference ──────────────────────────────────── -->
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="font-bold text-slate-900 mb-4 text-sm">Referencia de vistas</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">👥</span>
          <span class="font-bold text-blue-700 text-sm">Equipo</span>
          <span class="ml-auto text-[10px] bg-blue-200 text-blue-700 font-bold px-1.5 py-0.5 rounded">/equipo</span>
        </div>
        <div class="text-xs text-blue-600 space-y-1">
          <div>Control de consultores y horas</div>
          <div>Estado de proyectos y tareas</div>
          <div>Capacidad, sprints y alertas</div>
          <div>Anomalías de registro</div>
        </div>
      </div>
      <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">📊</span>
          <span class="font-bold text-emerald-700 text-sm">Finanzas</span>
          <span class="ml-auto text-[10px] bg-emerald-200 text-emerald-700 font-bold px-1.5 py-0.5 rounded">/finanzas</span>
        </div>
        <div class="text-xs text-emerald-600 space-y-1">
          <div>Ingresos, costos y márgenes</div>
          <div>Rentabilidad por cliente y producto</div>
          <div>CXC / CXP y flujo de caja</div>
          <div>Pipeline CRM y cierre YoY</div>
        </div>
      </div>
      <div class="rounded-xl border border-violet-200 bg-violet-50 p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">🔑</span>
          <span class="font-bold text-violet-700 text-sm">Admin</span>
          <span class="ml-auto text-[10px] bg-violet-200 text-violet-700 font-bold px-1.5 py-0.5 rounded">/admin</span>
        </div>
        <div class="text-xs text-violet-600 space-y-1">
          <div>Gestión de usuarios</div>
          <div>Control de accesos por vista</div>
          <div>Alta y baja de cuentas</div>
          <div>Auditoría de accesos</div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Footer -->
<div class="text-center text-xs text-slate-400 py-6 flex items-center justify-center gap-3">
  <span>Torus Dashboard Platform · <%= new Date().getFullYear() %></span>
  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-slate-100 font-mono text-slate-500"
        title="Deploy: <%= appDeployAt %>">v<%= appVersion %></span>
</div>

<script>
// ── Flash messages from query params ────────────────────────────────────────
(function() {
  const p = new URLSearchParams(window.location.search);
  const msg = document.getElementById('flashMsg');
  if (!msg) return;
  if (p.get('success')) {
    const text = p.get('success') === 'added'   ? 'Usuario agregado correctamente.'
               : p.get('success') === 'deleted' ? 'Usuario eliminado.'
               :                                   'Cambios guardados.';
    msg.className = 'p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700 font-medium flex items-center gap-2';
    msg.innerHTML = `<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>${text}`;
    msg.classList.remove('hidden');
    setTimeout(() => msg.classList.add('hidden'), 4000);
  }
  if (p.get('error')) {
    const errMap = {
      cant_delete_self:     'No podés eliminar tu propio acceso.',
      cant_edit_own_views:  'No podés modificar tus propios permisos.',
      cant_demote_self:     'No podés bajarte el rol a vos mismo.',
    };
    const text = errMap[p.get('error')] || decodeURIComponent(p.get('error'));
    msg.className = 'p-4 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700 font-medium flex items-center gap-2';
    msg.innerHTML = `<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>${text}`;
    msg.classList.remove('hidden');
    setTimeout(() => msg.classList.add('hidden'), 5000);
  }
  // Clean URL
  if (p.has('success') || p.has('error')) {
    const url = new URL(window.location.href);
    url.searchParams.delete('success');
    url.searchParams.delete('error');
    window.history.replaceState({}, '', url.toString());
  }
})();
</script>
</body>
</html>
